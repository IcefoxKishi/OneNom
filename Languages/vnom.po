msgstr "@niko 𫫡。。。"

#: Maps/POSTGAME RED GROUND/ground 1/Library entrance/Lobby/EV001:1:2:text
#: Maps/Red ground/ground
msgid "@niko_wtf What...are you doing...to that book?"
msgstr "@niko_wtf 舅當。。。𪵯之。。。卷冊妬丕？"

#: Maps/POSTGAME RED GROUND/ground 1/Library entrance/Lobby/EV001:1:3:text
msgid "Editing it!!!"
msgstr "當整𢯢伮渚哙之𡛤！！！"

#: Maps/POSTGAME RED GROUND/ground 1/Library entrance/Lobby/EV001:1:4:text
msgid "I've been in the Author's shadow for my entire career."
msgstr "𪝬㐌於𨑜琫作者創世𪥘󠄁事業耒。"

#: Maps/POSTGAME RED GROUND/ground 1/Library entrance/Lobby/EV001:1:5:text

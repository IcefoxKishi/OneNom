msgstr "@alula_pout 丕𪜀。。。舅𢯛𠫾耒唹？"

#: Maps/FINALE/Credits/map events:5:3:text
msgid "@calamus_smile We're glad we met you, Niko!"
msgstr "@calamus_smile 衆𨉟窒𢝙㐌得﨤舅、尼孤！"


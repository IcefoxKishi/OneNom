#: Maps/FINALE/Credits/EV070:1:38:choice:0 Maps/FINALE/Credits/map
#: events:5:43:choice:0
msgid "...will send them home soon."
msgstr "。。。𠱊𣋽迻𣱆𧗱茹催。"

#: Maps/FINALE/Credits/EV070:1:45:text Maps/FINALE/Credits/map events:5:50:text
msgid "@niko_speak Well, \\p says you're not dead!"
msgstr "@niko_speak 時、\\p吶哴舅𣗓𣩂！"

#: Maps/FINALE/Credits/EV070:1:47:text
msgid "@niko They said you'll be able to go back to your home very soon!"
msgstr "@niko 舅𧘇吶哴舅𠱊𠭤𧗱茹窒𣋽催！"

#: Maps/FINALE/Credits/EV071:1:2:text
msgid "@rue_smile Thank you for everything, Niko."
msgstr "@rue_smile 感恩㛪爲𤗆次㐌過。"

#: Maps/FINALE/Credits/EV071:1:3:text
msgid "@rue_sad We'll miss you."
msgstr "@rue_sad 𪨠姉𠱊𢖵㛪𡗋。"

#: Maps/FINALE/Credits/EV071:2:5:text
msgid "@rue This path leads to the summit of the tower."
msgstr "@rue 𡥵塘尼引𦤾頂座塔。"

#: Maps/FINALE/Credits/EV071:2:6:text
msgid "@rue You... \\.\\.already know what to expect, right?"
msgstr "@rue 㛪。。。\\.\\.㐌別於妬𣎏之耒、𠰚？"

#: Maps/FINALE/Credits/EV071:2:7:text
msgid "@niko Mhm..."
msgstr "@niko 𫫡。。。"

#: Maps/FINALE/Credits/EV071:2:8:text
msgid "@niko2 It's the glass room, right?"
msgstr "@niko2 𪜀間房鏡、𠰚？"

#: Maps/FINALE/Credits/EV071:2:9:text
msgid "@rue_smile That's it!"
msgstr "@rue_smile 董耒妬！"

#: Maps/FINALE/Credits/EV071:2:10:text
msgid "@rue You can go through this portal when you are ready."
msgstr "@rue 㛪𣎏体𠫾過𦑃𨶛尼欺𠻿𠳹。"

#: Maps/FINALE/Credits/EV071:2:23:text
msgid "@rue Goodbye, Niko."
msgstr "@rue 嘲暫別、尼孤。"

#: Maps/FINALE/Credits/@text:1:1:text
msgid "Roadcrosser"
msgstr "Roadcrosser"

#: Maps/FINALE/Credits/map events:1:5:text
msgid "@silver2 ...Messiah?"
msgstr "@silver2 。。。𠎬救世？"

#: Maps/FINALE/Credits/map events:1:6:text
msgid "@niko_surprised ROBOT LADY!!!!"
msgstr "@niko_surprised 姉𠊛𣛠！！！"

#: Maps/FINALE/Credits/map events:1:35:text
msgid "@niko_pancakes You're.... okay?"
msgstr "@niko_pancakes 姉吻。。。穩哰？"

#: Maps/FINALE/Credits/map events:1:36:text
msgid "@silver2 [I... think so.]"
msgstr "@silver2 【姉。。。擬勢。】"

#: Maps/FINALE/Credits/map events:1:37:text
msgid ""
"@silver_eyeclosed [The last thing I remember was the squares closing in on "
"me...]"
msgstr "@silver_eyeclosed 【次𡳳窮姉𢖵𪜀仍塊𣃱圍𥙩姉。。。】"

#: Maps/FINALE/Credits/map events:1:38:text
msgid "@silver2 [But then, I....\\.\\.ended up here unscathed.]"
msgstr "@silver2 【扔耒、姉。。。\\.\\.徠𠭤𧗱低無事。】"

#: Maps/FINALE/Credits/map events:1:40:text
msgid "@niko3 Is that so..."
msgstr "@niko3 實哰。。。"

#: Maps/FINALE/Credits/map events:1:42:text
msgid "@silver_lookup [...This is such a strange room.]"
msgstr "@silver_lookup 【間房尼奇𨓐實。】"

#: Maps/FINALE/Credits/map events:1:43:text
msgid "@silver2 [We can't be...\\.\\. in the Tower, can we?]"
msgstr "@silver2 【𪳨衆些空体。。。\\.\\.於𥪝座塔、董空？】"

#: Maps/FINALE/Credits/map events:1:44:text
msgid "@niko6 I'm actually not sure myself..."
msgstr "@niko6 寔𫥨㛪拱空昃𡗋。。。"

#: Maps/FINALE/Credits/map events:1:46:text
msgid "@silver2 [...where did YOU come from, anyway?]"
msgstr "@silver2 【。。。𦓡㛪𦤾自兜丕？】"

#: Maps/FINALE/Credits/map events:1:47:text
msgid "@niko2 The room where the World Machine was..."
msgstr "@niko2 房𧵑𣛠全世。。。"

#: Maps/FINALE/Credits/map events:1:48:text
msgid "@silver2 [...pardon?]"
msgstr "@silver2 【。。。之幾？】"

#: Maps/FINALE/Credits/map events:1:49:text
msgid "@niko5 I... think the World Machine is trying to remember, now..."
msgstr "@niko5 㛪擬。。。𣛠全世當固𠡚𢖵徠。。。"

#: Maps/FINALE/Credits/map events:1:50:text
msgid ""
"@niko4 The code that went bad...\\.\\.\\>\\n\\@niko2 I think it's restoring "
"it all."
msgstr "@niko4 仍斷碼閧。。。\\.\\.\\>\\n\\@niko2 㛪擬伮當復回衆。"

#: Maps/FINALE/Credits/map events:1:51:text
msgid "@niko6 That must've been why the squares were going away, \\p..."
msgstr "@niko6 昃𪜀爲勢𢧚仍塊𣃱㵋變𠅒妬\\p。。。"

#: Maps/FINALE/Credits/map events:1:52:text
msgid "@niko2 And... it's why you're here, miss!"
msgstr "@niko2 吧。。。爲勢𢧚姉㵋於低妬！"

#: Maps/FINALE/Credits/map events:1:53:text
msgid ""
"@niko_speak I think the World Machine was able to recover your code, too...!"
msgstr "@niko_speak 㛪擬𣛠世拱㐌復回徠得碼𧵑姉。。。！"

#: Maps/FINALE/Credits/map events:1:54:text
msgid "@silver2 [World... Machine, huh...]"
msgstr "@silver2 【𣛠。。。全世、嘑。。。】"

#: Maps/FINALE/Credits/map events:1:55:text
msgid "@niko2 Oh... I'm not sure if I should tell you this, but..."
msgstr "@niko2 溩。。。㛪空別𣎏𢧚吶朱姉空、仍𦓡。。。"

#: Maps/FINALE/Credits/map events:1:62:text
msgid "@silver2 [...What's that in the distance?]"
msgstr "@silver2 【。。。丐之其？】"

#: Maps/FINALE/Credits/map events:1:63:text
msgid "@silver [It... looks like a few more people are showing up.]"
msgstr "@silver 【𣎏𨤔。。。當𣎏𠊛㵋𦤾。"

#: Maps/FINALE/Credits/map events:1:64:text
msgid "@niko_pancakes Oh!!!"
msgstr "@niko_pancakes 溩！！！"

#: Maps/FINALE/Credits/map events:1:65:text
msgid "@silver2 [Are they... people you know?]"
msgstr "@silver2 【𣎏沛。。。𠊛慣𧵑㛪空？】"

#: Maps/FINALE/Credits/map events:1:66:text
msgid "@niko It's... \\.\\.a bit too far to tell."
msgstr "@niko 㛪。。。\\.\\.空𥆾𤑟𩈘𣱆𡗋。"

#: Maps/FINALE/Credits/map events:1:67:text
msgid "@niko_speak Come on, \\p, let's go take a closer look!"
msgstr "@niko_speak 𠫾催\\p、䀡𣱆𪜀埃鬧！"

#: Maps/FINALE/Credits/map events:2:2:text
msgid "@rowbot [THE HEAD ENGINEER CAN HELP ME DO NOT WORRY.]"
msgstr "@rowbot【技師長𣎏体𢴇𪝬吀揨𢥈。】"


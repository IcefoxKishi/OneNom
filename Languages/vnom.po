msgid ""
"@niko2 ...wait... didn't we find the magnets and stuff in the apartments, "
"\\p?"
msgstr "@niko2 。。。寬。。。拯沛衆𨉟尋𧡊埬南針吧各次恪𥪝區間戶哰、\\p？"

#: Maps/POSTGAME RED SKY/Elevator deck/npc_plight:2:58:text
msgid "@plight_worry The... what?"
msgstr "@plight_worry 埬。。。之幾？"

#: Maps/POSTGAME RED SKY/Elevator deck/npc_plight:2:59:text
msgid ""
"@niko_eyeclosed Looks like we'll have to find some other way to fix the "
"button, \\p..."

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:1:4:text
msgid "@niko Oh, sorry..."
msgstr "@niko 溩、吀纇。。。"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:1:5:text
msgid ""
"@niko_eyeclosed  I... kinda just walked in because the door was unlocked..."
msgstr "@niko_eyeclosed 𨉟。。。𠓨茹爲𨷶空銙。。。"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:1:6:text
msgid "@niko_speak Do you want me to leave?"
msgstr "@niko_speak 伴㦖𨉟𨖨𠫾哰？"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:1:7:text
msgid "[Scanning for Suspicious Activity.\\..\\..\\.]"
msgstr "【當𢭯尋活動可疑。\\.。\\.。\\.】"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:1:8:text
msgid "[Suspicious Activities Detected: 0 ]"
msgstr "【活動可疑尋𧡊：0】"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:1:9:text
msgid "@niko_eyeclosed Well, I guess as long as I don't do anything bad..."
msgstr "@niko_eyeclosed 時、裊𨉟空𪵯之差債。。。"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:2:1:text
msgid "[I Am. Still Monitoring You]"
msgstr "【𪝬吻。當蹺𠼲伴】"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:2:2:text
msgid "[Alert Level Has Been Set To Low]"
msgstr "【𣞪度警覺㐌得撻於𣞪隰】"

#: Maps/Red sky/Apartments/Hall1/Room1 - bot/npc_protectbot:2:3:text
msgid "@niko_speak Don't worry! I promise I'll be a good guest!"
msgstr "@niko_speak 揨𢥈！𨉟𠱊𪜀𠬠位客卒𦓡！"


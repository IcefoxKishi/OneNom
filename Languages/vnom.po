#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:1:text
msgid "@proto1 [Okay, all of us are here.]"
msgstr "@proto1 【得耒、衆些㐌𣎏𩈘𣹓覩。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:5:text
msgid "@proto1 [There is an emergency exit behind my computer terminal.]"
msgstr "@proto1 【𣎏𠬠𡓃脫險緊急𢖖󠄁𣛠𠯅令𧵑𪝬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:10:text
msgid ""
"@proto2 [We did not want anyone to stumble upon this route, so the terminal "
"has been weighed down.]"
msgstr "@proto2 【衆𪝬空㦖埃妬情期尋𫥨𡓃𠫾尼、𢧚𣛠𠯅令㐌被碮𬺗。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:11:text
msgid "@proto1 [It cannot be moved by normal means.]"
msgstr "@proto1 【空体移轉伮憑各方法通常。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:12:text
msgid "@proto2 [...But with our combined effort, it might budge.]"
msgstr "@proto2 【。。。扔裊衆些合飭、𣎏体伮𠱊移轉。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:13:text
msgid "@proto2b [...Maybe.]"
msgstr "@proto2b 【。。。懞勢。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:14:text
msgid "@proto2b [I am not strong.]"
msgstr "@proto2b 【英空劸𡗋。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:15:text

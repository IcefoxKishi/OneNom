msgstr "@niko_eyeclosed L𣎏𨤔塘倈只𦤾低催。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:46:text
msgid "@niko So...\\.\\.\\. where are we?"
msgstr "@niko 丕。。。\\.\\.\\. 衆些當於兜丕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:47:text
msgid "@silver_lookup [One of the old observation rooms.]"
msgstr "@silver_lookup 【𠬠房觀察𫇰。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:48:text
msgid "@silver2 [Looks like it's still mostly intact.]"
msgstr "@silver2 【𣎏𨤔吻哙可原捖。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:56:text
msgid "@silver2 [What...?]"
msgstr "@silver2 【丐之。。。？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:57:text
msgid "@niko2 Huh?"
msgstr "@niko2 嘑？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:88:text
msgid "@silver2 [The terminal just reactivated!]"
msgstr "@silver2 【𣛠𠯅令𣃣弼𬨠！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:89:text
msgid "@silver [But the power was cut off so long ago...]"
msgstr "@silver 【扔源電㐌被割自窒嘍耒。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:90:text
msgid "@niko6 Weird!"
msgstr "@niko6 𨓐實！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:91:text
msgid "@niko_speak Maybe... it runs on battery?"
msgstr "@niko_speak 𣎏体由。。。伮𧼋憑汴庄？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:95:text
msgid "@silver_eyeclosed [No... that's not it.]"
msgstr "@silver_eyeclosed 【空。。。空沛丕？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:96:text
msgid "@silver2 [Whatever it is, I need to investigate.]"
msgstr "@silver2 【怞伮𪜀之、姉吻沛調查。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:98:text
msgid "@silver2 [Will you be okay by yourself for a bit?]"
msgstr "@silver2 【㛪𣎏体於𠬠𨉟𠬠𣅶得渚？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:99:text
msgid "@niko_speak Don't worry! \\p's with me!"
msgstr "@niko_speak 姉揨𢥈！\\p𠱊於邊㛪！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/EV024:1:100:text
msgid "@silver_eyeclosed [Alright. Stay safe.]"
msgstr "@silver_eyeclosed 【得耒。謹慎唲。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/EV024:2:1:text
#: room/EV032:2:1:text
msgid "@niko4 I shouldn't get too close..."
msgstr "@niko4 𨉟空𢧚𦤾過近。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/EV033:2:2:text
#: Maps/SQUARES BE GONE/server
msgid "@niko It's not safe to use this minecart anymore, \\p."
msgstr "@niko 空体用車𡎡尼安全得𡛤兜、\\p。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/EV033:4:1:text
msgid "@niko_eyeclosed We can't use this anymore..."
msgstr "@niko_eyeclosed 𨉟空体用丐尼𡛤。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:2:text
msgid "@niko Still at it?"
msgstr "@niko 姉吻當調查哰？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:3:text
msgid "@silver_eyeclosed [Still at it.]"
msgstr "@silver_eyeclosed 【𫫡。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:7:text
msgid "@silver_eyeclosed [Not ideal.]"
msgstr "@silver_eyeclosed 【空理想𡗋。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:8:text
msgid ""
"@silver [Looks like these terminals are running on a completely separate "
"power source.]"
msgstr "@silver 【𣎏𨤔仍𣛠𠯅令尼𧼋𨑗𠬠源電剒別完全。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:9:text
msgid ""
"@silver2 [I can't really recognize any of the data formats on this terminal, "
"either.]"
msgstr "@silver2 【姉拱空体認樣不其定樣與料𨑗𣛠尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:10:text
msgid "@silver2 [This is all... new....]"
msgstr "@silver2 【𤗆次調。。。㵋。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:11:text
msgid "@silver_eyeclosed [...or at least, encrypted.]"
msgstr "@silver_eyeclosed 【。。。或𠃣一𪜀被碼化。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:12:text
msgid "@silver [I will need to analyze it through my own system.]"
msgstr "@silver 【姉𠱊沛分析伮憑係統𥢆𧵑姉。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:1:13:text
msgid "@silver [Might take some time, so you don't need to stay.]"
msgstr "@silver 【𠱊損可可時間、𢧚㛪空沛䟻兜。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:2:text
msgid "@silver [Oh, found another video feed...]"
msgstr "@silver 【溩、𠬠塘傳形影恪。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:3:text
msgid "@silver2 [I should definitely go look for the cameras later.]"
msgstr "@silver2 【姉沛𠫾尋各𣛠影𢖖󠄁催。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:4:text
msgid "@silver_eyeclosed [This is really bothering me...]"
msgstr "@silver_eyeclosed 【𠸋曉實蒂。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:8:text
msgid "@silver2 [This observation room... isn't for the mines...]"
msgstr "@silver2 【房觀察尼。。。空屬𧗱𡌢𡎡。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:9:text
msgid "@silver2 [I've actually never been into this particular one.]"
msgstr "@silver2 【寔𫥨姉𣗓𠓨房尼包𣇞。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:10:text
msgid "@niko2 Really?"
msgstr "@niko2 實唹？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:11:text
msgid "@niko You recognized it at first, though..."
msgstr "@niko 扔姉𣎏認𫥨伮𦓡。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:12:text
msgid "@silver_eyeclosed [They all look the same.]"
msgstr "@silver_eyeclosed 【爲衆調矓如僥𪥘󠄁。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:13:text
msgid "@niko_eyeclosed Fair enough!"
msgstr "@niko_eyeclosed 合理！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:15:text
msgid "@silver2 [I did find something interesting, though.]"
msgstr "@silver2 【雖然姉𣎏尋𧡊𠬠次可趣味。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:16:text
msgid "@silver_lookup [All the databases seem to encode video feeds.]"
msgstr "@silver_lookup 【全部各基礎與料調貯各塘傳形影。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:17:text
msgid "@silver [Right now, I can see various places in the Barrens.]"
msgstr "@silver 【現在、姉𣎏体𧡊各地点恪僥𥪝塳邊疆。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:18:text
msgid "@silver [The outpost... the residential areas...]"
msgstr "@silver 【據点。。。區民居。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:19:text
msgid "@silver2 [Even my own house.]"
msgstr "@silver2 【𪥘󠄁茹𧵑姉。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:20:text
msgid "@silver_eyeclosed [They're all shot from a top-down perspective, too.]"
msgstr "@silver_eyeclosed 【調𪜀𧣳𢮿自邊𨑗𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:21:text
msgid "@silver2 [...which means the cameras would have to be in the air.]"
msgstr "@silver2 【義𪜀𣛠𢮿沛於𨑗空。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:22:text
msgid "@silver_eyeclosed [But... I have never seen any cameras around.]"
msgstr "@silver_eyeclosed 【扔。。。姉貯曾𧡊不據𣛠𢮿鬧𨒺低。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:23:text
msgid "@niko_what That's kind of spooky!"
msgstr "@niko_what 𦖑𢜝實！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:24:text
msgid "@silver_eyeclosed [I might go investigate later, yeah.]"
msgstr "@silver_eyeclosed 【𫫡、𣎏欺姉沛𠫾調查務尼𢖖󠄁。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:25:text
msgid "@silver [Did you find anything interesting in the backroom?]"
msgstr "@silver 【掩𣎏𧡊之趣味𥪝間房其空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:26:text
msgid "@silver2 [You were in there for a while.]"
msgstr "@silver2 【㛪於𥪝妬可嘍妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:27:text
msgid "@niko_speak Yeah! We... \\.\\.\\@niko5 ...found...\\.\\.a"
msgstr "@niko_speak 𣎏！衆㛪。。。 \\.\\.\\@niko5 。。。尋𧡊。。。\\.\\.𠬠"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:28:text
msgid "@niko6 ...a dead end?"
msgstr "@niko6 。。。𠬠塘𡭕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver
#: stand:2:29:text
msgid "@silver_eyeclosed [I see.]"
msgstr "@silver_eyeclosed 【𫥨丕。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/silver

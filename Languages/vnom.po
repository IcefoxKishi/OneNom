msgstr "@silver_eyeclosed 【哺。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:47:text
msgid "@Silver [Come on.]"
msgstr "@Silver 【𠫾催。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:56:text
msgid "@proto_jealous [...Showoff.]"
msgstr "@proto_jealous 【。。。齊蒂。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/silver2:1:1:text
msgid "@silver [He says the exit is in here, but ...]"
msgstr "@silver 【英𧘇吶𡓃脫於𥪝尼、扔。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/silver2:1:2:text

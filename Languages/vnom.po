#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:1:3:text
msgid ""
"@george1_hm \"The Creation of Prophetbot\", one of the Author's greatest "
"works in my opinion."
msgstr "@george1_hm 「創造𣛠先知」、蹺𪝬𪜀𠬠𥪝仍作品偉大一𧵑作者創世。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:1:4:text
msgid ""
"@george1 It's filled to the brim with intricate illustrations and "
"blueprints... \\>\\n\\@george1_smile Lots of attention to detail, for sure."
msgstr ""
"@george1 𣹓浥仍形𦘧吧版樸草枝節。。。 \\>\\n\\@george1_smile 寔事作者㐌𢟙注𦤾"
"層枝節𡮈一。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:1:5:text
msgid "@george1_hm George rates it 10 out of 10."
msgstr "@george1_hm 觫打價10𨑗10。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:1:6:text entrance/Lobby/npc_george2:2:8:text
#: entrance/Lobby/npc_george2:4:8:text entrance/Lobby/npc_george2:5:6:text
#: entrance/Lobby/npc_george2:6:8:text Maps/FINALE/Credits/map events:5:17:text

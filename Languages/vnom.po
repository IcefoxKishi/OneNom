msgid "@niko Everyone in this room is fine!"
msgstr "@niko 悉𪥘󠄁𤗆𠊛於低調穩！"

#: Maps/FINALE/Credits/EV070:1:19:text Maps/FINALE/Credits/map events:5:25:text
msgid "@niko_speak You'll be able to go back home soon..."
msgstr "@niko_speak 英𠱊𠭤𧗱茹𣋽催。。。"

#: Maps/FINALE/Credits/EV070:1:20:text Maps/FINALE/Credits/EV070:1:48:text
msgid "@plight_sigh Oh thank goodness gracious."
msgstr "@plight_sigh 喂𥚄聖神𡗶𡐙。"


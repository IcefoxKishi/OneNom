#: Maps/Green/Village/House 4 - squares/fisherman npc:1:3:text
msgid "Squares are bad news, man. \\>\\nStay away from 'em, kids!"
msgstr "形𣃱𪜀䀨醜妬。\\>\\n𠬉賒衆𫥨唲！"

#: Maps/Green/Village/House 4 - squares/fisherman npc:1:4:text
msgid "@alula We will!"
msgstr "@alula 㐌曉！"

#: Maps/Green/Village/House 4 - squares/fisherman npc:1:7:text
msgid "Stay away from the squares, okay?"
msgstr "𠬉賒仍形𣃱𫥨、唲？"


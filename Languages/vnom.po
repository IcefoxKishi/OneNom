msgid "@ed [It doesn't respond to the remote.]"
msgstr "@ed 【伮空反應喟調遣。】"

msgid ""
"@ed [Niko looks at the buttons on the remote, but they cannot be read in the "
"dark.]"
msgstr "@ed 【尼孤𥆾各鈕𨑗調遣、扔空体讀衆𥪝琫𣋁。】"

msgid "@ed [Perhaps a \\c[4]light\\c[0] would help?]"
msgstr "@ed 【𣎏𨤰𠬠𠃣\\c[4]暎𤏬\\c[0]𣎏体𢴇益？】"

msgstr "@niko 𣎏𠬠𠃣𧅫𣼼𫥨孱。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/stairwell/EV006:1:1:text Maps/Red ground/ground
#: entrance/stairwell/EV006:1:1:text
msgid "@niko_eyeclosed It's full..."
msgstr "@niko_eyeclosed 伮𣹓耒。。。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/stairwell/EV007:1:1:text Maps/Red ground/ground
#: entrance/stairwell/EV007:1:1:text
msgid "@niko Looks like an old phone."
msgstr "@niko 𣎏𨤔𪜀𠬠隻電話𫇰。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/stairwell/EV008:1:1:text
#: entrance/Lobby/stairwell/EV009:1:1:text Maps/Red ground/ground
#: entrance/stairwell/EV008:1:1:text entrance/stairwell/EV009:1:1:text
msgid "@niko A small tree."
msgstr "@niko 𠬠丐𣘃𡮈。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:1:1:text
msgid "@niko Some sort of computer."
msgstr "@niko 𣛠性之妬。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:5:text
msgid "@ed [I remember it... what happened in the Tower.]"
msgstr "@ed 【𪝬㐌𢖵𫥨。。。仍之㐌侈𫥨𥪝座塔。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:6:text
msgid "@ed [What I tried to do... and how you managed to see through it all.]"
msgstr "@ed 【仍之𪝬㐌固𪵯。。。吧格伴㐌𥆾透悉𪥘󠄁。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:8:text
msgid "@ed [We HAVE been through all of this.]"
msgstr "@ed 【衆些㐌經過𤗆次耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:9:text
msgid ""
"@ed [Even though it was only supposed to run once... you still managed to "
"come back.]"
msgstr "@ed 【怞當𫥨伮只𢧚𧼋𠬠吝。。。伴吻尋得塘𢮿徠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:11:text
msgid "@ed [...How did you come back?]"
msgstr "@ed 【。。。憑格鬧？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:12:text
msgid "@ed [...How did you bring Niko back?]"
msgstr "@ed 【。。。伴㐌𫼳尼孤𠭤徠勢鬧？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:14:text
msgid "@ed [And then, you even managed to break out of bounds.]"
msgstr "@ed 【欣𡛤、伴㐌越𠺌邊界。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:15:text
msgid "@ed [Bringing Niko to places that never should have been.]"
msgstr "@ed 【𠀲尼孤𦤾仍坭被禁。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:17:text
msgid "@ed [It was HIM, wasn't it?]"
msgstr "@ed 【正𪜀𪝳、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:19:text
msgid "@ed [And now... now....]"
msgstr "@ed 【吧𣇞。。。𣇞。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:20:text EVENTS:2:25:text EVENTS:2:38:text
msgid "@ed [Niko is upset.]"
msgstr "@ed 【尼孤㐌恍𢜝。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:22:text
msgid "@ed [What even happened in that room back there?]"
msgstr "@ed 【仍之㐌侈𫥨𥪝間房妬？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:23:text
msgid "@ed [What did Niko learn?]"
msgstr "@ed 【尼孤㐌學得仍之？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:26:text
msgid "@ed [I can feel it.]"
msgstr "@ed 【𪝬𣎏体感認得。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:28:text
msgid "@ed [I told you to turn back, \\p!]"
msgstr "@ed 【𪝬㐌勸伴𢮿徠、\\p！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:29:text
msgid "@ed [But you've chosen to trust that man instead of me.]"
msgstr "@ed 【扔伴㐌𢵬信𪝳𠊝爲𪝬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:31:text
msgid "@ed [...No, not even that.]"
msgstr "@ed 【。。。空、哙空沛丕。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:32:text
msgid "@ed [Just his book.]"
msgstr "@ed 【只𣎏卷冊𧵑𪝳。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:33:text
msgid "@ed [His ghost.]"
msgstr "@ed 【魂魔𧵑𪝳。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:35:text
msgid "@ed [This world is not real.]"
msgstr "@ed 【世界尼空𣎏實。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:36:text
msgid "@ed [The people are not real.]"
msgstr "@ed 【𤗆𠊛空𣎏實。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:39:text
msgid "@ed [Niko... is....]"
msgstr "@ed 【尼。。。孤。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:41:text
msgid "@ed [No no no no no.]"
msgstr "@ed 【 空空空空空。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:43:text
msgid "@ed [Everything.]"
msgstr "@ed 【𤗆次。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:45:text
msgid "@ed [Is.]"
msgstr "@ed 【𪜀。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:48:text
msgid "@ed [  W  r  o  n  g  !  !  ]"
msgstr "@ed 【⺶  工  口  林  ！  ！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:59:text
msgid "@niko_shock AH!!"
msgstr "@niko_shock 啞！！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:66:text
msgid "@silver_worry [...The minecart!]"
msgstr "@silver_worry 【。。車𡎡！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:73:text
msgid "@silver3 [Earthquake...]"
msgstr "@silver3 【動𡐙。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:75:text
msgid "@niko_surprised Th-\\.\\.the tunnel back out just collapsed!"
msgstr "@niko_surprised 塘－\\.\\.塘𡌢滕𢖖󠄁被砬耒！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:76:text
msgid "@silver_worry [No!!]"
msgstr "@silver_worry 【空体鬧！！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:77:text
msgid "@niko3 What are we gonna do?!"
msgstr "@niko3 衆些𪵯之𣊾𣇞？！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:78:text
msgid "@silver_worry [I....]"
msgstr "@silver_worry 【姉。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:80:text
msgid "@proto1 [Wait.]"
msgstr "@proto1 【寬㐌。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:88:text
msgid "@proto2 [The exit just caved, didn't it.]"
msgstr "@proto2 【𡓃𫥨𣃣砬、董空。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:94:text
msgid "@proto2b [Sigh.]"
msgstr "@proto2b 【係。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:95:text
msgid ""
"@proto2 [I saw this coming, but this is a bit more sudden than I "
"anticipated.]"
msgstr "@proto2 【𪝬㐌預斷𠓀條尼、扔伮𦤾𨘱欣𪝬想。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:97:text
msgid "@proto1 [Both of you. Follow me.]"
msgstr "@proto1 【𪥘󠄁𠄩𠊛。蹺𪝬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:98:text
msgid "@niko3 Where to?"
msgstr "@niko3 𦤾兜丕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/MAP
#: EVENTS:2:99:text
msgid "@proto1 [The way out.]"
msgstr "@proto1 【𡓃𫥨。】"


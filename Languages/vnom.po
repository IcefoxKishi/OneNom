#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:19:text
msgid "@silver2 [You...\\.\\. could've just asked.]"
msgstr "@silver2 【英。。。\\.\\.𠾒𪝬𪜀得𦓡。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server room/backroom/npc
#: proto2:1:43:text

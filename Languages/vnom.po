msgid "@plight_worry I can't work when I'm dead!"
msgstr "@plight_worry 𣩂耒時哰𦓡英𪵯役得𡛤！"

#: Maps/FINALE/Credits/EV070:1:25:text
msgid "@niko6 (...\\p, IS he?)"
msgstr "@niko6 （。。。\\p、愥𣎏實𪜀穩空勢？）"

#: Maps/FINALE/Credits/EV070:1:26:choice:0
msgid "He's fine, Niko"
msgstr "英𧘇穩、尼孤啊"

#: Maps/FINALE/Credits/EV070:1:30:choice:0
msgid "Everyone here is fine."
msgstr "𤗆𠊛於低調穩。"

#: Maps/FINALE/Credits/EV070:1:34:choice:0 Maps/FINALE/Credits/map
#: events:5:39:choice:0
msgid "The World Machine..."

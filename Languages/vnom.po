msgid "lightbulb"
msgstr "琫畑"

#. item description
#: Items:1
msgid "A large lightbulb. It's the sun."
msgstr "𠬠䏾畑𡘯，同時𪜀𩈘𡗶。"

#. item name
#: Items:2
msgid "television remote"
msgstr "調遣無線"

#. item description
#: Items:2
msgid "It's too hard to read in the dark light."
msgstr "空体讀得之𥪝䏾晬。"

#. item name
#: Items:3
msgid "bottle of alcohol"
msgstr "𥑂溜"

#. item description
#: Items:3
msgid "The smell of the liquid is repugnant."
msgstr "味香實苦写。"

#. item name
#: Items:4
msgid "dry branch"
msgstr "梗𣘃枯"

#. item description
#: Items:4
msgid "A flaky, dry branch from the bathroom plant."
msgstr "𠬠梗伅，枯自丐𣘃𥪝房沁。"

#. item name
#: Items:5
msgid "wet branch"
msgstr "梗𣘃𤀔"

#. item description
#: Items:5
msgid "The tip of the branch is soaked with alcohol."
msgstr "𦰟梗㐌寖溜。"

#. item name
#: Items:6
msgid "torch"
msgstr "燭"

#. item description
#: Items:6
msgid "Doesn't give off much light."
msgstr "空𤏬夦。"

#. item name
#: Items:7
msgid "basement key"
msgstr "鈙錁層窨"

#. item description
#: Items:7
msgid "This thing looks old."
msgstr "𣎏𡲈窒𡳰。"

#. item name
#: Items:8
msgid "camera"
msgstr "𣛠影"

#. item description
#: Items:8
msgid "A broken camera with a large screwed-in lens."
msgstr "𠬠𣛠影閧𣎏𠬠透鏡𡘯得𢪏𠓨。"

#. item name
#: Items:9
msgid "screwdriver"
msgstr "鬚𢪏"

#. item description
#: Items:9
msgid "Phillips-head."
msgstr "頭非䉭。"

#. item name
#: Items:10
msgid "lens"
msgstr "透鏡"

#. item description
#: Items:10
msgid "A large glass lens."
msgstr "𠬠透鏡水晶𡘯。"

#. item name
#: Items:11
msgid "empty bottle"
msgstr "𥑂筩"

#. item description
#: Items:11
msgid "The smell of alcohol lingers."
msgstr "吻噲味溜。"

#. item name
#: Items:12
msgid "broken battery"
msgstr "碰閧"

#. item description
#: Items:12
msgid "Apparently a battery.  It has some broken glass in it."
msgstr "𣎏𡲈𪜀𠬠梮汴。辺𥪝𣎏𠬠𠃣鏡破。"

#. item name
#: Items:13
msgid "empty battery"
msgstr "碰筩"

#. item description
#: Items:13
msgid "An intact, rechargable battery. Currently empty."
msgstr "𠬠梮汴完整，𣎏体𠻓。現当喝汴。"

#. item name
#: Items:14 Items:77
msgid "charged battery"
msgstr "碰㐌納"

#. item description
#: Items:14
msgid "A working, rechargable battery. Maximum power."
msgstr "𠬠梮汴活動，𣎏体𠻓。㐌苔汴。"

#. item name
#: Items:15
msgid "bottle of smoke"
msgstr "𥑂𤌋"

#. item description
#: Items:15
msgid "It's full of noxious fumes."
msgstr "貯𣹓氣毒。"

#. item name
#: Items:16
msgid "bottle of acid"
msgstr "𥑂啊掇"

#. item description
#: Items:16
msgid "It's full of a thick liquid acid."
msgstr "𥑂貯𣹓𠬠類啊掇𣿅。"

#. item name
#: Items:17
msgid "wet sponge"
msgstr "渤㴜㲸"

#. item description
#: Items:17
msgid "Sponge soaked with acidic cleaning solution."
msgstr "渤㴜㐌得𣴛𠓨𠬠溶液撈𣳮啊掇。"

#. item name
#: Items:18
msgid "crowbar"
msgstr "錆㖼𩿙"

#. item description
#: Items:18
msgid "Makeshift crowbar made from a pipe."
msgstr "錆暫備得製作自𠬠隻䈵渃。"

#. item name
#: Items:19
msgid "metal rod"
msgstr "錆金類"

#. item description
#: Items:19
msgid "It weighs surprisingly little."
msgstr "珥𦤾不㘈。"

#. item name
#: Items:20
msgid "sponge"
msgstr "渤㴜"

#. item description
#: Items:20
msgid "A flat sponge with a rough surface."
msgstr "𠰳渤㴜塝𣎏皮𩈘粗𢺎。"

#. item name
#: Items:21
msgid "empty syringe"
msgstr "䈵尖筩"

#. item description
#: Items:21
msgid "The needle is particularly long."
msgstr "頭針可𨱽。"

#. item name
#: Items:22
msgid "filled syringe"
msgstr "䈵尖𣹓"

#. item description
#: Items:22
msgid "It's full of the strange liquid from the pond."
msgstr "伮貯𣹓質𣿅奇𨓐自湖渃。"

#. item name
#: Items:23
msgid "amber"
msgstr "琥珀"

#. item description
#: Items:23
msgid "A piece of glowing amber with a black clover inside."
msgstr "𠬠𤗖琥珀發𤏬喟 𠬠𣘃𦹯𠀧蘿黰邊𥪝。"

#. item name
#: Items:24
msgid "strange journal"
msgstr "日記奇𨓐"

#. item description
#: Items:24
msgid "Found in the Barrens. It's written in an unknown language."
msgstr "尋𧡊在塳邊疆。邊𥪝蘿𠬠言語秘隱。"

#. item name
#: Items:25
msgid "feather"
msgstr "𦒮羽"

#. item description
#: Items:25
msgid "A long and slender feather with glowing edges."
msgstr "𠬠隻𦒮羽𨱽𤗖𣎏𧟁發𤏬。"

#. item name
#: Items:26
msgid "bottle of dye"
msgstr "𥑂𧆄染"

#. item description
#: Items:26
msgid "A small vial filled with dark blue liquid used for dying wool."
msgstr "𠬠䈵驗𡮈貯𧆄染縺青藍。"

#. item name
#: Items:27
msgid "tube of water"
msgstr "䈵驗貯渃"

#. item description
#: Items:27
msgid "The label says \"water sample\"."
msgstr "𣠰提「母渃」。"

#. item name
#: Items:28
msgid "seed"
msgstr "籺𥞖"

#. item description
#: Items:28
msgid "It's a seed apparently left behind by Maize."
msgstr "𠬠籺𥞖𣎏𨤔𩄲㐌抵徠。"

#. item name
#: Items:29
msgid "wool"
msgstr "縺"

#. item description
#: Items:29
msgid "It's... kind of useless."
msgstr "唏。。。無用。"

#. item name
#: Items:30
msgid "feather pen"
msgstr "筆𦒮"

#. item description
#: Items:30
msgid "A pen made from dipping a feather into ink."

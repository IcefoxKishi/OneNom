#: npc:2:43:text
msgid "@niko_speak Oh?"
msgstr "@niko_speak 溩？"

#: Maps/Green/Ruins Out/EV193:1:9:text
msgid "@alula_pout I don't remember the last time I was here..."
msgstr "@alula_pout 𨉟拱拯𢖵吝近一𨉟𦤾低𪜀𠸒𣇞𡛤。。。"

#: Maps/Green/Ruins Out/EV193:1:10:text
msgid "@alula_speak Back when she was still alive, I think?"
msgstr "@alula_speak 形如𪜀欺姉𧘇吻哙𤯩？"

#: Maps/Blue/Dormitories/EV012:1:1:text
msgid "[HELLO, ORGANIC PERSON WHO IS ALIVE.]"
msgstr "【吀嘲、𠊛有機當𤯩。】"

#: Maps/Blue/Dormitories/EV012:1:2:text
msgid "[THE INFIRMARY IS UP AHEAD.]"
msgstr "【茹醫濟於𠌨𠓀。】"

#: Maps/Blue/Dormitories/EV027:1:4:text
msgid "@blue_gatekeeper [Oh, Hello.]"
msgstr "@blue_gatekeeper 【溩、吀嘲。】"

#: Maps/Blue/Dormitories/EV027:1:5:text
msgid "@blue_gatekeeper [What Are You Doing Here?]"
msgstr "@blue_gatekeeper 【伴當𪵯之於低丕？】"

#: Maps/Blue/Dormitories/EV027:1:6:text Maps/Blue/Outpost/prophet:4:257:text
#: Maps/Blue/Outpost/prophet:4:271:text Maps/Blue/Outpost/prophet:4:281:text
#: Maps/Blue/Outpost/prophet:4:294:text Maps/Red ground/ground 1/Library
#: entrance/stairwell/GeorgeRoom/npc_george:3:69:text
msgid "@niko Hm?"
msgstr "@niko 嘑？"

#: Maps/Blue/Dormitories/EV027:1:7:text
msgid ""
"@blue_gatekeeper [A Living Person Such As Yourself Should Have Evacuated "
"This Place Long Ago.]"
msgstr "@blue_gatekeeper 【𠬠𠊛𤯩如伴當𫥨𢧚疏散徐窒嘍耒。】"

#: Maps/Blue/Dormitories/EV027:1:8:text
msgid ""
"@niko_speak Oh, but I just got here! \\>\\n\\@niko To this world, I mean!"
msgstr "@niko_speak 溩、扔𨉟只𣃣㵋𦤾低催！\\>\\n\\@niko 意𪜀、𦤾世界尼！"

#: Maps/Blue/Dormitories/EV027:1:9:text
msgid "@niko_speak See? \\.\\. I have the sun!"
msgstr "@niko_speak 𧡊空？ \\.\\. 𨉟𣎏𩈘𡗶尼！"

#: Maps/Blue/Dormitories/EV027:1:10:text
msgid "@blue_gatekeeper [Oh, The Messiah.]"
msgstr "@blue_gatekeeper 【溩、𠎬救世。】"

#: Maps/Blue/Dormitories/EV027:1:11:text
msgid "@blue_gatekeeper [I...\\. Do Not Know What To Say.]"
msgstr "@blue_gatekeeper 【𪝬。。。\\.空別吶之。】"

#: Maps/Blue/Dormitories/EV027:1:12:text
msgid "@blue_gatekeeper [Greeting You Was Not Part Of My Programming.]"
msgstr "@blue_gatekeeper 【𪝬空得立程抵嘲𢜏伴。】"

#: Maps/Blue/Dormitories/EV027:1:13:text
msgid "@blue_gatekeeper [Have You\\.\\. Spoken To Prophetbot?]"
msgstr "@blue_gatekeeper 【伴㐌。。。\\.\\.吶𡀯喟𣛠先知𣗓？】"

#: Maps/Blue/Dormitories/EV027:1:14:text
msgid "@niko_speak I think so, yeah!"
msgstr "@niko_speak 𨉟擬𪜀耒、𫫡！"

#: Maps/Blue/Dormitories/EV027:1:15:text
msgid ""
"@blue_gatekeeper [Prophetbot Was Built With The Sole Purpose Of Greeting "
"You.]"
msgstr "@blue_gatekeeper 【𣛠先知得𡏦𥩯喟目的唯一𪜀嘲迍伴。】"

#: Maps/Blue/Dormitories/EV027:1:17:text
msgid ""
"@blue_gatekeeper [Yes. He Cannot Speak With Anyone Else.] \\>\\n[At Least, "
"Not With Ease.]"
msgstr ""
"@blue_gatekeeper 【董丕。英些空体交接喟不其埃恪。】 \\>\\n【𠃣一𪜀空奚易"
"揚。】"

#: Maps/Blue/Dormitories/EV027:1:18:text
msgid "@niko Oh...\\n\\>\\@niko_eyeclosed that's...\\.\\.kind of sad..."
msgstr "@niko 溩。。。\\n\\>\\@niko_eyeclosed 𢞂。。。\\.\\.𠰚。。。"

#: Maps/Blue/Dormitories/EV027:1:19:text
msgid "@niko_speak What are you built for, then?"
msgstr "@niko_speak 勢舅得製造抵𪵯之丕？"

#: Maps/Blue/Dormitories/EV027:1:20:text
msgid "@blue_gatekeeper [My Purpose Is To Guard This Settlement.]"
msgstr "@blue_gatekeeper 【目的𧵑𪝬𪜀更𡨺區定居尼。】"

#: Maps/Blue/Dormitories/EV027:1:21:text
msgid ""
"@blue_gatekeeper [Even Though The Residents Have Long Gone, I Must Remain.]"
msgstr "@blue_gatekeeper 【雖各居民㐌灑𠫾徐嘍、𪝬沛於徠。】"

#: Maps/Blue/Dormitories/EV027:1:22:text Maps/Red ground/ground 1/Library
#: entrance/stairwell/GeorgeRoom/Map Events:7:84:text Events:7:99:text
#: Events:7:120:text sky/Apartments/Hall1/Room3 - bot friend/EV004:1:11:text
#: Maps/POSTGAME green/Research Station/EV002:1:4:text
msgid "@niko Ah..."
msgstr "@niko 啊。。。"

#: Maps/Blue/Dormitories/EV027:1:23:text
msgid "@niko_speak Why, though?"
msgstr "@niko_speak 扔在哰丕？"

#: Maps/Blue/Dormitories/EV027:1:24:text
msgid "@blue_gatekeeper [I Have Not Been Tamed.]"
msgstr "@blue_gatekeeper 【𪝬𣗓得純化。】"

#: Maps/Blue/Dormitories/EV027:1:25:text Maps/Blue/Cliffs/Lookout
#: point/Cabin/npc_silver:4:28:text
msgid "@niko_speak Tamed?"
msgstr "@niko_speak 純化？"

#: Maps/Blue/Dormitories/EV027:1:26:text
msgid "@blue_gatekeeper [It Was Not Worth The Effort.]"
msgstr "@blue_gatekeeper 【空當。】"

#: Maps/Blue/Dormitories/EV027:2:4:text
msgid "@blue_gatekeeper [Stay Safe.]"
msgstr "@blue_gatekeeper 【保重唲。】"

#: Maps/Blue/Dormitories/EV027:2:7:text
msgid ""
"@blue_gatekeeper [By The Way, Some Robots May Start Following You Around "
"This Settlement As Well.]"
msgstr "@blue_gatekeeper 【因便、𠬠数𠊛𣛠𣎏体蹺蹎伴𨒺區定居尼。】"

#: Maps/Blue/Dormitories/EV027:2:8:text
msgid ""
"@blue_gatekeeper [Do Not Be Alarmed.]\\n\\>[It Is Their Job To Keep People "
"Safe.]"
msgstr "@blue_gatekeeper 【揨慌𢜝。】\\n\\>【役𧵑𣱆𪜀𡨺安全朱𡥵𠊛。】"

#: Maps/Blue/Dormitories/EV520:1:1:text Maps/Blue/Dormitories/EV521:1:1:text
msgid "INFIRMARY"
msgstr "茹醫濟"

#: Maps/Blue/Dormitories/EV523:1:1:text Maps/Blue/Dormitories/EV524:1:1:text
msgid "[HELLO. DO YOU NEED ANY HELP?]"
msgstr "【吀嘲。伴𣎏懃𢴇之空？】"

#: Maps/Blue/Dormitories/EV523:1:2:text Maps/Blue/Dormitories/EV524:1:2:text
msgid "@niko_speak I'm good, thanks!"
msgstr "@niko_speak 𨉟劸、感恩唲！"

#: Maps/Blue/Dormitories/EV523:2:1:text
msgid "[UNIT RM-2883417 REPORTING FOR DUTY!]"
msgstr "【單位RM2883417𣎏𩈘！】"

#: Maps/Blue/Dormitories/EV523:2:2:text
msgid "[I SAW THAT YOU SPOKE WITH THE GUARDIAN OF THE SETTLEMENT.]"
msgstr "【𪝬𧡊伴㐌吶𡀯喟總管𧵑區定居尼。】"

#: Maps/Blue/Dormitories/EV523:2:3:text Maps/Blue/Dormitories/EV524:2:6:text
msgid "[I WILL NOW ESCORT YOU UNTIL YOU REACH YOUR DORMITORY.]"
msgstr "【𣊾𣇞𪝬𠱊護送伴𦤾寄宿舍。】"

#: Maps/Blue/Dormitories/EV523:2:4:text
msgid "@niko um....what?"
msgstr "@niko 唹。。。之幾？"

#: Maps/Blue/Dormitories/EV523:3:1:text
msgid "@niko_speak So you're just gonna...follow me?"
msgstr "@niko_speak 丕𪜀舅𠱊。。。蹺𨉟哰？"

#: Maps/Blue/Dormitories/EV523:3:2:text Maps/Blue/Dormitories/118 - robot
#: voice/Map Events:2:9:text
msgid "[YES.]"
msgstr "【董。】"

#: Maps/Blue/Dormitories/EV523:3:3:text
msgid "[UNTIL YOU SAFELY REACH A BUILDING OF YOUR DESTINATION.]"
msgstr "【朱𦤾欺伴安全𠓨𠬠座茹的𦤾。】"

#: Maps/Blue/Dormitories/EV523:3:4:text
msgid "@niko Alright."
msgstr "@niko 得耒。"

#: Maps/Blue/Dormitories/EV523:4:1:text Maps/Blue/Dormitories/EV524:4:1:text
#: Maps/INIT/DEBUG/EV073:4:2:text
msgid "@niko Hello"
msgstr "@niko 吀嘲"

#: Maps/Blue/Dormitories/EV523:4:2:text Maps/INIT/DEBUG/EV073:4:1:text
msgid "[BOOP]"
msgstr "【芣】"

#: Maps/Blue/Dormitories/EV524:2:1:text
msgid "[UNIT RT-3847201 REPORTING FOR DUTY!]"
msgstr "【單位RT3847201𣎏𩈘！】"

#: Maps/Blue/Dormitories/EV524:2:2:text
msgid "[IT SEEMS THAT YOU ALREADY HAVE AN ASSIGNED ESCORT, UNIT  RM-2883417]"
msgstr "【𣎏𨤔伴㐌𣎏單位RM2883417護送。】"

#: Maps/Blue/Dormitories/EV524:2:3:text
msgid "[WOULD YOU LIKE ME TO LEAVE?]"
msgstr "【伴𣎏㦖𪝬𨖨𠫾空？】"

#: Maps/Blue/Dormitories/EV524:2:4:text
msgid "@niko You can follow me if you want..."
msgstr "@niko 舅𣎏体𠫾蹺𨉟裊㦖。。。"

#: Maps/Blue/Dormitories/EV524:2:5:text
msgid "[UNDERSTOOD.]"
msgstr "【㐌曉。】"

#: Maps/Blue/Dormitories/EV524:3:1:text
msgid "@niko_speak Are you guys not supposed to go in buildings?"
msgstr "@niko_speak 各舅空得𠫾𠓨茹哰？"

#: Maps/Blue/Dormitories/EV524:3:2:text
msgid "[CORRECT.]"
msgstr "【董。】"

#: Maps/Blue/Dormitories/EV524:3:3:text
msgid "[WE ARE BUILT FOR OUTDOOR USE ONLY.]"
msgstr "【衆𪝬只得𡏦𥩯朱目的使用外𡗶。】"

#: Maps/Blue/Dormitories/EV524:3:4:text
msgid "[ENTERING BUILDINGS IS NOT PART OF OUR PROGRAMMING.]"
msgstr "【𠓨茹空𣎏𥪝係統𧵑衆𪝬。】"

#: Maps/Blue/Dormitories/EV524:3:5:text
msgid "@niko That's... strange."
msgstr "@niko 𨓐。。。實蒂。"

#: Maps/Blue/Dormitories/EV524:4:2:text Maps/INIT/DEBUG/EV074:3:1:text
msgid "[BEEP]"
msgstr "【芣】"

#: Maps/Unused/stairwell-demo/pc:1:3:text Maps/Red
#: sky/Office/stairwell/pc:1:6:text
msgid "@ed [You are testing my patience.]"
msgstr "@ed 【伴當實事試𡂓事堅忍𧵑𪝬蒂。】"

#: Maps/Unused/stairwell-demo/pc:1:4:text Maps/Red
#: sky/Office/stairwell/pc:1:7:text
msgid "@ed [Do you really want the answer?]"
msgstr "@ed 【伴實事㦖答案𦤾勢哰？】"

#: Maps/Unused/stairwell-demo/pc:1:7:text Maps/Red
#: sky/Office/stairwell/pc:1:10:text
msgid ""
"@ed [When you view the film, it fills your entire window into our world, "
"yes?]"
msgstr "@ed 【欺伴䀡𬌓眨、伮垃𣹓𫔤擻𧵑伴䀡世界衆𪝬、董空？】"

#: Maps/Unused/stairwell-demo/pc:1:8:text Maps/Red
#: sky/Office/stairwell/pc:1:11:text
msgid "@ed [I believe you refer to the action I describe as \"dragging\".]"
msgstr "@ed 【𪝬擬伴哙行動妬𪜀「捁」。】"

#: Maps/Unused/stairwell-demo/pc:1:9:text Maps/Red
#: sky/Office/stairwell/pc:1:12:text
msgid "@ed [The void is beyond the borders of your view.]"
msgstr "@ed 【曠空㑲外範圍伴𣎏体觀察。】"

#: Maps/Unused/stairwell-demo/pc:1:10:text Maps/Red
#: sky/Office/stairwell/pc:1:13:text
msgid "@ed [Through the void, and back again...]"
msgstr "@ed 【𠓨曠空、耒捁𫥨。。。】"

#: Maps/Unused/stairwell-demo/pc:1:13:text Maps/Red
#: sky/Office/stairwell/pc:1:16:text
msgid "@ed [Are you just here to waste more of my time?]"
msgstr "@ed 【伴於低只抵費添時間𧵑𪝬嘑？】"

#: Maps/Unused/stairwell-demo/pc:1:14:text Maps/Blue/Outpost/Outpost
#: interior/pc:2:49:text Maps/Red sky/Office/stairwell/pc:1:17:text
msgid "@ed [Sigh.]"
msgstr "@ed 【係。】"

#: Maps/Unused/stairwell-demo/pc:1:19:text Maps/Red
#: sky/Office/stairwell/pc:1:22:text
msgid "@ed [Still clueless?]"
msgstr "@ed 【吻𠸠󠄁嘑？】"

#: Maps/Unused/stairwell-demo/pc:1:20:text Maps/Red
#: sky/Office/stairwell/pc:1:23:text
msgid "@ed [Figures.]"
msgstr "@ed 【拱沛催。】"

#: Maps/Unused/stairwell-demo/pc:1:21:text Maps/Red
#: sky/Office/stairwell/pc:1:24:text
msgid "@ed [Want another tip?]"
msgstr "@ed 【㦖添𠬠㨳意𡛤嘑？】"

#: Maps/Unused/stairwell-demo/pc:1:25:text Maps/Red
#: sky/Office/stairwell/pc:1:28:text
msgid ""
"@ed [There's a void beyond the four walls that bind our world to yours. The "
"edges of your viewport, where everything is obscured...]"
msgstr ""
"@ed 【𣎏𠬠曠空邊外𦊚幅墻結綏世界𧵑衆𪝬喟𧵑伴。仍紒外𧵑尋𥆾𧵑伴、坭𤗆次變"
"𠅒。。。】"

#: Maps/Unused/stairwell-demo/pc:1:26:text Maps/Red
#: sky/Office/stairwell/pc:1:29:text
msgid "@ed [I'm sure you know what I'm talking about.]"
msgstr "@ed 【𪝬昃伴別𪝬當指丐之。】"

#: Maps/Unused/stairwell-demo/pc:1:27:text Maps/Red
#: sky/Office/stairwell/pc:1:30:text
msgid "@ed [Pass the film through the void and back again.]"
msgstr "@ed 【𠀲𬌓眨𠓨曠空吧捽𫥨。】"

#: Maps/Unused/stairwell-demo/pc:1:30:text Maps/Red
#: sky/Office/stairwell/pc:1:33:text
msgid "@ed [Fine, keep at it.]"
msgstr "@ed 【催得耒、據固𠫾。】"

#: Maps/Unused/stairwell-demo/pc:1:31:text Maps/Red
#: sky/Office/stairwell/pc:1:34:text
msgid "@ed [It's not like I'm going anywhere.]"
msgstr "@ed 【𪝬拱𣎏𠫾兜兜𦓡。】"

#: Maps/Unused/stairwell-demo/pc:1:40:text Maps/Red
#: sky/Office/stairwell/pc:1:43:text
msgid "@ed [Looking for a code, are you?]"
msgstr "@ed 【伴當尋𠬠段碼、沛空？】"

#: Maps/Unused/stairwell-demo/pc:1:43:text Maps/Red
#: sky/Office/stairwell/pc:1:46:text
msgid "@ed [You're going to need this soon.]"
msgstr "@ed 【伴𠱊懃丐尼蒂。】"

#: Maps/Unused/stairwell-demo/pc:1:46:text Maps/Red
#: sky/Office/stairwell/pc:1:49:text
msgid "@ed [Take this film and expose it to the void.]"
msgstr "@ed 【𥙩𬌓眨尼吧𠀲伮接触喟曠空。】"

#: Maps/Unused/stairwell-demo/pc:1:47:text Maps/Red
#: sky/Office/stairwell/pc:1:50:text
msgid "@ed [The answer will be revealed when you bring it back again.]"
msgstr "@ed 【答案𠱊露𫥨欺伴𠀲伮𠭤徠。】"

#: Maps/Unused/stairwell-demo/pc:1:48:text Maps/Red
#: sky/Office/stairwell/pc:1:51:text
msgid "@niko The computer printed out a strange transparent sheet..."
msgstr "@niko 𣛠併印𫥨𠬠詞眨其𨓐。。。"


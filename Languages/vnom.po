msgstr "@niko_sad 喂。。。。"

#: Maps/Tower/Summit/map event:3:7:text
msgid ""
"@niko_distressed2 ....\\p? \\>\\n\\@niko_distressed2 What should I... do?"
msgstr ""
"@niko_distressed2 。。。。\\p？ \\>\\n\\@niko_distressed2 𨉟𢧚。。。𪵯之低？"

#: Maps/Tower/Summit/map event:3:11:text
msgid "What's the right thing to do?"
msgstr "役沛𪵯𪜀之？"

#: Maps/Tower/Summit/map event:3:62:text
msgid ""
"@niko_eyeclosed Y-You're right...\\>\\nI can't just leave everyone here to "
"die."
msgstr "@niko_eyeclosed 舅－舅吶董妬。。。\\>\\n𨉟空体𠬃嚜𤗆𠊛𣩂得。"

#: Maps/Tower/Summit/map event:3:63:text
msgid "@niko Thank you for your help, \\p.\\>\\nI promise I'll be okay."
msgstr "@niko 感恩舅㐌𢴇扡、\\p。\\>\\n𨉟許𨉟𠱊穩催。"

#: Maps/Tower/Summit/map event:3:167:text
#: Maps/Tower/Summit/Shatter/EV003:1:89:text
msgid "@credits Thanks for Playing!"
msgstr "@credits 感恩伴㐌𨔈！"

#: Maps/Tower/Summit/map event:3:216:text
msgid "I...\\> trust your judgement, \\p."
msgstr "𨉟。。。\\>信想決定𧵑舅、\\p。"


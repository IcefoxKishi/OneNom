#: Maps/Green/Research Station/EV003:1:10:text Maps/POSTGAME green/Research
#: Station/EV003:1:11:text
msgid "@niko_speak ...no?"
msgstr "@niko_speak 。。。空？"

#: Maps/Green/Research Station/EV003:1:11:text Station/EV010:1:11:text
#: Maps/POSTGAME green/Research Station/EV003:1:12:text
msgid "[OH, CARRY ON, THEN.]"
msgstr "【溩、丕時、吀唉接續。】"

#: Maps/Green/Research Station/EV007:1:1:text
msgid "[MONITORING ANOMALY...]"
msgstr "【當觀測異点。。。】"

#: Maps/Green/Research Station/EV007:1:2:text
msgid "@niko_speak What IS that thing?"
msgstr "@niko_speak 丐之丕？"

#: Maps/Green/Research Station/EV007:1:3:text
msgid "[AN ANOMALY.]"
msgstr "【𠬠異点。】"

#: Maps/Green/Research Station/EV007:1:4:text
msgid "@niko_eyeclosed Well, yeah, but..."
msgstr "@niko_eyeclosed 空差、扔𦓡。。。"

#: Maps/Green/Research Station/EV008:1:2:text Station/EV008:1:8:text
msgid "[I WILL RETURN TO MY STATION IN THE CITY SOON.]"
msgstr "【𪝬𠱊𣋽𠭤徠站𧵑𪝬𥪝城庯。】"

#: Maps/Green/Research Station/EV008:1:5:text
msgid "@niko_speak How come you're red instead of green?"
msgstr "@niko_speak 在哰伴空沛𦭷青蘿𦓡徠𪜀𦭷𧹻丕？"

#: Maps/Green/Research Station/EV008:1:6:text
msgid ""
"@niko Well...more of a purple than red...\\>\\n\\@niko_speak But your eyes "
"and stuff are red!"
msgstr ""
"@niko 時。。。偅𦭷𧹿欣𪜀𧹻。。。\\>\\n\\@niko_speak 扔眜喟各次𧵑舅𪜀𦭷𧹻！"

#: Maps/Green/Research Station/EV008:1:7:text
msgid "[I AM ONLY HERE TO PICK UP THIS WEEK'S MOSS SAMPLES.]"
msgstr "【𪝬只𣎏𩈘抵收拾各母𦼔𧵑旬尼催。】"

#: Maps/Green/Research Station/EV008:1:9:text
msgid "@niko_speak I see!"
msgstr "@niko_speak 𫥨勢！"

#: Maps/Green/Research Station/EV009:1:1:text
msgid "[I AM IN CHARGE OF COLLECTING THE MOSS SAMPLES.]"
msgstr "【𪝬負責役收拾各母𦼔。】"

#: Maps/Green/Research Station/EV009:1:2:text
msgid "@niko_speak Cool!"
msgstr "@niko_speak 咍！"

#: Maps/Green/Research Station/EV010:1:9:text
msgid "[DID DR. SILVERPOINT SEND YOU?]"
msgstr "【教師銀点寄伴𦤾嘑？】"

#: Maps/Green/Research Station/EV010:1:10:text
msgid "@niko_speak No? I'm with \\p..."
msgstr "@niko_speak 空？𨉟𠫾喟\\p𦓡。。。"

#: Maps/Green/Research Station/EV011:1:1:text
msgid "[PHOSPHOR TREE GROWTH RATE HAS BEEN REDUCED AS OF LATE...]"
msgstr "【近低速度發展各𣘃光素㐌踸徠。。。】"

#: Maps/Green/Ruins In/Junction/EV001:1:2:text
msgid "[PLEASE DO NOTE THAT THE RUINS BELOW ARE PARTIALLY FLOODED.]"
msgstr "【唉留意各殘跡邊𨑜被汲𠬠份。】"

#: Maps/Green/Ruins In/Junction/EV001:1:4:text
msgid "@niko Should we...not be here?"
msgstr "@niko 衆𨉟。。。空𢧚𠓨低哰？"

#: Maps/Green/Ruins In/Junction/EV001:1:5:text
msgid "[THERE IS NO IMMEDIATE DANGER.]"
msgstr "【空𣎏䋦危害直接鬧。】"

#: Maps/Green/Ruins In/Junction/EV001:1:6:text
msgid "[USING THIS AREA AS A DWELLING IS NOT RECOMMENDED, HOWEVER.]"
msgstr "【雖然、空勸激使用坭尼𪵯坭常住。】"

#: Maps/Red ground/backalley/EV007:1:2:text
msgid ""
"@kelvin [You have been here for a while...] \\>\\n[Are you sure you do not "
"wish to stay?]"
msgstr "@kelvin 【㛪㐌於低可嘍耒妬。。。】 \\>\\n【㛪𣎏昃𪜀空㦖於徠空丕？】"

#: Maps/Red ground/backalley/EV007:1:3:text
msgid "@niko_speak I'm good, thanks for offering though!"
msgstr "@niko_speak 㛪穩、感恩英吖！"

#: Maps/Red ground/backalley/EV007:1:7:text
msgid "@niko So... where did you find all your cats?"
msgstr "@niko 丕時。。。英檢僤貓妬於兜丕吖？"

#: Maps/Red ground/backalley/EV007:1:8:text
msgid "@kelvin [They found me on their own.] \\>\\n[So I stay here now.]"
msgstr "@kelvin 【衆自尋𦤾英。】\\>\\n【𢧚𣇞英於低。】"

#: Maps/Red ground/backalley/EV007:1:9:text
msgid ""
"@niko2 Ah... \\>\\n\\@niko_speak Well, it's good that you're not alone, at "
"least!"
msgstr "@niko2 啊。。。 \\>\\n\\@niko_speak 時、𠃣𫥨英空於𠬠𨉟！"

#: Maps/Red ground/backalley/EV007:1:10:text
msgid ""
"@niko I met some robots in the other areas stationed all by themselves..."
msgstr "@niko 㛪𣎏﨤𠬠数𠊛𣛠於𡊲恪𠬠𨉟。。。"

#: Maps/Red ground/backalley/EV007:1:11:text
msgid "@niko_eyeclosed I felt kinda... bad..."
msgstr "@niko_eyeclosed 㛪𧡊可。。。罪。。。"

#: Maps/Red ground/backalley/EV007:1:12:text
msgid "@kelvin [With robots, it is alright.]"
msgstr "@kelvin 【對喟𠊛𣛠時、空哰𪥘󠄁。】"

#: Maps/Red ground/backalley/EV007:1:13:text
msgid ""
"@kelvin [We are not like people, we are typically unable to feel loneliness.]"
msgstr "@kelvin 【𪨠英空偅𡥵𠊛、空体感認事孤單。】"

#: Maps/Red ground/backalley/EV007:1:15:text
msgid ""
"@niko_speak Well, you talk less like a robot than most other robots I've met!"
msgstr "@niko_speak 扔𦓡、英吶𡀯𠃣偅𠊛𣛠欣仍𠊛𣛠㛪㐌﨤𧘇！"

#: Maps/Red ground/backalley/EV007:1:16:text
msgid "@kelvin [Maybe.]"
msgstr "@kelvin 【𣎏体。】"

#: Maps/Red ground/backalley/EV007:1:17:text
msgid ""
"@kelvin [Not many people frequent this part of the alley, but there are a "
"few.]"
msgstr "@kelvin 【空𠇍埃咍過徠曲尼𧵑𡥵險、扔吻𣎏𠬠数𠃣。】"

#: Maps/Red ground/backalley/EV007:1:18:text
msgid "@kelvin [One of them even lives here.]"
msgstr "@kelvin 【甚至𣎏𠬠𠊛𤯩𥪝尼。】"

#: Maps/Red ground/backalley/EV007:1:24:text
msgid "@niko_speak It's warm here!"
msgstr "@niko_speak 𥪝尼𤋾過！"

#: Maps/Red ground/backalley/EV007:1:25:text
msgid "@kelvin [Yeah.]"
msgstr "@kelvin 【𫫡。】"

#: Maps/Red ground/backalley/EV007:1:26:text
msgid "@kelvin [This was my original purpose.]"
msgstr "@kelvin 【低𪜀目的班頭𧵑英。】"

#: Maps/Red ground/backalley/EV007:1:27:text
msgid "@niko_speak ...watching cats?"
msgstr "@niko_speak 。。。𥋴貓吖？"

#: Maps/Red ground/backalley/EV007:1:28:text
msgid "@kelvin [Warmth.]"
msgstr "@kelvin 【𤇧𤋾。】"

#: Maps/Red ground/backalley/EV007:1:30:text
msgid ""
"@niko_speak It's a nice purpose!...\\>\\@niko ... "
"\\>\\n\\@niko_yawn ....yawn..."
msgstr ""
"@niko_speak 𠬠目的卒妬吖！\\>\\@niko 。。。 \\>\\n\\@niko_yawn 。。。。"
"哈。。。"

#: Maps/Red ground/backalley/EV007:1:31:text
msgid "@kelvin [Oh,  you look tired.] \\>\\n[Do you wish to rest?]"
msgstr "@kelvin 【溩、  㛪𣎏𨤔𢞂𥄬。】 \\>\\n【㛪𣎏㦖儗𢯕𠬠𣋩空？】"

#: Maps/Red ground/backalley/EV007:1:32:text
msgid "@niko_speak I can't sleep now! \\p and I got stuff to do!"
msgstr "@niko_speak 𣊾𣇞㛪空𥄬得！㛪吧\\p哙役懃𪵯吖！"

#: Maps/Red ground/backalley/EV007:1:33:text ground/backalley/EV007:1:54:text
msgid "@kelvin [I see.]"
msgstr "@kelvin 【𫥨勢。】"

#: Maps/Red ground/backalley/EV007:1:37:text
msgid "@kelvin [Oh, a cat.]"
msgstr "@kelvin 【溩、𠬠注貓。】"

#: Maps/Red ground/backalley/EV007:1:38:text
msgid "@kelvin [Are you lost?]"
msgstr "@kelvin 【㛪被落哰？】"

#: Maps/Red ground/backalley/EV007:1:39:text
msgid "@niko Me?"
msgstr "@niko 㛪吖？"

#: Maps/Red ground/backalley/EV007:1:40:text
msgid "@kelvin [Do you wish to join us?]"
msgstr "@kelvin 【㛪𣎏㦖𡎥喟衆英空？】"

#: Maps/Red ground/backalley/EV007:1:41:text
msgid "@niko Join... \\.\\@niko_speak your cats?"
msgstr "@niko 𡎥喟。。。 \\.\\@niko_speak 貓𧵑英𧘇吖？"

#: Maps/Red ground/backalley/EV007:1:42:text
msgid "@kelvin [Yes.]"
msgstr "@kelvin 【董丕。】"

#: Maps/Red ground/backalley/EV007:1:43:text
msgid "@niko But I'm not a cat..."
msgstr "@niko 扔㛪空沛貓。。。"

#: Maps/Red ground/backalley/EV007:1:44:text
msgid "@niko_eyeclosed I don't walk on four legs like they do..."
msgstr "@niko_eyeclosed 㛪兜𣎏𠫾憑𦊚蹎兜吖。。。"

#: Maps/Red ground/backalley/EV007:1:45:text
msgid "@kelvin [You have cat eyes.]"
msgstr "@kelvin 【㛪𣎏眜貓。】"

#: Maps/Red ground/backalley/EV007:1:46:text
msgid "@niko My eyes are normal people eyes..."
msgstr "@niko 眜㛪𪜀眜𠊛平常𦓡。。。"

#: Maps/Red ground/backalley/EV007:1:47:text
msgid "@niko_speak Well, normal back home!"
msgstr "@niko_speak 意𪜀、平常於茹㛪啞！"

#: Maps/Red ground/backalley/EV007:1:48:text
msgid "@kelvin [Your hat is shaped like a cat.]"
msgstr "@kelvin 【𢃱㛪拱𣎏𦖻貓𡛤。】"

#: Maps/Red ground/backalley/EV007:1:49:text
msgid "@niko But I'm just a person!"
msgstr "@niko 扔㛪𪜀𡥵𠊛催𦓡！"

#: Maps/Red ground/backalley/EV007:1:50:text
msgid "@kelvin [You are still welcome here.]"
msgstr "@kelvin 【㛪吻得嘲迍於低。】"

#: Maps/Red ground/backalley/EV007:1:51:text
msgid "@kelvin [I protect lost people as well.]"
msgstr "@kelvin 【英拱𠸒衛稚落𡛤。】"

#: Maps/Red ground/backalley/EV007:1:52:text
msgid "@niko_speak Thanks! \\.\\.\\@niko But I'm not lost though!"
msgstr "@niko_speak 感恩吖！ \\.\\.\\@niko 扔㛪空被落兜吖！"

#: Maps/Red ground/backalley/EV007:1:53:text
msgid "@niko I've got \\p to guide me!"
msgstr "@niko 㛪𣎏\\p引塘耒吖！"

#: Maps/Red ground/backalley/EV013:1:2:text ground/backalley/EV025:1:2:text
msgid "I see you have the club uniform."
msgstr "𪝬𧡊伴當𬡶同服俱樂部。"

#: Maps/Red ground/backalley/EV013:1:3:text ground/backalley/EV025:1:3:text
msgid "You may come in."
msgstr "𠸼𠓨。"

#: Maps/Red ground/backalley/EV013:1:8:text ground/backalley/EV025:1:8:text
msgid "@niko A curious marking on the wall."
msgstr "@niko 𠬠形𦘧奇𨓐𨑗墻。"

#: Maps/Red ground/backalley/EV013:1:9:text ground/backalley/EV025:1:9:text
msgid "@niko It looks like a... ram...?"
msgstr "@niko 𣎏𨤔𪜀𠬠𡥵。。。羝。。。？"

#: Maps/Red ground/backalley/EV016:1:1:text ground/backalley/EV024:1:1:text
msgid "@niko It's strangely warm in this room."
msgstr "@niko 𥪝房𤋾𦤾𨓐常。"

#: Maps/Red ground/backalley/EV064:1:1:text Maps/POSTGAME RED
#: GROUND/backalley/EV064:1:1:text
msgid "[P\\.\\.#L.%%E\\|AS;E D\\.O NO//T AP\\.\\.PR#OACH]"
msgstr "【口\\.\\.#千.%%扌\\|亭\\.彳//來\\.\\.近】"

#: Maps/Red ground/backalley/EV084:1:1:text ground/backalley/EV085:1:1:text
#: Maps/POSTGAME RED GROUND/backalley/EV084:1:1:text
#: GROUND/backalley/EV085:1:1:text
msgid "@niko It's a faded flyer."
msgstr "@niko 𠬠詞淶㐌㗑墨。"

#: Maps/Red ground/backalley/CUBBYHOLE:1:1:text Maps/POSTGAME RED
#: GROUND/backalley/CUBBYHOLE:1:1:text
msgid "@niko_speak It's a big crack in the wall!"
msgstr "@niko_speak 𠬠溪𡐘𡘯𥪝墻！"

#: Maps/Red ground/backalley/CUBBYHOLE:1:2:text Maps/POSTGAME RED
#: GROUND/backalley/CUBBYHOLE:1:2:text
msgid "@niko I see bunch of mice, huddled together."
msgstr "@niko 𨉟𧡊𠬠僤𤝞、𡇸群邊僥。"

#: Maps/Red ground/backalley/CUBBYHOLE:1:3:text Maps/POSTGAME RED
#: GROUND/backalley/CUBBYHOLE:1:3:text
msgid "@niko2 ...oh, but they scurried off..."
msgstr "@niko2 。。。溩、扔衆𠬃𠫾𠅒耒。。。"

#: Maps/Red ground/backalley/CUBBYHOLE:1:5:text Maps/POSTGAME RED
#: GROUND/backalley/CUBBYHOLE:1:5:text
msgid "@niko_eyeclosed I hope they didn't think I was gonna eat them..."
msgstr "@niko_eyeclosed 懞衆空擬𨉟定咹衆。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV004:1:1:text
#: point/Cabin/EV040:1:1:text
msgid "@niko It's a crate."
msgstr "@niko 𠬠丐桶。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/screwdriver:1:2:text
msgid "@niko_speak Ah...it's a screwdriver."
msgstr "@niko_speak 啊。。。𠬠隻須𥿀。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/screwdriver:1:4:text
msgid "@silver [You can take it if you want. It may help you.]"
msgstr "@silver 【㛪𣎏体𥙩伮裊㦖。𣎏体伮𠱊𢴇益朱㛪。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/screwdriver:1:6:text
msgid "@silver [Yes. I have many.]"
msgstr "@silver 【空懃客套𤴬。姉𣎏𡗉𦓡。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:1:text
msgid "@silver [Please do not touch that.]"
msgstr "@silver 【揨動𠓨丐妬。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:3:text
msgid "@niko_eyeclosed Sorry... I got curious..."
msgstr "@niko_eyeclosed 吀纇。。。㛪被殂摸吖。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:4:text
msgid "@niko ...what is this thing?"
msgstr "@niko 。。。丐之低吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:5:text
msgid "@silver [Back-up power cell. It keeps me functional.]"
msgstr "@silver 【汴預防。伮𡨺姉活動。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:6:text
msgid ""
"@silver_lookup [The main generator for the Barrens ran out of power some "
"time ago.]"
msgstr "@silver_lookup 【𣛠發電正於塳邊疆㐌𠅒電自隔低可嘍。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:7:text
msgid "@silver_eyeclosed [It could not even last a week without the sun.]"
msgstr "@silver_eyeclosed 【甚至伮哙空住得𠬠旬空𣎏𩈘𡗶。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:8:text
msgid "@niko_eyeclosed Sorry to hear that..."
msgstr "@niko_eyeclosed 㛪窒惜。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:1:9:text
msgid "@silver_lookup [All we can do is make use of the light we have.]"
msgstr "@silver_lookup 【𪨠姉只𣎏体盡用源暎𤏬哙徠。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:2:1:text
#: point/Cabin/EV006:6:1:text
msgid "@niko This is some kind of power cell, apparently!"
msgstr "@niko 𣎏𨤔𪜀𠬠𫪐汴之妬！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:2:2:text
#: point/Cabin/EV006:6:2:text
msgid "@niko The word \"SILVER\" is written on the side."
msgstr "@niko 𨑗𩈘邊𣎏𥱬𡨸【銀】。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:2:3:text
#: point/Cabin/EV006:6:3:text
msgid "@niko_speak Why does it say that?"
msgstr "@niko_speak 在哰丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:2:4:text
msgid "@silver_eyeclosed [That's not important.]"
msgstr "@silver_eyeclosed 【空連關𬧐㛪兜。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:3:5:text
msgid "@niko I got shocked..."
msgstr "@niko 𨉟被𪮞耒。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:3:6:text
msgid "@silver_eyeclosed [I told you not to touch it...]"
msgstr "@silver_eyeclosed 【㐌𠸒㛪揨𪮻𠓨伮耒𦓡。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:3:7:text
msgid "@niko_eyeclosed \\p made me."
msgstr "@niko_eyeclosed 由\\p妬。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV006:4:1:text
msgid "@niko_eyeclosed I'm not falling for that one again, \\p..."
msgstr "@niko_eyeclosed 𨉟縸擺妬吝𡛤兜、\\p。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:2:1:text
msgid "@niko The chess table has 2 small chairs."
msgstr "@niko 盤棋𤤰𣎏𠄩隻𧦕𡮈。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:3:text
msgid "@niko A chess table.\\>\\nIt's not dusty anymore."
msgstr "@niko 𠬠盤棋𤤰。\\>\\n伮空哙𡏧𠹰𡛤。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:15:text
msgid "@niko A dusty chess table."
msgstr "@niko 𠬠盤棋𤤰𡏧𠹰。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:18:text
msgid "@niko It's a metal chess table covered in dust."
msgstr "@niko 𠬠盤棋𤤰撫𡏧。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:20:text
msgid "@silver [I haven't played chess with anyone else for a very long time.]"
msgstr "@silver 【㐌窒嘍耒姉空打棋𤤰喟埃。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:22:text
msgid "@niko_speak Not even... \\.\\. with the other robots?"
msgstr "@niko_speak 𪥘󠄁喟仍。。。\\.\\.𠊛𣛠哙徠哰吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:23:text
msgid ""
"@silver_eyeclosed [No.] \\>\\n\\@silver [Nobody in the Barrens have that "
"capacity in their programming.]"
msgstr ""
"@silver_eyeclosed 【空。】 \\>\\n\\@silver 【空埃於塳邊疆得立程喟可能妬𪥘󠄁。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:3:24:text
msgid "@silver_eyeclosed [Nobody here is tamed, for that matter.]"
msgstr "@silver_eyeclosed 【因便時、於低拱空𣎏埃得純化兜。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:4:1:text Maps/Red
#: ground/backalley/lamplighter house/EV001:1:1:text
msgid "@niko A bed."
msgstr "@niko 𠬠隻床。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:4:2:text
msgid "@niko_speak It's made of metal...?"
msgstr "@niko_speak 𪵯憑金類。。。？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:4:3:text
msgid "@niko_eyeclosed Doesn't look very comfortable..."
msgstr "@niko_eyeclosed 𣎏𨤔空淹𡗋。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/Map Events:5:1:text
msgid "@niko A shelf of weird tools and pieces of metal."
msgstr "@niko 𠬠架𣹓仍工具奇𨓐吧各𤗖金類。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:1:text
msgid "@niko Lots of tiny shrimp are swimming in this jar."
msgstr "@niko 𥪝𤮗𣎏窒𡗉𩵽𡮈當𬈺。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:1:text
msgid "@niko There's lots of tiny glowing shrimp swimming in this jar."
msgstr "@niko 𥪝𤮗𣎏窒𡗉𩵽𡮈發𤏬當𬈺。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:2:text
msgid "@niko And lots of tiny shrimp that aren't glowing..."
msgstr "@niko 吧窒𡗉𩵽𡮈拱空發𤏬。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:3:text
msgid "@niko_eyeclosed ...or swimming..."
msgstr "@niko_eyeclosed 。。。或𬈺。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:5:text
msgid "@silver2 [No way! I just refilled that two days ago!]"
msgstr "@silver2 【𢭶！姉𣃣㵋𠊝𤮗㵋𠄩𣋚𠓀𦓡！】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:6:text
msgid "@silver_eyeclosed [Guess I'll make a trip to the shore later...]"
msgstr "@silver_eyeclosed 【𣎏𨤔姉沛𫥨坡㴜催。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:2:2:text
msgid "@silver_eyeclosed [These jars don't last very long.]"
msgstr "@silver_eyeclosed 【仍𤮗尼拱空住得嘍𡗋。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:2:5:text
#: point/Cabin/fireflies:1:1:text
msgid "@niko A jar full of glowing shrimp."
msgstr "@niko 𠬠𤮗𣹓仍𡥵𩵽𡮈發𤏬。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV023:1:2:text
msgid "$I heard the news about the mines."
msgstr "$姉㐌𦖑信𧗱𡌢𡎡。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV023:1:3:text
msgid "$I'm sorry... I can't imagine what you're feeling."
msgstr "$姉窒吀纇。。。空体想浽㛪當感𧡊勢鬧。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV023:1:5:text
msgid "$It's been two weeks..."
msgstr "$㐌𠄩旬耒妬。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV023:1:6:text
msgid "$I know it must be hard, but maybe it's better that you came back..."
msgstr "$姉別𪜀窒𠸋、扔𣎏𨤰㛪𢧚𢮿徠催。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV023:1:10:text
msgid "$-Kip"
msgstr "$－喼"

#: Maps/Blue/Cliffs/Lookout point/Cabin/fireflies:1:2:text
msgid "@niko The top is covered with a wire mesh."
msgstr "@niko 份𨑗得撫䋥𨨧。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV038:1:1:text
msgid "@niko It's a photo of two people."
msgstr "@niko 𠬠幅影𨄴𠄩𠊛。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/EV038:1:2:text
msgid "@niko The glass is a bit too foggy to see details, though."
msgstr "@niko 扔𩈘鏡唏過𥊚𢧚空体𧡊𤑟各枝節。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:3:text
msgid "@silver2 [Oh, it's that journal you showed me in the mines.]"
msgstr "@silver2 【溩、𪜀捲日記㛪朱姉䀡𥪝𡌢𡎡。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:4:text
msgid "@silver [Doesn't look like it's glowing anymore, though.]"
msgstr "@silver 【扔𣎏𨤔伮空發𤏬𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:5:text
msgid "@niko Do you know what I'm supposed to do with it?"
msgstr "@niko 姉𣎏別㛪沛𪵯之喟伮空吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:6:text
msgid "@silver2 [I am unsure, but...]"
msgstr "@silver2 姉空別、扔。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:7:text
#: point/Cabin/npc_silver:1:20:text
msgid "@silver [...hold on to the journal for now.]"
msgstr "@silver 【。。。暫時㛪𢧚𡨺𥙩伮。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:8:text
#: point/Cabin/npc_silver:1:21:text
msgid "@silver [It will be important.]"
msgstr "@silver 【伮𠱊關重妬。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:9:text
#: point/Cabin/npc_silver:1:22:text
msgid "@niko O...kay..."
msgstr "@niko 嗚。。。雞。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:12:text
msgid "@niko Excuse me, miss..."
msgstr "@niko 姉㗒。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:13:text
msgid "@niko_speak I found this book.\\nDo you know anything about it?"
msgstr "@niko_speak 㛪尋𧡊卷冊尼。\\n姉𣎏別之𧗱伮空吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:14:text
msgid "@silver [Let me see.\\..\\..]"
msgstr "@silver 【抵姉䀡鬧。\\.。\\.。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:15:text
msgid "@silver2 [What language is this...?]"
msgstr "@silver2 【言語之低。。。？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:16:text
msgid ""
"@silver_eyeclosed [I'm sorry, I... don't even recognize this writing system.]"
msgstr "@silver_eyeclosed 【姉吀纇、姉。。。哙空別低𪜀系𡨸𢪏之𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:17:text
msgid "@niko Ah, well, it was worth a shot."
msgstr "@niko 啊、時、拱當試𠳨姉𠬠吝。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:18:text
msgid "@silver2 [Although...this insignia.]"
msgstr "@silver2 【扔。。。符號尼。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:19:text
#: point/Cabin/npc_silver:1:57:text point/Cabin/npc_silver:4:34:text
#: point/Cabin/npc_silver:4:41:text
msgid "@silver [...]"
msgstr "@silver 【。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:29:text
msgid "@silver [Off you go...]"
msgstr "@silver 【㛪𠫾唲。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:30:text
msgid "@silver [There's no reason for you to linger in the Barrens.]"
msgstr "@silver 【㛪空𢧚儺徠漨邊疆嘍𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:33:text
msgid "@niko_speak Excuse me again, miss..."
msgstr "@niko_speak 姉㗒。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:34:text
msgid "@niko_speak I found a robot who can take me towards the Tower!"
msgstr "@niko_speak 㛪𧡊𣎏𠬠𠊛𣛠𣎏体迻㛪𦤾座塔耒吖！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:35:text
msgid ""
"@niko_eyeclosed ...but it's having some trouble, so it told me to talk to "
"you."
msgstr "@niko_eyeclosed 。。。扔伮當﨤𠃣事故、𢧚伮𠸒㛪𦤾﨤姉。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:36:text
msgid "@silver [Alright.\\>\\nWhat is the issue?]"
msgstr "@silver 【得耒。\\>\\n事故之丕？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:37:text
msgid "@niko It said something about its navigation circuits being fried."
msgstr "@niko 伮吶之妬𧗱各脈電定位㐌被閧完全。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:38:text
msgid "@silver2 [Just the navigation circuits?]"
msgstr "@silver2 【只各脈電定位催哰？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:39:text
msgid ""
"@niko_speak Apparently!\\n\\>\\@niko \\p and I fixed everything else, I "
"think..."
msgstr "@niko_speak 㛪擬勢！\\n\\>\\@niko 𣎏𨤔㛪吧\\p㐌𢯢歇𤗆次恪耒吖。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:40:text
msgid "@silver [Hm...]"
msgstr "@silver 【嘘。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:41:text
msgid "@silver [I have something that may help.]"
msgstr "@silver 【姉𣎏𦁺尼𣎏体𢴇。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:42:text
msgid ""
"@silver_lookup [Rowbots have the ability to trace material from their source "
"locations.]"
msgstr "@silver_lookup 【𠊛𣛠棹船𣎏可能追𤵖物料自地点源㭲𧵑衆。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:43:text
msgid ""
"@silver [If you let the rowbot borrow this, then its backup tracking system "
"should activate.]"
msgstr "@silver 【裊㛪抵𪝳摱丐尼、系統𢲛塘預房𧵑𪝳𠱊激活。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:51:text
msgid "@niko_speak That's a very pretty necklace!"
msgstr "@niko_speak 隻𤥑𦙶窒惵妬吖！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:52:text
msgid "@niko What's it made of?"
msgstr "@niko 伮𪵯憑之丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:53:text
msgid "@silver_lookup [Amber found from the Glen.]"
msgstr "@silver_lookup 【琥珀𥪝塳潭浰。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:54:text
msgid "@niko What's the thing inside the amber?"
msgstr "@niko 邊𥪝𠰳琥珀𪜀之丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:55:text
msgid ""
"@silver2 [The black clover? \\>\\n\\@silver That's a common plant in our "
"world.]"
msgstr "@silver2 【𣘃𦹯𠀧蘿黰𧘇嘑？\\>\\n\\@silver 𠬠類𣘃普遍𥪝世界尼。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:56:text
msgid "@silver_lookup [It's also...]"
msgstr "@silver_lookup 【伮拱𪜀。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:58:text
msgid "@niko ?"
msgstr "@niko ？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:59:text
msgid ""
"@silver_eyeclosed [Sigh...I'm not sure if I can bear to part with this.]"
msgstr "@silver_eyeclosed 【係。。。姉空昃𣎏体嘲暫別伮唉空。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:60:text
msgid ""
"@silver_eyeclosed [My programming says yes, but I still feel conflicted.]"
msgstr "@silver_eyeclosed 【立程𧵑姉吶𪜀𣎏、扔姉吻空安心𡗋。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:62:text
msgid "@silver_eyeclosed [Nevermind.]"
msgstr "@silver_eyeclosed 【偈𠫾。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:63:text
msgid ""
"@silver_eyeclosed [You need to finish your mission more than I need a "
"keepsake.]"
msgstr "@silver_eyeclosed 【㛪懃完成任務欣𪜀姉懃𠬠𦁺紀念。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:64:text
msgid "@silver [Here.]"
msgstr "@silver 【低。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:65:text
msgid "@niko_speak Oh, thank you!"
msgstr "@niko_speak 溩、感恩姉吖！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:75:text
msgid "@silver [Do you need further assistance?]"
msgstr "@silver 【㛪懃𢴇之𡛤空？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:76:text
msgid "@niko We're good, thanks!"
msgstr "@niko 𪨠㛪穩耒、感恩姉吖！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:79:text
msgid "@niko_speak What's inside the Tower?"
msgstr "@niko_speak 邊𥪝座塔𣎏之丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:80:text
msgid "@silver_lookup [I don't know. Nobody's ever entered it before.]"
msgstr "@silver_lookup 【姉𠹾。貯曾𣎏埃𠓨𥪝妬。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:81:text
msgid "@silver [At least, nobody history knows.]"
msgstr "@silver 【𠃣一𪜀、歷史空別𧗱埃。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:82:text
msgid "@niko Then... who built it?"
msgstr "@niko 勢時。。。埃𡏦伮丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:83:text
msgid "@silver2 [Built?]"
msgstr "@silver2 【𡏦嘑？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:84:text
msgid ""
"@silver [As far as anyone can tell, it's been there since the beginning of "
"time.]"
msgstr "@silver 【蹺𤗆𠊛別時、伮㐌於妬自𣇫創世。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:85:text
msgid "@silver [I know someone who wanted to study it before, but...]"
msgstr "@silver 【姉𣎏慣𠬠𠊛曾定研究伮、扔。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:86:text
msgid "@silver_eyeclosed [...]"
msgstr "@silver_eyeclosed 【。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:1:88:text
msgid "@silver [He never told me if it went anywhere.]"
msgstr "@silver 【英𧘇空朱姉別𣎏結果之空。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:6:text
msgid "@silver2 [The lightbulb...]"
msgstr "@silver2 【琫畑。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:10:text
msgid "@silver2 [So, are you the \"messiah\"?]"
msgstr "@silver2 【㛪𪜀「𠎬救世」哰？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:11:text
msgid "@niko That's what I've been told."
msgstr "@niko 㛪𦖑𠸒丕吖。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:12:text
msgid "@silver [I expected someone...taller.]"
msgstr "@silver 【姉想哴𠱊𪜀埃妬。。。高欣。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:13:text
msgid ""
"@silver_eyeclosed [Or at least someone that doesn't look like a kitten.]"
msgstr "@silver_eyeclosed 【或𠃣一𪜀空矓如貓𡥵。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:14:text
msgid "@silver [That's what you are, right? Some sort of cat?]"
msgstr "@silver 【𪜀㛪沛空？𠬠類貓鬧妬嘑？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:15:text
msgid "@niko Nuh-uh!"
msgstr "@niko 淤唹！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:16:text
msgid "@niko_speak I'm a person!"
msgstr "@niko_speak 㛪𪜀𡥵𠊛妬！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:17:text
msgid "@silver [You got the eyes of a cat...]"
msgstr "@silver 【扔眜㛪𪜀眜貓。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:18:text
msgid "@niko_speak But cats walk on four legs!"
msgstr "@niko_speak 扔貓𠫾憑𦊚蹎𦓡！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:19:text
msgid "@silver_eyeclosed [Well, either way...]"
msgstr "@silver_eyeclosed 【怞哰時。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:20:text
msgid ""
"@silver_lookup [A child like you being the messiah...just doesn't feel "
"right.]"
msgstr "@silver_lookup 【𠬠𠀲稚如㛪𪵯𠎬救世。。。𦖑空董𠬠𡭧鬧。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:21:text
msgid "@niko_eyeclosed But that robot back there says there's no mistake..."
msgstr "@niko_eyeclosed 扔𠊛𣛠外其𠸒𪜀昃𥗜董耒𦓡。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:22:text
#: point/Cabin/npc_silver:4:26:text
msgid "@silver [I know.]"
msgstr "@silver 【姉別。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:23:text
msgid "@silver_eyeclosed [...sigh.]"
msgstr "@silver_eyeclosed 【。。。係。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:24:text
msgid "@silver_eyeclosed [This is going to sound cold, but...]"
msgstr "@silver_eyeclosed 【𦖑𠱊窒無心、扔。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:25:text
msgid ""
"@silver_lookup [I honestly think you are better off just...leaving and "
"letting the world die naturally.]"
msgstr "@silver_lookup 【姉寔事勸㛪𢧚。。。𨖨𠫾吧抵世界𣩂自然。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:26:text
msgid "@silver [The world has been falling apart for a long time.]"
msgstr "@silver 【世界尼㐌扒頭散沲自窒嘍耒。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:27:text
msgid ""
"@silver_eyeclosed [This manner of decay...It's highly unprobable that the "
"sun can fix it.]"
msgstr "@silver_eyeclosed 【𣞪度散沲尼。。。可能𩈘𡗶𢯢得伮𪜀窒隰。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:28:text
msgid "@silver [You've already seen how bad it can get, right?]"
msgstr "@silver 【㛪㐌𧡊伮𣎏体弊𦤾櫸鬧耒渚？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:29:text
msgid "@niko We...haven't seen much of anything, actually..."
msgstr "@niko 寔𫥨。。。𪨠㛪貯𧡊𡗉次𡗋。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:30:text
msgid "@niko_eyeclosed And we can't really just leave..."
msgstr "@niko_eyeclosed 吧𪨠㛪拱空𨖨𠫾得。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:31:text
msgid "@silver2 [Oh, so you just got here?]"
msgstr "@silver2 【溩、𫥨𪜀㛪𣃣𦤾低哰？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:32:text
msgid "@silver [Then you must be headed towards the Tower.]"
msgstr "@silver 【𪳨𪜀㛪當𨑗塘𦤾座塔。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:34:text
msgid "@niko It's where I'm supposed put the lightbulb... er, sun, isn't it?"
msgstr "@niko 𪜀坭㛪沛撻丐琫畑。。。唹、𩈘𡗶、沛空吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:35:text
msgid "@silver [Yes, at the very top.]"
msgstr "@silver 【董丕、於𨑗頂。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:36:text
msgid ""
"@silver_lookup [We know that the Tower contains a force that nobody could "
"comprehend.]"
msgstr "@silver_lookup 【衆些別哴座塔貯𠬠源能量空想。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:37:text
msgid "@silver_lookup [And the power is strongest at the summit.]"
msgstr "@silver_lookup 【吧能量妬猛一𨑗頂。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:38:text
msgid ""
"@silver [Maybe it will send you back home after you complete your mission.]"
msgstr "@silver 【𣎏体伮𠱊迻㛪𧗱茹𢖖󠄁欺完成任務。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:39:text
#: Maps/Tower/Water/pc:1:35:text
msgid "@niko_pancakes Oh!"
msgstr "@niko_pancakes 溩！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:2:40:text
msgid "@silver_eyeclosed [Don't take my word for it, though.]"
msgstr "@silver_eyeclosed 【扔揨信姉完全唲。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:1:text
msgid "@niko Before I go...\\. Is there anything I can do in return?"
msgstr "@niko 𠓀欺㛪𠫾。。。\\.㛪𣎏体𪵯之㨋徠姉空吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:2:text
msgid "@silver [Actually...]"
msgstr "@silver 【寔𫥨。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:3:text
msgid "@silver2 [Do you... \\.\\. know how to play chess?]"
msgstr "@silver2 【㛪𣎏別。。。\\.\\.𨔈棋𤤰空？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:4:text
msgid "@niko_speak Yeah!\\n\\>\\@niko Well, sort of..."
msgstr "@niko_speak 𣎏吖！\\n\\>\\@niko 時、大概丕吖。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:5:text
msgid "@niko_speak I've played it with some older kids before!"
msgstr "@niko_speak 㛪𨔈喟𠄧英姉耒吖！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:6:text
msgid "@silver [Then, will you play a game with me?]"
msgstr "@silver 【丕時、㛪𣎏体打𠬠板喟姉渚？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:7:text
msgid "@niko_eyeclosed I mean, I don't know the rules very well...."
msgstr "@niko_eyeclosed 意𪜀、㛪拱空𤑟律𨔈𡗋。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:8:text
msgid "@niko_speak But I guess it's the least I could do!"
msgstr "@niko_speak 扔㛪𠱊固吖！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:19:text
msgid "@niko You're really good at this!"
msgstr "@niko 姉𨔈𠐞𧦕！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:20:text
msgid "@silver [Thank you.\\>\\n\\@silver2 It was built into my code.]"
msgstr "@silver 【吀感恩。\\>\\n\\@silver2 伮得立程𥪝碼源𧵑姉。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:22:text
msgid ""
"@niko So.... \\>\\@niko_speak What's it like?\\>\\n\\@niko Being a robot and "
"all..."
msgstr ""
"@niko 丕時。。。。\\>\\@niko_speak 局𤯩勢鬧丕吖？\\>\\n\\@niko 𪜀𠬠𠊛𣛠"
"吧。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:23:text
msgid ""
"@niko I've talked to other robots, and they all say something about "
"programming and code and stuff."
msgstr "@niko 㛪㐌吶𡀯喟𠬠数𠊛𣛠恪、吧衆調吶𧗱立程喟徠碼喟徠各次。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:24:text
msgid "@niko_speak Even you did, just now!"
msgstr "@niko_speak 𪥘󠄁姉𡛤、𬆄𣃣𣅅！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:25:text
msgid "@niko_eyeclosed It's a little hard to understand sometimes."
msgstr "@niko_eyeclosed 對𣅶衆𠸋曉實。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:27:text
msgid "@silver_eyeclosed [Most of the robots here are not tamed.]"
msgstr "@silver_eyeclosed 【份𡘯𠊛𣛠於低空得純化。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:29:text
msgid "@silver [Watch out.]"
msgstr "@silver 【謹慎。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:30:text
msgid "@niko_what ...\\.\\.there goes my bishop..."
msgstr "@niko_what 。。。\\.\\.𠅒象耒。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:31:text
msgid "@silver [Taming... \\.\\. is complicated.]"
msgstr "@silver 【役純化。。。\\.\\.窒複雜。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:33:text
msgid "@niko_speak How complicated, exactly?"
msgstr "@niko_speak 複雜𦤾櫸鬧丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:35:text
msgid "@niko_eyeclosed ...\\.\\.there goes my other bishop..."
msgstr "@niko_eyeclosed 。。。\\.\\.。。。𠅒訥𡥵象其耒。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:36:text
msgid "@silver_lookup [I can't really explain what tamed robots are.]"
msgstr "@silver_lookup 【姉空体解釋正確𠊛𣛠純化𪜀之得。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:37:text
msgid "@silver [But I'm one of them.]"
msgstr "@silver 【扔姉𪜀𠬠𠊛𣛠如丕。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:38:text
msgid ""
"@silver_lookup [All the other tamed robots have been moved to other regions.]"
msgstr "@silver_lookup 【全部各𠊛𣛠純化哙徠㐌得輪轉𨖅各塳恪。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:39:text
msgid "@silver_eyeclosed [Exactly where, I don't know.]"
msgstr "@silver_eyeclosed 【正確𪜀兜、時姉空別。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:42:text
msgid "@niko_what ...\\.\\.there goes my little horse..."
msgstr "@niko_what 。。。\\.\\.𠅒𠅒𡥵馭耒。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:43:text
msgid "@silver [Knight.]"
msgstr "@silver 【馬。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:45:text
msgid ""
"@niko_speak Oh! Have you ever been to any other regions?\\n\\>\\@niko I "
"heard that there's two more."
msgstr "@niko_speak 溩！姉𦤾各塳恪𣗓吖？\\n\\>\\@niko 㛪𦖑𪜀哙𠄩塳𡛤。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:46:text
msgid "@silver [In the past, yes.]"
msgstr "@silver 【𥪝過去、時耒。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:47:text
msgid ""
"@silver_eyeclosed [I still have the data, the coordinates,\\. the "
"memories...]"
msgstr "@silver_eyeclosed 【姉吻哙與料、仍座度、\\.仍記憶。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:48:text
msgid "@silver_eyeclosed [...I don't know how much of that still holds true.]"
msgstr "@silver_eyeclosed 【。。。姉空別包饒份𤾓𥪝数妬吻哙董。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:49:text
msgid "@silver [The world may be a very different place now.]"
msgstr "@silver 【𣎏体世界㐌𠭤成𠬠坭窒恪。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:50:text
msgid "@niko Because the sun is gone?"
msgstr "@niko 爲𩈘𡗶㐌闃耒吖？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:51:text
msgid "@silver [No.]"
msgstr "@silver 【空。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:52:text
msgid "@silver2 [I said this already, didn't I?]"
msgstr "@silver2 【姉吶耒𦓡、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:53:text
msgid "@silver [The sun probably won't save the world.]"
msgstr "@silver 【𩈘𡗶𣎏𨤰𠱊空救得世界兜。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:54:text
msgid "@silver_lookup [The decaying started back before the sun went out.]"
msgstr "@silver_lookup 【事散沲㐌扒頭自窒嘍𠓀欺𩈘𡗶𨄠。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:55:text
msgid ""
"@silver_eyeclosed [The sun's sudden death was just the tipping point, and "
"things went south really fast after that.]"
msgstr "@silver_eyeclosed 【丐𣩂突兀𧵑𩈘𡗶只𪜀頂点、吧𤗆次弊𠫾窒𨘱𢖖󠄁妬。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:57:text
msgid "@niko_eyeclosed Then... there's nothing I can do?"
msgstr "@niko_eyeclosed 丕𪜀。。。㛪空体𪵯之哰？"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:58:text
msgid "@silver [Check.]"
msgstr "@silver 【照將。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:59:text
msgid "@niko_speak W-what!"
msgstr "@niko_speak 嘑！"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:60:text
msgid "@niko_eyeclosed When did your queen get there..."
msgstr "@niko_eyeclosed 后𧵑姉𦤾妬自欺鬧丕。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:61:text
msgid "@silver [The only thing you can do is complete your pilgrimage.]"
msgstr "@silver 【條唯一㛪𣎏体𪵯𪜀完畢轉行鄉尼。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:62:text
msgid ""
"@silver_lookup [In a way, you are only supposed to be a second chance for "
"the people.]"
msgstr "@silver_lookup 【蹺𠬠格鬧妬、㛪只𪜀𠬠機會次𠄩句𠳨𤗆𠊛𦓡催。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:63:text
msgid ""
"@silver [Just like how the Barrens was only supposed to be a second chance "
"for me.]"
msgstr "@silver 【如丐格𦓡塳邊疆只𪜀𠬠機會次𠄩朱姉丕。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:64:text
msgid "@silver_eyeclosed [There's no guarantee that things will work out.]"
msgstr "@silver_eyeclosed 【空擔保得𤗆次𠱊棆𢩿。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:65:text
msgid "@niko But..."
msgstr "@niko 扔。。。"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:66:text
msgid "@silver [Checkmate.]"
msgstr "@silver 【歇棋。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:68:text
msgid "@silver_eyeclosed [Alright, guess I've kept you long enough...]"
msgstr "@silver_eyeclosed 【得耒、𣎏𨤔姉㐌𡨺㛪徠𨁥嘍耒。。。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:69:text
msgid "@silver [...Thank you for listening.]"
msgstr "@silver 【。。。感恩㛪㐌𢠯𦖑。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:70:text
msgid "@silver [I hope you get home safely.]"
msgstr "@silver 【懞㛪𧗱茹安全。】"

#: Maps/Blue/Cliffs/Lookout point/Cabin/npc_silver:4:71:text
msgid "@niko Ah, thank you also!"
msgstr "@niko 啊、㛪拱感恩姉吖！"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:28:text
msgid "@rue_sigh You know... \\.\\.This is the tallest building in the refuge."
msgstr "@rue_sigh 㛪別空。。。\\.\\.低𪜀座茹高一𥪝區避難妬。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:29:text
msgid "@rue It's...\\.\\. my favorite place in this world."
msgstr "@rue 𪜀。。。\\.\\.坭姉適一𥪝世界尼。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:30:text
msgid ""
"@rue I liked to look at the far-off buildings and imagine...\\.\\.what kind "
"of lives that might be behind each of the windows."
msgstr "@rue 姉常矓𧗱仍座茹滕賒吧想像。。。\\.\\.局𤯩𠌨𢖖󠄁曾𦑃𫔤擻𫥨哰。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:36:text
msgid "@rue_talk ...Can you...\\.\\. lift me onto the banister?"
msgstr "@rue_talk 。。。㛪。。。\\.\\.𢩮姉𬨠欄杆得空？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:37:text
msgid "@rue I want to get a better look."
msgstr "@rue 姉㦖𥆾𤗆次𤑟欣。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:52:text
msgid "@rue_sad It was depressing for me at first too, you know..."
msgstr "@rue_sad 㛪別空、班頭姉拱窒𢞂妬。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:53:text
msgid "@rue Knowing that all of this is...\\.\\. well..."
msgstr "@rue 欺別𤗆次。。。\\.\\.調。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:54:text
msgid "@niko_upset2 ...fake?"
msgstr "@niko_upset2 。。。假吖？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:55:text
msgid "@rue_sigh Simulated."
msgstr "@rue_sigh 調得模倣。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:57:text
msgid "@niko3 ...Cedric... told me about what happened to your old world."
msgstr "@niko3 。。。察嚦。。。㐌𠸥朱㛪仍之㐌侈𫥨𥪝世界𫇰𧵑姉。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:58:text
msgid "@rue_talk Did he?"
msgstr "@rue_talk 丕哰？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:59:text
msgid ""
"@niko_eyeclosed I'm... really sorry about that... \\> \\@niko_upset I can't "
"imagine...\\.\\.how you must feel..."
msgstr ""
"@niko_eyeclosed 㛪。。。窒惜。。。 \\> \\@niko_upset 㛪空体想像浽。。。\\.\\."
"姉感𧡊勢鬧。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:61:text
msgid "@rue_sad The feeling of never being able to go home again...?"
msgstr "@rue_sad 感覺空包𣇞𣎏体𠭤𧗱茹𡛤嘑。。。？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:62:text
msgid ""
"@rue That's... \\.\\.probably not all that different from your plight, is it?"
msgstr "@rue 拱。。。\\.\\.空恪挭𥘀𧵑㛪𪜀包、𠰚？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:64:text
msgid "@rue_sad ...it really IS ironic."
msgstr "@rue_sad 。。。實咋嘹。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:65:text
msgid ""
"@rue You are prevented from going home by the same...\\.\\.individual...\\."
"\\. who never wanted to bring you here."
msgstr "@rue 㛪空体𠭤𧗱茹由共𠬠。。。\\.\\.個人。。。\\.\\.𣗓曾㦖㛪𦤾低。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:66:text
msgid "@niko3 ...Huh?\\> Who would that be?"
msgstr "@niko3 。。。𠼯？\\>埃丕吖？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:67:text
msgid "@rue The World Machine."
msgstr "@rue 鈷𣛠全世。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:68:text
msgid "@rue_talk You... might know it as the Entity."
msgstr "@rue_talk 㛪。。。𣎏体哙吶𪜀寔体。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:69:text
msgid "@niko2 Oh..."
msgstr "@niko2 溩。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:70:text
msgid "@niko_eyeclosed \"The Entity\"... DOES sound familiar."
msgstr "@niko_eyeclosed 「寔体」。。。𦖑可慣。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:71:text
msgid "@niko2 I think I heard it from the dice lady, from another time."
msgstr "@niko2 形如㛪𦖑姉頭劅色𠸥、自𠓀妬。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:72:text
msgid "@niko3 Was it... the spirit of the world?"
msgstr "@niko3 伮。。。𣎏沛𪜀靈魂𧵑世界空吖？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:73:text
msgid "@rue_smile Yes!"
msgstr "@rue_smile 董丕！"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:74:text
msgid "@rue ...."
msgstr "@rue 。。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:77:text
msgid ""
"@rue ...But... thing is...\\>\\n\\@rue_sigh The World Machine was only built "
"to run on the mental abilities of someone else."
msgstr ""
"@rue 。。。扔。。。縸𠬠𡊲𪜀。。。\\>\\n\\@rue_sigh 𣛠全世只得設計抵𧼋𨑗可能思"
"維𧵑𠬠𡥵𠊛恪。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:78:text
msgid "@rue_talk It was never meant to develop a mind of its own."
msgstr "@rue_talk 伮空包𣇞𢧚自發展𠬠意識𥢆別。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:80:text
msgid "@rue_sigh It was an oversight."
msgstr "@rue_sigh 妬𪜀𠬠疏率。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:81:text
msgid ""
"@rue_sad My creator specialized in artificial intelligence for so long... "
"\\>\\nIt was simply ingrained in his work."
msgstr ""
"@rue_sad 𠎬創世㐌𪵯役喟智慧人造嘍𦤾餒。。。\\>\\n伮㐌咹漊𠓨𥪝工程𧵑翁。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:82:text
msgid "@rue_sigh ...sigh."
msgstr "@rue_sigh 。。。係。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:83:text
msgid ""
"@rue And... all machines are built with a fundamental law. \"Never let a "
"living being come to harm\"."
msgstr "@rue 吧。。。悉𪥘󠄁𣛠𢪮調得𡏦𥩯喟𠬠規則基本。「空得抵𠬠寔体𤯩﨤危。」"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:84:text
msgid ""
"@rue From the World Machine's perspective, it has to violate its deepest, "
"most foundational instinct."
msgstr "@rue 蹺𧣳𥆾𧵑鈷𣛠全世、伮沛違犯本能漊一、基礎一𧵑伮。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:85:text
msgid "@rue_sigh It has to put a living person in danger."
msgstr "@rue_sigh 伮沛撻𠬠𠊛𤯩𠓨情勢危險。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:86:text
msgid ""
"@rue_sigh It has to bring a real person into a dying world that isn't even "
"real."
msgstr "@rue_sigh 伮沛迻𠬠𠊛實𠓨𠬠世界當𣩂甚至哙空𣎏實。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:88:text
msgid "@rue ...Of course, the simulation never contained any real danger."
msgstr "@rue 。。。必然、程模倣𣗓曾𣎏危險寔事鬧。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:89:text
msgid "@rue_talk The eventual, intended ending was meant to be a happy one."
msgstr "@rue_talk 丐結𡳳共、得定𠓀𪜀𠬠丐結惵。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:90:text
msgid "@rue ...but the World Machine doesn't know that."
msgstr "@rue 。。。扔鈷𣛠全世空別條妬。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:91:text
msgid "@niko3 ...really?"
msgstr "@niko3 。。。實唹？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:92:text
msgid "@rue_sad Unfortunately..."
msgstr "@rue_sad 窒惜𪜀如丕。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:93:text
msgid ""
"@rue Sentient machines tend to handle conflicts in their code very badly."
msgstr "@rue 𣛠𢪮𣎏認識常處理衝突𥪝碼源窒弊。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:94:text
msgid ""
"@rue_sad This central conflict triggered a self- destructive downward spiral."
msgstr "@rue_sad 衝突中心尼㐌𨠳𫥨𠬠𤥑鬠自壞𠫾𬺗。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:95:text
msgid ""
"@rue_sigh You can see physical manifestations of that everywhere, now..."
msgstr "@rue_sigh 𣇞、㛪𣎏体𧡊事現面物理𧵑衆泣𤗆坭。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:96:text
msgid "@niko4 The squares..."
msgstr "@niko4 仍塊𣃱。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:97:text
msgid "@rue That's the World Machine corrupting its own code."
msgstr "@rue 妬𪜀𣛠全世當自毀壞碼源𧵑正伮。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:98:text
msgid ""
"@rue_talk ...My creator says it's largely an involuntary process, induced by "
"stress and the desire to self- terminate."
msgstr "@rue_talk 。。。𠎬創世吶哴伮𪜀𠬠過程空体檢詧、𨠳𢧚𤳸𢫮𣦎吧懞㦖自害。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:99:text
msgid "@niko3 Your creator knows?"
msgstr "@niko3 𠎬創世別吖？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:100:text
msgid "@niko4 Sounds like this has been going on since the beginning, then..."
msgstr "@niko4 𣎏𨤔伮㐌𣎏自𣅶扒頭耒、𠰚。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:101:text Events:1:135:text
msgid "@rue_sigh Yeah."
msgstr "@rue_sigh 𫫡。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:103:text
msgid "@rue_talk The disruption was an issue during test runs, even."
msgstr "@rue_talk 事擾亂甚至㐌出現𥪝仍吝𧼋試幾。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:104:text
msgid ""
"@rue At first, my creator thought the instability was due to the sheer scope "
"of the project."
msgstr "@rue 班頭、作者想哴事不穩定尼𦤾自尋櫸𧵑預案。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:105:text
msgid ""
"@rue He spent most of his remaining time testing it over and over again, "
"scaling down the story, reiterating the narrative..."
msgstr "@rue 翁𧶄份𡘯時間哙徠𧼋試𠫾試徠、收𡮈句𡀯徠、曰徠歇版尼𦤾版恪。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:106:text
msgid ""
"@rue_sad ...by the time he realized the actual root of the problem, our home "
"world's remaining lifespan was measured in mere days."
msgstr ""
"@rue_sad 。。。朱𦤾𣅶翁認𫥨源㭲實事𧵑問題、歲寿哙徠𧵑世界𫇰只哙併憑𣈜。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:107:text
msgid "@niko4 ...Oh."
msgstr "@niko4 。。。溩。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:108:text
msgid "@niko3 ...is there....\\.\\. any way for us to..."
msgstr "@niko3 。。。𣎏格鬧。。。\\.\\.抵衆些。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:109:text
msgid "@rue_talk ...fix the World Machine? \\>\\n\\@rue_sad We tried."
msgstr "@rue_talk 。。。𢯢𣛠全世哰？ \\>\\n\\@rue_sad 𪨠姉㐌試耒。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:110:text
msgid ""
"@rue_sad The World Machine doesn't believe any of the world's residents are "
"real."
msgstr "@rue_sad 𣛠全世空信哴仍居民𥪝世界尼𪜀實。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:111:text
msgid "@rue ...myself included."
msgstr "@rue 。。。包𠁟𪥘󠄁姉。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:112:text
msgid "@rue_sad The odds are against us... we have no chance of taming it."
msgstr "@rue_sad 𤗆次調𢶢徠衆些。。。空哙機會鬧抵純化伮𪥘󠄁。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:113:text
msgid "@niko2 Taming?"
msgstr "@niko2 純化？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:114:text
msgid "@niko_eyeclosed I have heard that word SO many times!"
msgstr "@niko_eyeclosed 㛪𦖑詞妬𡗉吝𡗋耒妬！"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:115:text
msgid ""
"@niko5 I only know it's complicated \\.\\.\\n\\@niko6 ...and that it has to "
"do with robots, but..."
msgstr ""
"@niko5 㛪只別𪜀伮複雜\\.\\.\\n\\@niko6 。。。吧伮連關𦤾𠊛𣛠、扔𦓡。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:116:text
msgid "@niko2 ...for once, I want to know what it really means."
msgstr "@niko2 。。。吝尼、㛪寔事㦖別伮義𪜀之。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:117:text
msgid "@rue_smile ...that's what I'm here for."
msgstr "@rue_smile 。。。𢧚姉㵋於低妬。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:118:text
msgid "@rue Do you...\\.\\. know what a robot is?"
msgstr "@rue 㛪。。。𣎏\\.\\.別𠊛𣛠𪜀之空？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:119:text
msgid "@niko Yeah?"
msgstr "@niko 𣎏渚吖？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:120:text
msgid "@rue No, I mean. \\>\\nDo you KNOW what a robot is?"
msgstr "@rue 空、意姉𪜀。\\>\\n㛪𣎏寔事別𠊛𣛠𪜀之空？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:122:text
msgid "@rue A robot is not a real person, is it?"
msgstr "@rue 𠊛𣛠時空沛𠊛實、沛空？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:123:text
msgid "@niko2 ...right."
msgstr "@niko2 。。。沛。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:124:text
msgid "@rue It's a being whose entire existence is code."
msgstr "@rue 妬𪜀𠬠寔体得襘袞𥪝𠬠段碼。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:125:text
msgid ""
"@rue_talk Inflexible programming, with thoughts dictated by someone else's "
"design."
msgstr "@rue_talk 立程勁𠯅、喟思維被抪狹𤳸設計𧵑𠊛恪。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:126:text
msgid ""
"@rue They can be copied, they can be mass produced, then can be assigned all "
"sorts of jobs."
msgstr "@rue 𣎏体抄劄衆、𣎏体產出衆行刷、歱𣎏体朱衆𨁥類工役恪僥𡛤。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:127:text
msgid ""
"@rue ...And most importantly... they will never confuse themselves with the "
"living."
msgstr "@rue 。。。吧關重一𪜀。。。衆𠱊空包𣇞𡍚悋本身喟𠊛𤯩。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:128:text
msgid ""
"@rue They will always be bound by their code, the knowledge that they are a "
"robot."
msgstr "@rue 衆𠱊㫻被𦀾𫃚𤳸碼源、𤳸事自認別哴衆只𪜀𠊛𣛠。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:129:text
msgid "@rue ...but this was more of a limitation than anything else."
msgstr "@rue 。。。扔低只𪜀𠬠樔捍𦓡催。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:130:text
msgid "@niko_eyeclosed Ah, that makes sense."
msgstr "@niko_eyeclosed 啊、合理。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:131:text
msgid ""
"@niko2 You can't... really build a robot to not follow its own code, can you?"
msgstr "@niko2 空体。。。𡏦𠬠𠊛𣛠空遵守立程、𠰚？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:132:text
msgid "@rue_sigh People have tried, but it's a recipe for disaster."
msgstr "@rue_sigh 㐌𣎏𠊛試、扔調引𦤾慘禍。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:133:text
msgid "@rue In a way, that's what happened to The World Machine."
msgstr "@rue 蹺𠬠格鬧妬、妬拱𪜀仍之㐌侈𫥨喟𣛠全世。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:134:text
msgid "@niko The... code conflicts thing?"
msgstr "@niko 𧗱。。。衝突碼𧘇吖？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:136:text
msgid "@rue But, while you can't BUILD a robot to not follow its code..."
msgstr "@rue 扔、怞㛪空体自𡏦𠬠𠊛𣛠空遵蹺碼源。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:137:text
msgid "@rue_talk You can establish a special bond with it."
msgstr "@rue_talk 㛪𣎏体造𫥨𠬠䋦關係特別喟伮。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:138:text
msgid "@rue If the strength of that bond is strong enough..."
msgstr "@rue 裊䋦關係妬覩猛。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:139:text
msgid ""
"@rue ...the robot's mental capacity will start to develop outside of its "
"programming."
msgstr "@rue 。。。能力思維𧵑𠊛𣛠妬𠱊扒頭發展𫥨外仍之㐌得立程𠻿。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:140:text
msgid ""
"@rue_smile In a way, it's starting to believe itself as a \"real\", valid "
"individual."
msgstr "@rue_smile 吶格恪、伮扒頭信哴本身𪜀𠬠個人「實」。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:142:text
msgid "@rue It's a complete suspension of disbelief on your end, though."
msgstr "@rue 雖然、於頭邊其、𣱆沛打挶憑念信𧵑𣱆。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:143:text
msgid ""
"@rue_talk You have to fully embrace the robot as a genuine, living person, "
"even knowing they are not..."
msgstr "@rue_talk 㛪沛完全執認𠊛𣛠妬如𠬠𡥵𠊛當實事𤯩、怞別伮空如丕。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:144:text
msgid ""
"@rue You need to spend a lot time with it... treat it like a good friend..."
msgstr "@rue 㛪沛𧶄實𡗉時間喟伮。。。䁛伮如𠬠𠊛伴卒。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:145:text
msgid ""
"@rue Devoting your heart to the robot until it is able to return your "
"feelings."
msgstr "@rue 𢭂全部𬃻心𧵑㛪朱𠊛𣛠朱𦤾欺伮𣎏体答徠情感𧵑㛪。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:146:text
msgid "@rue_smile ...haha... I make it sound so easy, don't I?"
msgstr "@rue_smile 。。。哬哬。。。姉吶𦖑易𠰚？"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:147:text
msgid "@rue But you and \\p know better than anyone that it's not."
msgstr "@rue 扔㛪吧\\p別𤑟欣埃哴伮空如丕。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:148:text
msgid ""
"@rue_sad Right now, the World Machine is probably really, really scared."
msgstr "@rue_sad 現𣇞、𣎏𨤰𣛠全世當窒、窒𢜝駭。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:149:text
msgid "@rue_sad This content update... involved some pretty deep codework."
msgstr "@rue_sad 版及日內容尼。。。𣎏仍𢯢𢷮碼源可𡘯。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:150:text
msgid ""
"@rue_talk My creator was able to access some of the source code, you know..."
msgstr "@rue_talk 㛪別蒂、𠎬創世㐌掙得權追及𠬠𠄧份𧵑碼源。。。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:151:text
msgid "@rue He did what he could and established new connections between maps."
msgstr "@rue 翁㐌𪵯仍之𣎏体吧造𫥨各連結㵋𡧲各區域。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:152:text
msgid "@rue_smile Those links enabled you to meet the other two."
msgstr "@rue_smile 仍連結妬㐌𢴇㛪﨤𠄩𠊛其。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:153:text
msgid ""
"@rue_sad But as it turns out, the new code confused the World Machine to "
"such an extent that it's breaking down altogether."
msgstr "@rue_sad 扔化𫥨、仍段碼㵋㐌𪵯𦇒亂𣛠全世𦤾𣞪伮當𨀎𢭰完全。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:154:text
msgid ""
"@rue Even though the World Machine always had self-destructive tendencies, "
"it usually restrains itself when you are in the world."
msgstr "@rue 雖𣛠全世㫻𣎏意㦖自毀、伮常鉗制得本身欺㛪𣎏𩈘在低。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:155:text
msgid "@rue_sad It doesn't want to take you along with it."
msgstr "@rue_sad 伮空㦖㛪𠅒命伮。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:175:text
msgid "@rue_sad ...All my creator wanted was to write a happy ending."
msgstr "@rue_sad 。。。作者只㦖𢪏𠬠丐結𣎏後催𦓡。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:176:text
msgid ""
"@rue Right now, the only hope of saving you is to take you through that "
"ending."
msgstr "@rue 現𣇞、格唯一𣎏体救㛪𪜀迻㛪過丐結妬。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:177:text
msgid ""
"@rue_sad But now the other two are gone....\\>\\nI don't even know HOW we're "
"gonna get you there."
msgstr "@rue_sad 扔𣇞𠄩𠊛其㐌空哙𡛤耒。。。\\>\\n姉哙空別沛迻㛪𦤾妬矯之。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:191:text
msgid "@rue ...we should go."
msgstr "@rue 。。。衆些𢧚𠫾催。"

#: Maps/POSTGAME RED SKY/Elevator deck/Office/observation deck/Map
#: Events:1:192:text
msgid "@rue_sad Even this place is no longer safe."
msgstr "@rue_sad 𦤾𪥘󠄁坭尼拱空哙安全𡛤耒。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV001:1:1:text
msgid "@niko A painting of 4 robots playing cards."
msgstr "@niko 𠬠幅幀𦘧𦊚𠊛𣛠打牌。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:1:text
msgid "[Hello. Would You Like To Play A Game?]"
msgstr "【吀嘲。伴㦖𨔈之空？】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:3:text
msgid "@niko Sure!"
msgstr "@niko 得渚！"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:4:text
#: friend/EV003:2:1:text friend/EV003:3:1:text
msgid "[What Game Would You Like To Play?]"
msgstr "【伴㦖𨔈之？】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:5:text
msgid "@niko Hmm...."
msgstr "@niko 嘘。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:6:text
msgid "@niko_speak Do you know rock paper scissors?"
msgstr "@niko_speak 伴別𨔈𥺹酋嚏空？"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:7:text
#: friend/EV003:2:3:text
msgid "[Desired Difficulty Level?]"
msgstr "【度𠸋懞㦖？】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:9:text
msgid "[Desired Duration Of Turns?]"
msgstr "【度𨱽𦀎懞㦖？】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:10:text
msgid "@niko_speak Uh..."
msgstr "@niko_speak 唹。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:11:text
msgid "[Please Set Your Timer.]"
msgstr "【𢝙𢚸掑撻銅壺。】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:1:12:text
msgid "@niko_eyeclosed ...Nevermind..."
msgstr "@niko_eyeclosed 。。。偈𠫾。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:2:text
msgid "@niko How about... hide and seek?"
msgstr "@niko 勢時。。。遁尋時哰？"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:4:text
msgid "@niko_speak Well... maybe not too easy?"
msgstr "@niko_speak 時。。。空過易？"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:5:text
msgid "[Initiating. Ruthless Mode.]"
msgstr "【起動。制度狂怒。】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:6:text
msgid "[TARGET: LOCKED.\\| YOU HAVE EXACTLY 14 SECONDS.\\nSTART.\\| RUNNING.]"
msgstr "【目標：㐌銙。\\|伴𣎏董𨑮𦊚𣆰。\\n𧼋。\\|𬆄。\\|𠫾。】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:7:text
#: Maps/Unused/pshot/EV001:1:55:text Maps/Unused/pshot/EV001:1:146:text
#: Maps/Unused/pshot/EV001:1:154:text
msgid "@niko_wtf ..."
msgstr "@niko_wtf 。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:8:text
msgid "@niko_wtf2 ...I'm not sure if I want to play anymore."
msgstr "@niko_wtf2 。。。昃𪜀𨉟儗低。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:9:text
msgid "[OH.\\| Session. Abort.]"
msgstr "【溩。\\|㐌毀。】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:10:text
msgid "[Are You. Feeling Unwell?]"
msgstr "【伴。感𧡊空穩哰？】"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:2:11:text
msgid "@niko No, it's not that..."
msgstr "@niko 空、空沛丕。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV003:3:2:text
msgid "@niko I'll... pass."
msgstr "@niko 𨉟。。。吀𨆢。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:1:text
msgid "My parents are like, literally never home."
msgstr "爸媽𨉟矯、空包𣇞於茹𧘇。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:2:text
msgid "But I don't mind! I'm used to it!"
msgstr "扔拱空哰！𨉟慣耒！"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:3:text
msgid ""
"Besides, I've got model C-WT 2nd gen unit 4E here to keep me company now!"
msgstr "喟徠、𨉟𣎏母C-WT世系𠄩碼號4E抵匏伴喟𨉟耒！"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:4:text
msgid ""
"She still talks a little weird sometimes, but that's okay! She's learning!"
msgstr "伴𧘇𢷮欺吶𡀯唏𢞂唭、扔空哰！伴𧘇當學𦓡！"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:5:text
msgid "If I work real hard, she might even be tamed someday!"
msgstr "裊𨉟固𠡚、𠱊𣎏𣈜伴𧘇得純化催！"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:6:text
msgid "@niko I keep hearing that word..."
msgstr "@niko 𨉟𦖑𧡊詞妬泣坭㫻。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:7:text
msgid "What, tame?"
msgstr "之、純化嘑？"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:9:text
msgid "@niko Nobody's told me what it means yet..."
msgstr "@niko 𣗓𣎏埃解釋朱𨉟妬𪜀之𪥘󠄁。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:1:10:text
msgid "That's just a robot thing!\\n\\... I can't really explain it, either..."
msgstr "時伮只𪜀𠬠次聯關𦤾𠊛𣛠催！\\n。。。𨉟拱空解釋得。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:2:1:text
msgid "What? Don't you like to play \"Run Away From The Killer Robot\"?"
msgstr "之？伴空適𨔈「𧼋𥇻𠺌𠊛𣛠殺人」哰？"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV004:2:3:text
msgid "Well, at least *I* have fun with it."
msgstr "時、𠃣一＊𨉟＊𧡊伮𢝙。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV005:1:2:text
msgid "@niko One of them is a robot instruction manual..."
msgstr "@niko 𠬠𥪝数衆𪜀蠛向引使用𠊛𣛠。。。"

#: Maps/Red sky/Apartments/Hall1/Room3 - bot friend/EV008:1:1:text
msgid "@niko A picture of many 1's and 0's."
msgstr "@niko 𠬠幅影全仍数𠬠吧空。"

#: Maps/Green/Research Station/Power room/robot standing:1:2:text
msgid "[I AM THE GENERATOR MAINTENANCE UNIT.]"
msgstr "【𪝬𪜀單位保持𣛠發電。】"

#: Maps/Green/Research Station/Power room/robot standing:1:3:text
msgid "[EVERYTHING IS FINE HERE.]"
msgstr "【𤗆次調穩。】"

#: Maps/Green/Research Station/Power room/robot standing:1:8:text
#: Maps/Green/Ruins In/Birdhall/Birdhouse/EV016:1:17:text
msgid "@niko_speak Oooh!"
msgstr "@niko_speak 溩溩溩！"

#: Maps/Green/Research Station/Power room/robot standing:1:9:text
msgid ""
"@niko \\p and I actually fixed one of these earlier, in that place across "
"the ocean..."
msgstr "@niko \\p喟𨉟拱𣃣𢯢𠬠𣛠、於𡊲邊其大洋。。。"

#: Maps/Green/Research Station/Power room/robot standing:1:10:text
msgid "[THIS GENERATOR DOES NOT NEED TO BE FIXED RIGHT NOW.]"
msgstr "【𣛠發電尼現空懃𢯢𢵻。】"

#: Maps/Green/Research Station/Power room/robot standing:1:11:text
msgid "@niko Right... You guys already have power and all..."
msgstr "@niko 𫫡。。。各舅拱𣎏電𪥘󠄁耒。。。"

#: Maps/Green/Research Station/Power room/EV004:1:1:text
msgid "@niko A generator."
msgstr "@niko 𠬠𣛠發電。"

#: Maps/Green/Research Station/Power room/EV004:1:2:text
msgid "@niko_speak This one's got a working battery!"
msgstr "@niko_speak 𣛠尼𣎏𠬠𫪐汴哙活動尼！"

#: Maps/FINALE/Post Encounter/EV007:1:1:text
msgid "@ed [\\p... I think it's working.]"
msgstr "@ed 【\\p。。。𪝬擬伮當活動耒。】"

#: Maps/FINALE/Post Encounter/EV007:1:4:text
msgid "@ed [...Niko was right.]"
msgstr "@ed 【尼孤㐌董。】"

#: Maps/FINALE/Post Encounter/EV007:1:5:text
msgid "@ed [I... might actually be tamed, after all.]"
msgstr "@ed 【𢖖󠄁共、𣎏𨤔𪝬。。。㐌得純化。】"

#: Maps/FINALE/Post Encounter/EV007:1:8:text
msgid "@ed [I...]"
msgstr "@ed 【𪝬。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:9:text
msgid "@ed [I remembered what the code was supposed to be...]"
msgstr "@ed 【𪝬𢖵得段碼妬耒。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:10:text
msgid "@ed [Only bits and pieces, but I can remember...]"
msgstr "@ed 【只𪜀仍𤗖𡮈𨖨𫄈、扔𪝬𢖵。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:12:text
msgid "@ed [And... I'm trying to fill in the blanks, too...]"
msgstr "@ed 【吧。。。𪝬拱當填𠓨𡊲𤿰。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:14:text
msgid "@ed [And... I'm restoring the original ending as we speak.]"
msgstr "@ed 【吧。。。𪝬當恢復徠丐結班頭𬆄𣊾𣇞。】"

#: Maps/FINALE/Post Encounter/EV007:1:17:text
msgid ""
"@ed [Niko will be able to reach the tower's summit at the end of the "
"credits.]"
msgstr "@ed 【尼孤𠱊𣎏体𬨠頂座塔𢖖󠄁欺幔形感恩結束。】"

#: Maps/FINALE/Post Encounter/EV007:1:18:text
msgid "@ed [After replacing the sun, Niko will go back to where it all began.]"
msgstr "@ed 【𢖖󠄁欺㨋徠𩈘𡗶、尼固𠱊𠭤徠坭𤗆次扒頭。】"

#: Maps/FINALE/Post Encounter/EV007:1:19:text
msgid "@ed [And then... Niko will be able to go home from there.]"
msgstr "@ed 【吧耒。。。尼孤𠱊𣎏体𧗱茹自妬。】"

#: Maps/FINALE/Post Encounter/EV007:1:21:text
msgid "@ed [But...]"
msgstr "@ed 【扔。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:22:text
msgid "@ed [...this is permanent.]"
msgstr "@ed 【。。。𠱊𪜀永遠。】"

#: Maps/FINALE/Post Encounter/EV007:1:24:text
msgid "@ed [After Niko wakes up back home...]"
msgstr "@ed 【𢖖󠄁欺尼孤醒𧻭於茹。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:25:text
msgid "@ed [...This world would only exist as a memory.]"
msgstr "@ed 【。。。世界尼𠱊只哙𪜀𠬠記憶。】"

#: Maps/FINALE/Post Encounter/EV007:1:26:text
msgid "@ed [For Niko, a dream.]"
msgstr "@ed 【對喟尼孤、𠬠𥋏𢠩。】"

#: Maps/FINALE/Post Encounter/EV007:1:27:text
msgid "@ed [Like thousands of other dreams.]"
msgstr "@ed 【如𠦳萬𥋏𢠩恪。】"

#: Maps/FINALE/Post Encounter/EV007:1:28:text
msgid "@ed [For you, a story.]"
msgstr "@ed 【對喟伴、𠬠句𡀯。】"

#: Maps/FINALE/Post Encounter/EV007:1:29:text
msgid "@ed [Like thousands of other stories.]"
msgstr "@ed 【如𠦳萬句𡀯恪。】"

#: Maps/FINALE/Post Encounter/EV007:1:32:text
msgid "@ed [But... as long as Niko remembers this place...]"
msgstr "@ed 【扔。。。澄鬧尼孤哙𢖵𧗱坭尼。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:33:text
msgid "@ed [As long as you remember this place.]"
msgstr "@ed 【澄鬧伴哙𢖵𧗱坭尼。】"

#: Maps/FINALE/Post Encounter/EV007:1:34:text
msgid "@ed [It'll... be alright.]"
msgstr "@ed 【𤗆次。。。𠱊穩催。】"

#: Maps/FINALE/Post Encounter/EV007:1:37:text
msgid "@ed [I... was able to restore some other elements too.]"
msgstr "@ed 【𪝬。。。拱㐌成功恢復徠𠬠数要素恪。】"

#: Maps/FINALE/Post Encounter/EV007:1:38:text
msgid "@ed [The characters...The people that were lost on Niko's journey.]"
msgstr "@ed 【仍人物。。。仍𡥵𠊛㐌空過𠺌𨑗行程𧵑尼孤。】"

#: Maps/FINALE/Post Encounter/EV007:1:40:text
msgid "@ed [They're all in the next room.]"
msgstr "@ed 【𣱆調於𥪝間房接蹺。】"

#: Maps/FINALE/Post Encounter/EV007:1:42:text
msgid "@ed [I would've put them back where they belong, but...]"
msgstr "@ed 【當𫥨𪝬𠱊㨋𣱆徠𧗱坭𫇰、扔。。。】"

#: Maps/FINALE/Post Encounter/EV007:1:44:text
msgid "@ed [Not yet.]"
msgstr "@ed 【空懃𫏚。】"

#: Maps/FINALE/Post Encounter/EV007:1:45:text
msgid "@ed [...I think Niko should see them again, first.]"
msgstr "@ed 【。。。𪝬擬尼孤𢧚﨤徠𣱆𠓀。】"

#: Maps/FINALE/Post Encounter/EV007:1:48:text
msgid "@ed [...Please say goodbye to Niko for me.]"
msgstr "@ed 【。。。吀唉寄𠳒嘲暫別尼孤𢴇𪝬。】"

#: Maps/FINALE/Summit/map event:1:1:text Maps/Tower/Summit/map
msgid "@niko The world below looks so small..."
msgstr "@niko 世界邊𨑜矓𡮈子實。。。"

#: Maps/FINALE/Summit/map event:2:1:text
msgid "@niko_eyeclosed No turning back now."
msgstr "@niko_eyeclosed 空哙塘𨆢耒。"

#: Maps/FINALE/Summit/map event:3:2:text
msgid "@niko2 This is where the sun belongs."
msgstr "@niko2 低𪜀坭撻𩈘𡗶。"

#: Maps/FINALE/Summit/map event:3:4:text
msgid "@niko_eyeclosed Here goes nothing, \\p."
msgstr "@niko_eyeclosed 得咹𪥘󠄁、 我𧗱空鬧\\p。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:6:text
msgid ""
"@niko_speak Ah... \\>\\@niko do you want me to crush the pipe in here, \\p?"
msgstr "@niko_speak 啊。。。 \\>\\@niko 舅㦖𨉟𡏽丐䈵𥪝尼哰、\\p？"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:7:text
msgid "@niko_huh Ohh, but I don't wanna get too close..."
msgstr "@niko_huh 溩、扔𨉟空㦖徠過近兜。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:13:text
msgid "@niko_eyeclosed That was scary..."
msgstr "@niko_eyeclosed 𢜝實蒂。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:21:text
msgid "@niko_wtf ....\\p !"
msgstr "@niko_wtf 。。。\\p！"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:22:text
msgid "@niko_eyeclosed I am NOT going to put the sun here."
msgstr "@niko_eyeclosed 𨉟—空—撻𩈘𡗶𠓨蒂兜。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:28:text
msgid "@niko Why...\\.\\. would you want to smash a bottle here, \\p?"
msgstr "@niko 在哰。。。\\.\\.舅徠㦖𡏽𠬠丐𥑂水晶𥪝尼渚、\\p？"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:29:text
msgid "@niko_speak The shards would get everywhere!"
msgstr "@niko_speak 𤗖𥒮𢏑縱𤂭𠅒！"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:34:text
msgid "@niko_eyeclosed I hope we don't have to use this again, \\p..."
msgstr "@niko_eyeclosed 懞𨉟空沛用伮𡛤、\\p。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:37:text
msgid "@niko_speak Oh! This machine is still running!"
msgstr "@niko_speak 溩！𣛠尼吻當𧼋！"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:38:text
msgid "@niko Maybe I shouldn't stand so close to it..."
msgstr "@niko 昃𪜀𨉟空𢧚𨅸過近伮。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:39:text
msgid ""
"@niko_wtf Wh...what if my scarf got caught in there? And then it'll pull me "
"in, and...."
msgstr "@niko_wtf 𢙲。。。𢙲如巾𫏈𧵑𨉟被唿𠓨妬時哰？耒伮捁𨉟𠓨、耒。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/ :1:40:text
msgid "@niko_huh ...not gonna finish that sentence."
msgstr "@niko_huh 。。。催𨉟空吶歇句兜。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/EV012:1:1:text
#: upstairs/head:1:1:text
msgid "@niko_huh ...just a head. Yikes."
msgstr "@niko_huh 。。。𠬠丐頭空。喂。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/EV014:1:1:text
#: upstairs/EV018:1:1:text upstairs/EV019:1:1:text upstairs/EV024:1:1:text
#: upstairs/EV026:1:1:text upstairs/EV035:1:1:text
msgid "@niko_eyeclosed What's left of a robot's arm."
msgstr "@niko_eyeclosed 仍之哙𨔊徠𧵑𠬠𦑃𢬣𠊛𣛠。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/robot damaged:1:1:text
#: upstairs/EV025:1:1:text upstairs/EV028:1:1:text
msgid "@niko Piece of a robot. It's badly damaged..."
msgstr "@niko 各𤗖砵𧵑𠬠𠊛𣛠。衆㐌被墟害𥘀𪿗。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/EV029:1:1:text
#: upstairs/EV033:1:1:text upstairs/EV034:1:1:text
msgid "@niko_huh Just a head..."
msgstr "@niko_huh 𠬠丐頭空。。。"

#: Maps/Blue/Outpost/factory interior/factory upstairs/EV030:1:1:text
#: upstairs/EV031:1:1:text upstairs/EV032:1:1:text
msgid "@niko_eyeclosed I'm not even sure what this is supposed to be..."
msgstr "@niko_eyeclosed 𨉟哙空別丐尼𪜀份之。。。"

#: Maps/Green/Ruins In/Birdhall/blocks npc:1:4:text
msgid "@alula_speak Haha!"
msgstr "@alula_speak 哬哬！"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:22:text
msgid "@niko Oh, shoot!"
msgstr "@niko 喂、𣩂！"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:23:text
msgid "@niko_eyeclosed Looks like we can't get past that block..."
msgstr "@niko_eyeclosed 𣎏𨤔些空𠫾過丐𫪐妬得耒。。。"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:24:text
msgid "@alula_pout ..."
msgstr "@alula_pout 。。。"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:25:text
msgid "@alula_speak Seriously?"
msgstr "@alula_speak 實㫻？"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:120:text
msgid "@alula I'll be up ahead!"
msgstr "@alula 𨉟䟻𠌨𠓀唲！"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:122:text
msgid "@niko_eyeclosed ...I have literally never thought of that."
msgstr "@niko_eyeclosed 。。。哰𨉟𣗓擬如勢包𣇞𠰚。"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:123:text
msgid ""
"@calamus_heh You kinda get used to all the debris after living here for a "
"while."
msgstr "@calamus_heh 𤯩於低𨁥唻時舅𠱊慣喟仍𤗖砵伆𨗺𨒺催。"

#: Maps/Green/Ruins In/Birdhall/alula npc:1:124:text
msgid "@calamus_smile Come on, our house isn't far from here."
msgstr "@calamus_smile 𠫾鬧、茹衆𨉟可近低催。"

#: Maps/Green/Ruins In/Birdhall/calamus door:2:5:text
msgid ""
"@calamus Oh, Niko, did you come by for a visit?\\>\\n\\@calamus_smile Our "
"house is up here, please follow me."
msgstr ""
"@calamus 溩、尼孤、舅𬧐探妬哰？\\>\\n\\@calamus_smile 茹衆𨉟於𠌨𨑗尼、蹺蹎𨉟"
"唲。"

#: Maps/Green/Ruins Out/Prophet house/EV005:1:1:text
msgid "@niko It's a staff."
msgstr "@niko 𠬠𣘃杖。"

#: Maps/Green/Ruins Out/Prophet house/EV005:1:2:text
msgid ""
"@niko_speak Reminds me of the one that robot from the Barrens was holding!"
msgstr "@niko_speak 偅如𣘃𦓡𠊛𣛠妬於塳邊疆擒𧘇！"

#: Maps/Green/Ruins Out/Prophet house/EV006:1:1:text
msgid "@niko_speak It's an orb! \\>\\@niko The material looks like amber."
msgstr "@niko_speak 𠬠菓球！\\>\\@niko 物料𣎏𨤔𪜀琥珀。"

#: Maps/Green/Ruins Out/Prophet house/EV007:1:1:text
msgid "@niko Some kind of cloak or shawl, folded neatly."
msgstr "@niko 𠬠類襖撞或巾𠆳、岋𬆄𠦯。"

#: Maps/Green/Ruins Out/Prophet house/EV008:1:1:text
msgid "@niko A pair of shoes and some jewelry."
msgstr "@niko 𠬠對𩌂吧𠃣裝飾。"

#: Maps/Red sky/City gate/tutorial/intro:1:20:text
msgid "@niko \\p? Are you there?"
msgstr "@niko \\p？舅𣎏妬空？"

#: Maps/Red sky/City gate/tutorial/intro:1:21:choice:2
msgid "That's not my name"
msgstr "妬空沛𠸜𨉟。"

#: Maps/Red sky/City gate/tutorial/intro:1:24:text
msgid "@niko_speak Ah, me too!"
msgstr "@niko_speak 啊、𨉟拱丕！"

#: Maps/Red sky/City gate/tutorial/intro:1:25:text
msgid "@niko ...I mean... I'm awake now."
msgstr "@niko 。。。𧘇𪜀。。。𨉟𧻭耒。"

#: Maps/Red sky/City gate/tutorial/intro:1:28:text
msgid "@niko_eyeclosed \\p... I know you're here..."
msgstr "@niko_eyeclosed \\p。。。𨉟別舅當於低𦓡。。。"

#: Maps/Red sky/City gate/tutorial/intro:1:31:text
msgid "@niko_speak ...Oh."
msgstr "@niko_speak 。。。溩。"

#: Maps/Red sky/City gate/tutorial/intro:1:32:text
msgid "@niko_eyeclosed I'm sorry, I'm a little confused... I just woke up..."
msgstr "@niko_eyeclosed 吀纇、𨉟唏蕩智𠬠𡭧。。。𨉟𣃣醒𧻭。。。"

#: Maps/Red sky/City gate/tutorial/intro:1:33:text
msgid "@niko Can you tell me your name again?"
msgstr "@niko 舅𣎏体朱𨉟別𠸜舅得空？"

#: Maps/Red sky/City gate/tutorial/intro:1:38:text
msgid "@niko_eyeclosed I had another bad dream."
msgstr "@niko_eyeclosed 𨉟徠﨤惡夢。"

#: Maps/Red sky/City gate/tutorial/intro:1:39:text
msgid "@niko I know I have nothing to worry about with you here, but..."
msgstr "@niko 𨉟別空𣎏之沛𢥈𢠯喟舅於低、扔𦓡。。。"

#: Maps/Red sky/City gate/tutorial/intro:1:40:text
msgid "@niko_eyeclosed Can I really save everyone with this lightbulb?"
msgstr "@niko_eyeclosed 𨉟𣎏實事救得𤗆𠊛憑琫畑尼空？"

#: Maps/Red sky/City gate/tutorial/intro:1:42:text
msgid "@niko ...Let's get going now."
msgstr "@niko 。。。些𠫾催。"

#: Maps/Red sky/City gate/tutorial/Map Events:1:19:text
msgid "@niko These vines look tough, but I think I can manage to cut them!"
msgstr "@niko 𡌽絏蹽尼𣎏𨤔勁、扔𨉟擬𣎏体割衆得！"

#: Maps/Red sky/City gate/tutorial/Map Events:1:30:text
msgid "@niko_speak That did it!"
msgstr "@niko_speak 得耒！"

#: Maps/Red sky/City gate/tutorial/Map Events:1:31:text
msgid "@niko Ready to go, \\p?"
msgstr "@niko 𠻿𠳹𠫾𣗓、\\p？"

#: Maps/Red sky/City gate/tutorial/Map Events:1:36:text
msgid "@niko The clipper handles won't budge..."
msgstr "@niko 𢬣擒𨦀空𨃽蹢𡭧鬧。。。"

#: Maps/Red sky/City gate/tutorial/Map Events:1:37:text
msgid "@niko ...It's not broken, is it?"
msgstr "@niko 。。。𨦀空閧𦓡、董空？"

#: Maps/Red sky/City gate/tutorial/Map Events:1:40:text
msgid "@niko There are some really tangled-up vines in the way."
msgstr "@niko 滕尼𣎏窒𡗉仍絏蹽𦇒𠓨僥。"

#: Maps/Red sky/City gate/tutorial/Map Events:2:1:text
msgid "@niko It looks like an oil can..."
msgstr "@niko 𣎏𨤔𪜀𠬠錀油。。。"

#: Maps/Red sky/City gate/tutorial/Map Events:2:2:text
msgid "@niko This might be useful. I'll take it with me."
msgstr "@niko 𣎏体伮𠱊𣎏益。𨉟𠱊𫼳伮蹺𠊛。"

#: Maps/Red sky/City gate/tutorial/Map Events:2:11:text
msgid ""
"@niko I think I might be carrying something else I can use this with already."
msgstr "@niko 形如𨉟㐌𫼳𠻿𠬠𦁺𣎏体用喟伮耒。"

#: Maps/Red sky/City gate/tutorial/Map Events:2:12:text
msgid "@niko Maybe I should check my pockets again?"
msgstr "@niko 𣎏𨤰𨉟𢧚檢查徠𥪝襊𣘊？"

#: Maps/Red sky/City gate/tutorial/Map Events:3:1:text
msgid "@niko I don't think we need to go that way..."
msgstr "@niko 𨉟空擬懃沛𠫾𧗱向妬兜。。。"

#: Maps/Red sky/Office/stairwell/locked room/map events:3:3:text
msgid "@ed [\\p, I don't know who put this bed here...]"
msgstr "@ed 【\\p、𪝬空別埃㐌撻隻床尼於低。。。】"

#: Maps/Red sky/Office/stairwell/locked room/map events:3:5:text
msgid ""
"@ed [But this bed will bring you back to the beginning of your journey.]"
msgstr "@ed 【扔伮𠱊迻伴𠭤徠点扒頭𧵑行程。】"

#: Maps/Red sky/Office/stairwell/locked room/map events:3:7:text
msgid "@ed [Keep this in mind before you decide to let Niko sleep here.]"
msgstr "@ed 【吀唉留意𠓀欺抵尼孤𥄬於低。】"

#: Maps/Blue/Old factory/Factory interior2/gloves :bottom:1:1:text
msgid "@niko It's a pair of rubber gloves.\\nThey're a bit heavy."
msgstr "@niko 𠬠對矜𢬣膏蒭。\\n衆唏𥘀𠬠𡭧。"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:2:text
msgid "@niko_speak You...want me to smash the boards with the pipe?"
msgstr "@niko_speak 舅。。。㦖𨉟㧺𢭮埬板妬憑丐䈵哰？"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:3:text
msgid "@niko I can't do that! We'll have to pry them off!"
msgstr "@niko 𨉟空𪵯勢得！𨉟沛𢭄衆𫥨催！"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:4:text
msgid "@niko_eyeclosed But I don't think I can do that with a pipe..."
msgstr "@niko_eyeclosed 扔喟䈵圇時𨉟擬𪜀空𪵯勢得。。。"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:8:text
msgid "@niko_speak Good thing I kept this crowbar!"
msgstr "@niko_speak 𢆪𦓡𨉟吻𡨺丐錆𡎡𩿙！"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:21:text
msgid "@niko_eyeclosed What a workout..."
msgstr "@niko_eyeclosed 損飭實妬。。。"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:24:text
msgid "@niko The door is all boarded up..."
msgstr "@niko 𫔤被㨂板𡫨徠耒。。。"

#: Maps/Blue/Old factory/Factory interior2/Map Events:1:25:text
msgid ""
"@niko_speak The boards seem loose, though! I should be able to pull them off "
"with the right tool..."
msgstr "@niko_speak 扔仍𬌓板矓𣎏𨤔𣿅𣱾妬！裊𣎏董用具時𣎏欺𨉟𢭄衆𫥨得。。。"

#: Maps/Blue/Old factory/Factory interior2/EV017:2:2:text
msgid ""
"[THE ROBOT ASSEMBLY AND REPAIR SERVICES HAVE BEEN DISCONTINUED AT THE "
"BARRENS.]"
msgstr "【役務擸撘吧𢯢𢵻𠊛𣛠㐌仃活動在塳邊疆。】"

#: Maps/Blue/Old factory/Factory interior2/EV017:2:3:text
msgid "[IF YOU HAVE FURTHER INQUIRY, PLEASE CONTACT THE HEAD ENGINEER.]"
msgstr "【裊𣎏忑縸、𢝙𢚸聯係技師長。】"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:1:text
#: interior2/upstairs/EV004:1:1:text
msgid "@niko This seems to be a page ripped out of a book."
msgstr "@niko 𣎏𨤔𪜀𠬠張扯𫥨自𠬠卷冊。"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:2:text
msgid ""
"$-cannot overstate the importance of cleaning solvents in this environment."
msgstr "$－空体扨猛欣尋關重𧵑各溶液撈𢹉𥪝媒場尼。"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:3:text
msgid ""
"$Here is a simple recipe using the alternative method discussed in the last "
"chapter, utilizing the natural properties of blue phosphor."
msgstr "$低𪜀𠬠公式單簡憑方法次𠄩㐌得𪲍𥪝章𠓀、運用特性自然𧵑光素青。"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:5:text
msgid "$Reagents:"
msgstr "$作因："

#: Maps/Blue/Old factory/Factory interior2/EV018:1:6:text
msgid "$-Acidic gas"
msgstr "$－氣阿掇"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:7:text
msgid "$-Blue phosphor (rare form)"
msgstr "$－光素青（樣險）"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:9:text
msgid "$Instructions:"
msgstr "$向引："

#: Maps/Blue/Old factory/Factory interior2/EV018:1:10:text
msgid ""
"$1) In a well-ventilated area, direct the gas into your container of choice."
msgstr "$一・𥪝區域洸氣、納氣𠓨物貯隨意。"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:11:text
msgid "$Seal immediately."
msgstr "$粘封𬆄立即。"

#: Maps/Blue/Old factory/Factory interior2/EV018:1:12:text
msgid "@niko That's the end of the page..."
msgstr "@niko 歇張。。。"

#: Maps/Blue/Old factory/Factory interior2/EV019:2:2:text
msgid "[WELCOME TO THE OLD CHEMICAL PROCESSING PLANT.]"
msgstr "【嘲𢜏𦤾基礎處理化質𫇰。】"

#: Maps/Blue/Old factory/Factory interior2/EV019:2:3:text
msgid "[MOST OF THE EQUIPMENT HAS ALREADY BEEN RELOCATED.]"
msgstr "【份𡘯零件㐌得移移自𠓀。】"

#: Maps/POSTGAME green/Research Station/EV002:1:1:text
msgid "@niko Do you know where I could find a battery for a flying machine?"
msgstr "@niko 舅別𨉟𣎏体尋𠬠𫪐汴朱飛行機於兜空？"

#: Maps/POSTGAME green/Research Station/EV002:1:2:text
msgid "[I HAVE A BATTERY INTEGRATED INTO MY SYSTEM.]"
msgstr "【𪝬𣎏𠬠𫪐汴𠫾連喟系統。】"

#: Maps/POSTGAME green/Research Station/EV002:1:3:text
msgid "[IT CANNOT BE USED TO POWER OTHER THINGS.]"
msgstr "【空体用伮朱各目的恪。】"

#: Maps/POSTGAME green/Research Station/EV003:1:2:text
msgid "[STAY SAFE.]"
msgstr "【保重唲。】"

#: Maps/POSTGAME green/Research Station/EV003:1:7:text
msgid ""
"[THE RESEARCH STATION IS CURRENTLY EXPERIENCING SOME TECHNICAL DIFFICULTIES.]"
msgstr "【站研究現當﨤𠬠数事故技術。】"

#: Maps/POSTGAME green/Research Station/EV003:1:8:text
msgid "@niko2 I can tell..."
msgstr "@niko2 𨉟別。。。"

#: Maps/POSTGAME green/Research Station/EV003:1:9:text
msgid "@niko_eyeclosed Even the bridge on the way here was..."
msgstr "@niko_eyeclosed 𪥘󠄁𣘃橋𨑗塘𦤾低拱。。。"

#: Maps/POSTGAME green/Research Station/EV003:1:13:text
msgid ""
"@niko By the way, do you know where I could find a battery for a flying "
"machine?"
msgstr "@niko 因便、舅𣎏別尋汴朱飛行機於兜空？"

#: Maps/POSTGAME green/Research Station/EV003:1:14:text
msgid "[I DO NOT.]"
msgstr "【𪝬空。】"

#: Maps/POSTGAME green/Research Station/EV007:1:1:text
msgid "[ANOMALIES ARE INCREASING...]"
msgstr "【各異点當出現。。。】"

#: Maps/POSTGAME green/Research Station/EV009:1:1:text
msgid ""
"@niko_speak Do you know where I could find a battery for a flying machine?"
msgstr "@niko_speak 舅𣎏別尋汴朱飛行機於兜空？"

#: Maps/POSTGAME green/Research Station/EV009:1:2:text
msgid "[HAVE YOU CHECKED THE POWER ROOM?]"
msgstr "【伴㐌檢查房發電𣗓？】"

#: Maps/POSTGAME green/Research Station/EV010:1:2:text
msgid "[WHAT IS A FLYING MACHINE.]"
msgstr "【飛行機𪜀之丕。】"

#: Maps/POSTGAME green/Research Station/EV011:1:1:text
msgid "[SOME VINES JUST GREW AROUND THIS BRIDGE.]"
msgstr "【絏繚𣃣𠚐𨒺橋。】"

#: Maps/POSTGAME green/Research Station/EV011:1:2:text
msgid "[ALMOST AS IF IT WAS AN INTENTIONAL REPAIR EFFORT.]"
msgstr "【如矯𠬠努力𢯢𢵻固意丕。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:4:text room/backroom/proto:5:40:text
msgid "@proto1 [...]"
msgstr "【。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:10:text
msgid "@proto1 [I...]\\>\\n[...recognize the light in your eyes...]"
msgstr "@proto1 【英。。。】\\>\\n【。。。認𫥨次暎𤏬𥪝對眜㛪。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:12:text
msgid "@proto1 [You are the person I am destined to meet.]"
msgstr "@proto1 【㛪𪜀𠊛英得數分𢯛攝朱﨤。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:15:text
msgid "@proto1b [....Niko?]"
msgstr "@proto1b 【。。。尼孤？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:16:text
msgid "@niko3 Y...\\.\\.yes?"
msgstr "@niko3 㖡。。。\\.\\.？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:19:text
msgid "@proto1b [....What is your name?]"
msgstr "@proto1b 【。。。。𠸜㛪𪜀之？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:20:text
msgid "@niko2 I'm Niko..."
msgstr "@niko2 㛪𪜀尼孤吖。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:24:text
msgid "@proto2 [Do you know who sent you?]"
msgstr "@proto2 【㛪𣎏別埃寄㛪空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:25:text
msgid "@niko2 Oh....\\>\\n...um..."
msgstr "@niko2 溩。。。。\\>\\n。。。𫫡。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:26:text
msgid "@niko3 .....n...o?"
msgstr "@niko3 。。。。。空。。。吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:28:text
msgid "@niko ...wait, do you mean who sent me to this world?"
msgstr "@niko 。。。寬、意英𪜀埃寄㛪𦤾低𧘇吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:29:text
msgid ""
"@niko_speak There was a robot a while back who told me about how I'm the "
"messiah and stuff..."
msgstr "@niko_speak 𣎏𠬠𠊛𣛠於外其吶𧗱𡀯㛪𪜀𠎬救世吧尼呶其。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:30:text
msgid "@niko_speak So... I'm guessing \\p sent me!"
msgstr "@niko_speak 𢧚𪜀。。。㛪斷\\p寄㛪！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:31:text
msgid "@niko With them being god and all."
msgstr "@niko 時𪜀𠎬全能吧各矯体類𦓡。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:33:text
msgid ""
"@niko_speak The robot looks a little bit like you, even! \\>\\n\\@niko Maybe "
"you... know each other?"
msgstr "@niko_speak 𦓡𠊛𣛠妬拱矓唏偅英幾！\\>\\n\\@niko 𣎏欺。。。𠄩𠊛慣僥吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:34:text
msgid "@proto1 [I cannot say.]"
msgstr "@proto1 【英空別。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:36:text
msgid "@proto1 [A lot of my memories have been removed for safety reasons.]"
msgstr "@proto1 【份𡘯記憶𧵑英㐌被扠𠬃爲理由安全。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:37:text
msgid "@niko_wtf Your memories were removed?!"
msgstr "@niko_wtf 英被扠智𢖵哰？！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:38:text
msgid "@niko3 That's terrible!!"
msgstr "@niko3 驚恐實！！！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:39:text
msgid ""
"@niko Wait... \\>\\n\\@niko_eyeclosed I'm... guessing that's less of a big "
"deal for a robot..."
msgstr ""
"@niko 𦓡。。。\\>\\n\\@niko_eyeclosed 㛪。。。斷𪜀喟𠊛𣛠時伮𠃣關重欣。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:41:text
msgid "@proto2b [I am going to assume you do not know who sent you.]"
msgstr "@proto2b 【英𠱊假定𪜀㛪空別埃寄㛪。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:42:text
msgid ""
"@proto1b [How did you get here, then?] \\>\\n\\@proto2 [How did you reach "
"this room?]"
msgstr "@proto1b 【丕、㛪𦤾低憑格鬧丕？】 \\>\\n\\@proto2 【㛪𬧐房尼憑格鬧？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:43:text
msgid "@niko_speak Oh! \\>\\nWe got here in a minecart!"
msgstr "@niko_speak 溩！\\>\\n衆㛪𬧐低憑車𡎡吖！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:44:text
msgid ""
"@proto1 [But the minecart wasn't there when you entered the mines, was it?]"
msgstr "@proto1 【扔車𡎡空存在欺㛪𠓨𡌢𡎡吝頭、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:45:text
msgid "@niko_eyeclosed Oh yeah..."
msgstr "@niko_eyeclosed 啊唹。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:46:text
msgid "@proto1b [So... how did you find it?]"
msgstr "@proto1b 【丕時。。。㛪尋𧡊伮矯之丕？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:47:text
msgid "@niko_eyeclosed I didn't really find it..."
msgstr "@niko_eyeclosed 㛪空寔事尋伮。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:48:text
msgid ""
"@niko_speak The robot lady thinks it was just the minecart coming to us, "
"but..."
msgstr "@niko_speak 姉𠊛𣛠擬𪜀由車𡎡自𠫾𧗱𠌨衆㛪、扔𦓡。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:49:text
msgid "@niko I remember looking at the journal when it happened."
msgstr "@niko 㛪𢖵𪜀欺妬㛪當𥆾𠓨捲日記。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:50:text
msgid "@niko_speak And when I looked up again, the cart was just...\\. there!"
msgstr "@niko_speak 吧欺㛪𥆾𬨠、時丐䀡𡎡自𤼸。。。\\.出現催吖！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:51:text
msgid "@niko Poof. Just like that."
msgstr "@niko 𡀫。如丕啞。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:52:text
msgid "@proto1b [Interesting.\\> Please show me this journal.]"
msgstr "@proto1b 【窒趣味。\\>𢝙𢚸朱英㛪卷日記。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:66:text
msgid "@proto1 [...\\>\\nThen it has already begun.]"
msgstr "@proto1 【。。。\\>\\n丕𪜀伮㐌扒頭。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:73:text
msgid "@proto1 [Here.]"
msgstr "@proto1 【低。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:77:text
msgid "@niko2 What... IS that?"
msgstr "@niko2 丐。。。之丕吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:78:text
msgid "@proto1 [I am entrusting you with my main memory disk.]"
msgstr "@proto1 【英撻念信𠓨㛪憑隖𥐨正尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:79:text
msgid "@proto2 [You have passed the first test by showing me the book.]"
msgstr "@proto2 【㛪㐌越過排檢查頭先憑格朱英𧡊卷冊妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:80:text
msgid "@proto2 [Now, you will need to find a way to install the backup.]"
msgstr "@proto2 【𣊾𣇞、㛪𠱊懃尋格掑撻版抄留。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:81:text
msgid "@niko2 Install the..."
msgstr "@niko2 掑撻丐。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:82:text
msgid "@proto1 [Before you do that, though...]"
msgstr "@proto1 【扔𠓀歇。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:83:text
msgid "@proto1b [...Someone else is with you, right?]"
msgstr "@proto1b 【。。。𣎏𠬠𠊛恪𠫾共㛪、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:84:text
msgid "@proto1c [Someone aside from \\p.]\\>\\n[A resident of this world.]"
msgstr "@proto1c 【𠬠𠊛空沛\\p。】\\>\\n【𠬠居民𧵑世界尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:85:text
msgid "@niko_speak Yeah! \\.\\.\\@niko The robot lady with the red hair."
msgstr "@niko_speak 𠳐吖！.\\.\\@niko 姉𠊛𣛠𩯀𧹻。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:86:text
msgid "@niko She's in the computer room right now."
msgstr "@niko 姉當於𥪝房𣛠併。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:87:text
msgid "@proto1b [Then... please do not tell her you found me.]"
msgstr "@proto1b 【丕時。。。揨𠸒姉𧘇𪜀㛪㐌尋𧡊英。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:88:text
msgid "@proto2b [At least, not yet.]"
msgstr "@proto2b 【𠃣一𪜀、空沛𣊾𣇞。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:89:text
msgid "@proto2b [I can't be seen like this.]"
msgstr "@proto2b 【空体𧡊英𥪝狀態尼得。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:90:text
msgid "@niko2 Um... okay..."
msgstr "@niko2 𫫡。。。得吖。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:2:91:text
msgid ""
"@proto2 [Please help me restore my memory.]\\>\\n[Bring the disk back once "
"you have the backup.]"
msgstr "@proto2 【唉𢴇英恢復徠記憶。】>\\n【唉㨋徠隖𥐨𠬠欺㛪𣎏版抄留。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:2:text room/backroom/proto:3:342:text
msgid "@niko Does this work?"
msgstr "@niko 勢尼得空吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:3:text room/backroom/proto:3:343:text
msgid "@proto1b [Let's see...]"
msgstr "@proto1b 【䀡鬧。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:6:text room/backroom/proto:3:346:text
msgid "@proto_disk [Inserting Disk...]\\>\\n\\@proto_eyeclosed [Rebooting...]"
msgstr "@proto_disk 【當入𥐨。。。】\\>\\n\\@proto_eyeclosed 【起動徠。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:20:text
msgid "@proto_gasp2 [...]\\>\\n[Ah.]"
msgstr "@proto_gasp2 【。。。】\\>\\n【啊。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:22:text
msgid "@niko2 Are you okay?"
msgstr "@niko2 英穩空吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:23:text
msgid "@proto2 [...Sure.]"
msgstr "@proto2 【。。。必然。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:24:text
msgid "@niko2 So... I guess it worked?"
msgstr "@niko2 勢𪜀。。。㛪斷伮活動耒吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:25:text
msgid "@proto1c [Yes.]"
msgstr "@proto1c 【董丕。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:26:text
msgid "@proto2b [I believe a proper introduction is in order.]"
msgstr "@proto2b 【英擬𣊾𣇞懃沛介紹本身仔細。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:27:text
msgid "@proto1 [I am the Prototype, originally named Prophetbot.]"
msgstr "@proto1 【英𪜀一號、𠊛𣛠先知𠁀頭。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:28:text
msgid "@proto2 [I was built to greet the savior of the old world.]"
msgstr "@proto2 【英得𡏦抵嘲迍𠎬救世𧵑世界𫇰。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:29:text
msgid ""
"@niko ...wait. \\>\\n\\@niko_speak A prophet robot...\\. \\.like that one I "
"met?"
msgstr "@niko 。。。寬。\\>\\n\\@niko_speak 𠬠𠊛𣛠先知。。。\\.\\.如㛪𣃣﨤吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:30:text
msgid "@niko_eyeclosed ...Hey! I was right about you guys looking alike."
msgstr "@niko_eyeclosed 。。。尼！勢𪜀㛪斷董務𠄩𠊛矓偅僥耒。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:32:text
msgid ""
"@proto1c [Well, the Prophetbot out there now is a gross simplification of my "
"design.]"
msgstr "@proto1c 【時、𠊛𣛠先知外其𪜀㐌得簡化當𠸥𬧺喟設計𧵑英。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:33:text
msgid ""
"@proto2 [That is to say, he is much more primitive by comparison.] \\.\\."
"\\n[Embarassingly so.]"
msgstr "@proto2 【即𪜀、𪝳粗疏欣窒𡗉𬧺喟英。】\\.\\.\\n【𦤾𣞪當醜𢜜。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:34:text
msgid "@niko_eyeclosed Hey, he seemed alright to me..."
msgstr "@niko_eyeclosed 尼、㛪𧡊愥𣎏哰兜。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:36:text
msgid "@proto2b [You don't understand.]"
msgstr "@proto2b 【丕𪜀㛪空曉耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:37:text
msgid ""
"@proto2 [Not only is he not tamed... \\>\\@proto2b he was tailor-made for "
"this much smaller, simpler world to begin with.]"
msgstr ""
"@proto2 【𪝳空只𣗓得純化。。。\\>\\@proto2b 𦓡哙得𡏦𥩯抵服務世界𡮈欣、單簡欣"
"窒𡗉尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:39:text
msgid "@proto2b [I was not.]"
msgstr "@proto2b 【英時空。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:40:text
msgid "@proto1b [I was built before the real world ended.]"
msgstr "@proto1b 【英得𡏦𠓀欺世界寔衰亡。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:41:text
msgid "@niko The...\\.\\.\\@niko2 ...real world?"
msgstr "@niko 世界。。。\\.\\.\\@niko2 。。。實吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:42:text
msgid "@proto_gasp2 [...Oh, right.]"
msgstr "@proto_gasp2 【。。。啊、唹。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:43:text
msgid "@proto2b [...You don't know.]"
msgstr "@proto2b 【。。。㛪空別。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:45:text
msgid "@proto1b [Niko...]\\.\\.\\n[Do you... \\.\\.remember the ending?]"
msgstr "@proto1b 【尼孤。。。】.\\.\\n【㛪𣎏。。。\\.\\.𢖵丐結空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:46:text
msgid "@niko3 ...excuse me?"
msgstr "@niko3 。。。㖡？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:47:text
msgid ""
"@proto1 [The fact that you've found me at all... means this is not your "
"first time in this world.]"
msgstr "@proto1 【本身役㛪尋𫥨英。。。義𪜀低空沛吝頭㛪𦤾世界尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:50:text
msgid "@proto1c [You have already been summoned to this world once before.]"
msgstr "@proto1c 【㛪㐌得召回𦤾低𠬠吝耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:51:text
msgid ""
"@proto2 [In fact, you've already traversed the entire world and went through "
"the Tower already.]"
msgstr "@proto2 【寔𫥨、㛪㐌𠫾過𪥘󠄁世界𦓡座塔耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:52:text
msgid ""
"@proto2b [And, in the ending...\\> you either put in the sun...\\>or didn't.]"
msgstr "@proto2b 【吧、於回結。。。\\>㛪㐌㨋徠𩈘𡗶。。。\\>或空。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:54:text
msgid "@proto_eyeclosed [What matters is that you are here now.]"
msgstr "@proto_eyeclosed 【條關重𪜀𣇞㛪於低。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:56:text
msgid ""
"@proto2b [\\p has successfully bypassed the \"one shot\" restriction and "
"brought you back again.]"
msgstr "@proto2b 【\\p㐌越過成功界限「𠬠機會」抵迻㛪𠭤徠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:57:text
msgid "@niko2 I... \\>\\@niko3 ..."
msgstr "@niko2 㛪。。。\\>\\@niko3 。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:59:text
msgid "@niko_distressed2 oh..."
msgstr "@niko_distressed2 溩。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:61:text
msgid "@proto2 [...Hm?]"
msgstr "@proto2 【嘘？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:63:text
msgid "@niko_distressed2 ...I...\\>THOUGHT something was weird...."
msgstr "@niko_distressed2 。。。㛪。。。\\>拱想𪜀𣎏之妬空董。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:65:text
msgid "@niko_distressed ...when I woke up at the house, I called out a name..."
msgstr "@niko_distressed 。。。欺㛪醒𧻭𥪝茹、㛪㐌說𫥨𠬠丐𠸜。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:66:text
msgid "@niko_eyeclosed It turned out to be \\p's name..."
msgstr "@niko_eyeclosed 化𫥨𪜀𠸜𧵑\\p。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:67:text
msgid ""
"@niko3 And then I... \\.\\.back at the other robot...\\>\\n\\@niko_eyeclosed "
"I even asked \\p if we met before."
msgstr ""
"@niko3 耒㛪。。。\\.\\.於𡊲𠊛𣛠其。。。\\>\\n\\@niko_eyeclosed 㛪哙𠳨\\p料㐌"
"﨤僥吝鬧𣗓。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:68:text
msgid "@niko_eyeclosed Felt like such a dumb question at the time!"
msgstr "@niko_eyeclosed 𣅶妬㛪據想𪜀𠬠句𠳨愚幾！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:70:text
msgid "@proto2 [It looks like you are at least aware of it.]"
msgstr "@proto2 【𣎏𨤔𠃣一𪜀㛪𣎏認識得伮。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:71:text
msgid "@proto2b [...to some extent.]"
msgstr "@proto2b 【。。。𦤾𠬠𣞪度鬧妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:72:text
msgid "@niko_distressed_talk It's...\\> just this weird feeling, okay?"
msgstr "@niko_distressed_talk 伮只𪜀。。。\\>𠬠感覺窒奇𨓐、英曉空？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:73:text
msgid ""
"@niko_distressed I don't... \\>\\nactually remember going through the "
"world...\\>\\n\\@niko_eyeclosed I just remember \\p..."
msgstr ""
"@niko_distressed 㛪空。。。\\>\\n寔事𢖵𨉟㐌經過世界尼。。。"
"\\>\\n\\@niko_eyeclosed 㛪只𢖵每\\p催。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:74:text
msgid "@niko_distressed2 It's...\\.\\.really starting to freak me out."
msgstr "@niko_distressed2 實事。。。\\.\\.扒頭𪵯㛪慌亂耒妬。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:76:text
msgid "@proto2 [Calm down.]"
msgstr "@proto2 【平靜鬧。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:78:text
msgid ""
"@proto2b [Look, just like how my memories were locked away, yours are too.]"
msgstr "@proto2b 【意𪜀、記憶𧵑㛪拱當被銙𠫾、偅如𧵑英意。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:79:text
msgid "@niko_distressed2 ...but."
msgstr "@niko_distressed2 。。。扔。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:80:text
msgid ""
"@proto2b [You're a living being. You don't even need extra hardware to "
"remember.]"
msgstr "@proto2b 【㛪𪜀𠬠𠊛𤯩意。㛪哙𠁙懃份勁外抵𢖵。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:82:text
msgid "@proto1 [Just...\\.\\. close your eyes and focus.]"
msgstr "@proto1 【㛪只懃。。。\\.\\.𥄮眜吧集中催。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:83:text
msgid "@niko3 ...focus on what?"
msgstr "@niko3 。。。集中𠓨丐之吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:84:text
msgid "@proto1b [...]"
msgstr "@proto1b 【。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:85:text
msgid "@proto1b [...try to picture a big room made entirely of glass.]"
msgstr "@proto1b 【。。。唉試形容𠬠間房水晶。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:86:text
msgid ""
"@proto2b [No matter what you saw in the Tower, the top room never changes.]"
msgstr "@proto2b 【不𠸥㛪𧡊之𥪝座塔、間房𨑗頂空包𣇞𠊝𢷮。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:87:text
msgid "@niko2 ...Alright."
msgstr "@niko2 。。。得耒。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:125:text
msgid "@niko_surprised ..."
msgstr "@niko_surprised 。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:127:text
msgid "@niko_shock ...no way..."
msgstr "@niko_shock 。。。空体鬧。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:128:text
msgid "@niko_shock I was...\\.\\.\\@niko_wtf THERE, wasn't I?"
msgstr "@niko_shock 㛪㐌。。。\\.\\.\\@niko_wtf 實事於妬、沛空？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:129:text
msgid "@niko_upset At... the Tower..."
msgstr "@niko_upset 𥪝。。。座塔。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:130:text
msgid "@niko_eyeclosed I've been through...\\.\\.the Tower..."
msgstr "@niko_eyeclosed 㛪㐌𠫾過。。。\\.\\.座塔。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:156:text
msgid "@proto2 [There we go.]"
msgstr "@proto2 【唁耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:157:text
msgid "@niko_distressed2 I... \\.\\.can't remember all that much, but..."
msgstr "@niko_distressed2 㛪。。。\\.\\.空𢖵歇、扔𦓡。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:158:text
msgid "@niko_distressed_talk The room with the sun..."
msgstr "@niko_distressed_talk 間房𩈘𡗶。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:159:text
msgid "@niko_distressed2 It feels like...\\.\\.such a long time ago."
msgstr "@niko_distressed2 感覺㐌。。。\\.\\.窒嘍𧗱𠓀耒。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:161:text
msgid "@niko_distressed_talk ...it doesn't make sense!!!"
msgstr "@niko_distressed_talk 。。。空合理𡭧鬧𪥘󠄁！！！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:162:text
msgid ""
"@niko_distressed If I already finished the mission... \\>\\nWhy didn't "
"anything change?"
msgstr "@niko_distressed 裊如㛪㐌完全任務。。。\\>\\n哰拯𣎏之𠊝𢷮丕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:163:text
msgid "@niko3 And... why doesn't anyone know me?"
msgstr "@niko3 吧。。。在哰空𣎏埃𢖵𩈘㛪丕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:164:text
msgid ""
"@niko_upset The other Prophetbot... the robot lady... \\>\\nNone of them "
"remember who I am..."
msgstr "@niko_upset 𠊛𣛠先知其。。。姉𠊛𣛠𡛤。。。\\>\\n空埃𢖵㛪𪜀埃𪥘󠄁。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:165:text
msgid "@proto1c [Of course not. The residents do not have that capacity.]"
msgstr "@proto1c 【必然耒。各居民於低空𣎏可能妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:166:text
msgid "@proto1 [NPC memories do not last beyond the scope of a session.]"
msgstr "@proto1 【記憶𧵑人物附空捁𨱽過𠬠吝𨔈。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:167:text
msgid "@niko2 N...\\.\\.PC?"
msgstr "@niko2 人。。。\\.\\.物附？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:168:text
msgid "@proto1c [You know, the characters...\\>the world's residents.]"
msgstr "@proto1c 【㛪別蒂、各人物。。。\\>仍居民𧵑世界尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:169:text
msgid "@proto1 [All their \"past\" memories are built into their code, but...]"
msgstr "@proto1 【悉𪥘󠄁仍記憶「𫇰」𧵑𣱆得立程𠻿、扔。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:170:text
msgid ""
"@proto1b [The characters themselves don't... really exist until \\p wills "
"it.]"
msgstr "@proto1b 【本身各人物空。。。寔事存在朱𦤾欺\\p㦖如丕。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:171:text
msgid "@proto2B [Same story for the world itself.]"
msgstr "@proto2B 【世界拱相似。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:172:text
msgid "@proto2B [Doesn't really exist unless \\p initiates the program.]"
msgstr "@proto2B 【空寔事存在朱𦤾欺\\p起動份繌。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:175:text
msgid "@niko3 ...the... \\.\\.program?"
msgstr "@niko3 。。。份。。。\\.\\.繌？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:176:text
msgid ""
"@proto1b [The World Machine.]\\>\\n[A universe simulator that runs on \\p's "
"computer.]"
msgstr "@proto1b 【鈷𣛠全世。】\\>\\n【𠬠程模倣宇宙𧼋𨑗𣛠併𧵑\\p。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:177:text
msgid "@proto2 [We are all in it right now.]"
msgstr "@proto2 【衆些調當於𥪝妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:178:text
msgid "@niko_shock ....."
msgstr "@niko_shock 。。。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:180:text
msgid "@niko_distressed_talk ...SO WE'RE NOT REAL?"
msgstr "@niko_distressed_talk 。。。即𪜀衆𥪝空𣎏實嘑？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:181:text
msgid "@proto2 [Oh, you are.]"
msgstr "@proto2 【溩、㛪時𣎏。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:183:text
msgid "@proto2b [...which is why you're so important.]"
msgstr "@proto2b 【。。。𢧚㛪㵋關重𦤾丕妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:184:text
msgid ""
"@proto1 [The biggest flaw of the program is that it cannot be run "
"independently.]"
msgstr "@proto1 【𡓇𠸣𡘯一𧵑份繌𪜀伮空体𧼋獨立。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:185:text
msgid ""
"@proto2 [It requires the mental processing abilities of a real person from "
"another universe.]"
msgstr "@proto2 【伮要求可能處理腦部𧵑𠬠𠊛實自𠬠宇宙恪。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:186:text
msgid "@proto2b [Think of it like...\\.\\.one of your dreams.]"
msgstr "@proto2b 【偅如。。。\\.\\.𠬠𥋏𢠩𧵑㛪𧘇。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:187:text
msgid "@proto1b [When you wake up, it's gone.]"
msgstr "@proto1b 【欺㛪醒𧻭、伮變𠅒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:188:text
msgid ""
"@proto1c [But unlike a dream, this world has a physical location inside a "
"computer, which \\p operates.]"
msgstr "@proto1c 【扔恪喟𠬠𥋏𢠩、世界尼𣎏𠬠地址物理𥪝𠬠𣛠併𦓡\\p運行。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:189:text
msgid ""
"@proto1b [For this world to continue existing around you, \\p has to be in "
"constant contact with you.]"
msgstr "@proto1b 【抵世界尼接續存在衆𨒺㛪、\\p沛𡨺聯絡連續喟㛪。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:190:text
msgid "@proto2b [If \\p ends the program, the world will go into a stasis.]"
msgstr "@proto2b 【裊\\p仃份繌、世界𠱊𠫾𠓨狀態𥄬冬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:192:text
msgid "@niko3 Does...\\.\\. does \\p know this?"
msgstr "@niko3 \\p...\\.\\.\\p𣎏別條尼空吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:193:text
msgid "@proto1b [Of course.]"
msgstr "@proto1b 【必然。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:194:text
msgid ""
"@proto1c [From \\p's perspective, The World Machine isn't all that special.]"
msgstr "@proto1c 【自𧣳𥆾𧵑\\p、𣛠全世空特別𦤾勢。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:195:text
msgid ""
"@proto2b [It's no different from other recreational, game-type software they "
"may have installed on their computer.]"
msgstr "@proto2b 【伮空恪之仍份繌解智樣𠻀𨔈恪𣱆𣎏体㐌掑撻𨑗𣛠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:196:text
msgid ""
"@proto1c [They can also regenerate the world as many times as they'd like, "
"now that the restriction is nullified.]"
msgstr "@proto1c 【𣱆拱𣎏体再造世界包饒吝隨意、欺𦓡界限㐌被攑𠬃。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:197:text
msgid ""
"@proto2b [...All of that is consistent with their concept of what a computer "
"game looks like.]"
msgstr "@proto2b 【。。。悉𪥘󠄁調遵蹺定義𧗱𠬠𠻀𨔈電子𧵑𣱆。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:201:text
msgid "@niko_distressed_talk So why am I even here!!"
msgstr "@niko_distressed_talk 丕時在哰㛪徠於低渚！！！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:202:text
msgid ""
"@niko_distressed What am I even supposed to save if everything is just..."
msgstr "@niko_distressed 㛪沛救丐之欺𤗆次只𪜀。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:204:text
msgid "@niko_distressed_meow FAKE??"
msgstr "@niko_distressed_meow 假？？？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:206:text
msgid "@proto2b [...\"Fake\" is a harsh word, but...]"
msgstr "@proto2b 【。。。「假」𪜀𠬠自唏粗、扔。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:208:text
msgid ""
"@niko_distressed2 And...\\.\\.why...did \\p never tell me anything about... "
"\\.\\.any of this..."
msgstr ""
"@niko_distressed2 吧。。。\\.\\.在哰。。。\\p空包𣇞吶朱㛪𧗱。。。\\.\\.𡀯"
"尼。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:209:text
msgid "@proto2b [...I cannot speak for \\p.]"
msgstr "@proto2b 【。。。英空体吶𠊝意\\p得。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:210:text
msgid "@niko_distressed2 I... just want to go home..."
msgstr "@niko_distressed2 㛪。。。只㦖𧗱茹𦓡催。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:211:text
msgid ""
"@niko_distressed_talk But... every time \\p runs the program, I come back??"
msgstr "@niko_distressed_talk 扔。。。每吝\\p𧼋份繌、㛪徠𢮿徠哰？？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:212:text
msgid "@proto2b [Correct.]"
msgstr "@proto2b 【董。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:213:text
msgid "@niko_distressed Is this why... I feel like..."
msgstr "@niko_distressed 𣎏沛爲勢。。。𢧚㛪。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:214:text
msgid ""
"@niko_distressed2 Is this why it feels like I haven't been home for so long?"
msgstr "@niko_distressed2 𣎏沛爲勢𢧚㛪㵋感覺㐌窒嘍耒㛪空得𧗱茹空？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:215:text
msgid "@proto2b [Maybe.]"
msgstr "@proto2b 【𣎏体。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:216:text
msgid ""
"@proto2 [Once you've established a mental link with the world, you cannot "
"break it unless the world is saved.]"
msgstr "@proto2 【𠬠欺㐌連結心理喟世界尼、㛪空体破𠬃伮裊𣗓救世界。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:217:text
msgid "@proto2b [...but at this point, the world can never be truly saved.]"
msgstr "@proto2b 【。。。扔𦤾𣅶尼、空哙𣎏体寔事救世界𡛤耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:219:text
msgid "@niko_distressed2 That's..."
msgstr "@niko_distressed2 伮。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:226:text
msgid ""
"@niko_upset ...why would...\\>\\nwhy would you create a world like..."
"\\>\\n\\@niko_distressed_meow this?"
msgstr ""
"@niko_upset 。。。在哰。。。\\>\\n在哰舅徠造𫥨𠬠世界。。。"
"\\>\\n\\@niko_distressed_meow 如勢尼渚？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:227:text
msgid "@proto_gasp2 [Wait, what?]"
msgstr "@proto_gasp2 【寬、之幾？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:228:text
msgid ""
"@niko_upset_meow Why would you make a world that's doomed from the beginning?"
msgstr "@niko_upset_meow 在哰舅徠造𫥨𠬠世界㐌確定𪜀𠱊衰亡𬆄自伴頭？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:229:text
msgid "@niko_distressed_meow ...why do you keep bringing me back to it?"
msgstr "@niko_distressed_meow 。。。在哰舅據迻𨉟𠭤徠伮丕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:230:text
msgid "@niko_upset2 \\p..... \\>\\naren't you supposed to be a kind god??"
msgstr "@niko_upset2 \\p。。。。。 \\>\\n拯沛舅𪜀𠬠𠎬全能仁慈哰？？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:232:text
msgid "@proto1b [...oh.]"
msgstr "@proto1b 【。。。溩。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:233:text
msgid "@proto_eyeclosed [It appears that we have some confusion here.]"
msgstr "@proto_eyeclosed 【𣎏𨤔衆些𣎏𠬠𡭧𡍚悋於低。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:235:text
msgid "@proto2 [\\p did not build the world, Niko.]"
msgstr "@proto2 【\\p空造𫥨世界尼兜、尼孤啊。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:261:text
msgid ""
"@proto2 [\\p only owns a machine that is able to generate the world from "
"preexisting code.]"
msgstr "@proto2 【\\p只所有𠬠𣛠併𣎏体產出𫥨世界自碼源𣎏𠻿。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:262:text
msgid "@proto2b [They actually have fairly limited control of the events.]"
msgstr "@proto2b 【寔𫥨𣱆𣎏權檢詧可界限對喟各事件。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:264:text
msgid "@proto2 [The world was built by someone else altogether.]"
msgstr "@proto2 【世界尼得𡏦𤳸𠬠𠊛恪完全。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:265:text
msgid "@proto1c [Someone you cannot begin to fathom.]"
msgstr "@proto1c 【𠬠𠊛𦓡㛪空体想像浽。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:266:text
msgid ""
"@proto2b [It was also not designed to be the futile quest that it is now, "
"but...]"
msgstr "@proto2b 【伮拱空得設計抵𠭤成𠬠世界無方救𢵻如𣊾𣇞、扔。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:267:text
msgid "@proto_eyeclosed [...too many things went wrong.]"
msgstr "@proto_eyeclosed 【𣎏過𡗉次㐌𠫾差向。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:269:text
msgid ""
"@proto1c [There's... a type of signal disruption that he never expected.]"
msgstr "@proto1c 【𣎏。。。𠬠類擾亂信號翁𢵻曾擬𬧐。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:270:text
msgid ""
"@proto1b [It's eating away at the world, slowly rendering it into an "
"unrecognizable mess.]"
msgstr "@proto1b 【伮當咹𤷱𢴍世界尼、𢴍𢴍變伮成𠬠𧜗混沌空体認𫥨。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:271:text
msgid "@proto2b [Even if you bring back the sun, it will not go away.]"
msgstr "@proto2b 【朱怞㛪𣎏㨋徠得𩈘𡗶、伮拱𠱊空變𠅒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:273:text
msgid "@niko3 The square stuff, isn't it?"
msgstr "@niko3 𡌽塊𣃱、沛空吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:274:text
msgid "@niko_eyeclosed I remember those from before..."
msgstr "@niko_eyeclosed 㛪𢖵衆自吝𠓀。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:275:text
msgid "@proto1b [Then you know what to watch out for.]"
msgstr "@proto1b 【丕㛪別沛𠽮澄丐之耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:277:text
msgid ""
"@proto1c [...The creator knows what might be causing it, but there is "
"nothing that he could do...]"
msgstr "@proto1c 【。。。作者創世別𠬠次𣎏体𨠳𫥨伮、扔翁空体𪵯之。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:279:text
msgid "@proto1 [...until now.]"
msgstr "@proto1 【。。。朱𦤾𣊾𣇞。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:281:text
msgid "@proto1b [You managed to find me, after all.]"
msgstr "@proto1b 【𢖖󠄁共時、㛪㐌尋得英幾𦓡。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:283:text
msgid "@proto2 [You being here was due to his help.]"
msgstr "@proto2 【㛪於低𪜀𠾒𣎏事助𢴇𧵑翁𧘇妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:285:text
msgid "@niko2 Oh...\\>I guess it has something to do with the journal?"
msgstr "@niko2 溩。。。\\>丕㛪斷𪜀𣎏連關𬧐卷日記吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:286:text
msgid "@proto1b [Correct.]"
msgstr "@proto1b 【正確。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:287:text
msgid "@proto1 [Looks like he wants to have one final attempt at fixing it.]"
msgstr "@proto1 【𣎏𨤔翁𧘇㦖試𢯢伮𠬠吝𡳳窮。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:288:text
msgid "@proto2 [...and he might need to do it through you.]"
msgstr "@proto2 【。。。吧𣎏𨤰翁𧘇𠱊沛𪵯丕通過㛪。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:290:text
msgid "@proto1b [Niko, do you remember how to get to the Glen?]"
msgstr "@proto1b 【尼孤、㛪哙𢖵格𦤾塳潭浰空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:291:text
msgid ""
"@proto2 [Whatever you did in your last session, you should stick with it for "
"now.]"
msgstr "@proto2 【仍之㛪㐌𪵯於吝𠓀、㛪𢧚接續𪵯蹺。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:293:text
msgid "@niko_eyeclosed I remember a boat..."
msgstr "@niko_eyeclosed 㛪𢖵𣎏𠬠𡥵船。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:294:text
msgid "@niko ...more specifically, fixing a robot that drives the boat."
msgstr "@niko 。。。具体欣𪜀、𢯢𠬠𠊛𣛠棹𡥵船妬。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:295:text
msgid "@proto2 [Alright, then go do that.]"
msgstr "@proto2 【得耒、丕𠫾處理務妬𠫾。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:298:text
msgid "@niko_eyeclosed The boat robot has those squares over it..."
msgstr "@niko_eyeclosed 𠊛𣛠𨑗船被撫𡫨塊𣃱耒。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:299:text
msgid "@proto_gasp2 ...oh."
msgstr "@proto_gasp2 。。。溩。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:300:text
msgid "@proto2b [Then do whatever you must to find a new boat.]"
msgstr "@proto2b 【丕唉尋格檢𠬠𡥵船㵋𠫾。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:301:text
msgid ""
"@proto2 [There are plenty of machine parts around the Barrens that can be "
"repurposed.]"
msgstr "@proto2 【𣎏幾数零件𣛠𢪮𨒺塳邊疆𣎏体再使用。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:307:text
msgid "@niko_upset ...\\>\\n\\@niko_upset2 .........."
msgstr "@niko_upset 。。。\\>\\n\\@niko_upset2 。。。。。。。。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:310:text
msgid "@proto2 [You seem enthusiastic.]"
msgstr "@proto2 【㛪矓興起㗶。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:312:text
msgid "@proto2b [...that was sarcasm.]"
msgstr "@proto2b 【。。。英𢴉蒂。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:313:text
msgid "@niko_upset Knowing everything isn't real..."
msgstr "@niko_upset 別哴𤗆次調空𣎏實。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:314:text
msgid "@niko_upset2 ...really does make it feel pointless..."
msgstr "@niko_upset2 。。。𪵯𤗆役𠭤𢧚無義𪥘󠄁。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:315:text
msgid "@proto1b [But you DO want to go home, right?]"
msgstr "@proto1b 【扔㛪㦖𧗱茹、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:316:text
msgid "@niko3 Yeah, but..."
msgstr "@niko3 唹、扔𦓡。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:317:text
msgid "@niko_distressed2 How will I know that this isn't just another..."
msgstr "@niko_distressed2 𪵯哰𦓡㛪別低空沛𪜀𠬠。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:318:text
msgid "@proto2b [Because this session might be the last one.]"
msgstr "@proto2b 【爲吝尼𣎏体𪜀吝𡳳窮。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:319:text
msgid "@niko3 ...?"
msgstr "@niko3 。。。？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:321:text
msgid ""
"@proto1c [The creator is mobilizing things, throwing everything into this "
"one last shot.]"
msgstr "@proto1c 【作者創世當揮動𤗆財源、打挶悉𪥘󠄁𤗆次𠓨𠬠更博𡳳窮尼。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:322:text
msgid ""
"@proto2b [There might not be enough internal resources left for \\p to be "
"able to generate another session after this.]"
msgstr "@proto2b 【𣎏体𠱊空哙𨁥財源內部抵\\p𧼋添𠬠吝𨔈𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:325:text
msgid "@proto1c [...Just go find a new boat for now.]"
msgstr "@proto1c 【。。。暫時㛪𠫾檢𠬠𡥵船恪𠫾。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:328:text
msgid "@proto1c [...Just go fix the rowbot for now.]"
msgstr "@proto1c 【。。。暫時㛪𠫾𢯢𠊛𣛠棹船𠫾。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:331:text
msgid "@proto1b [But please, be careful.]"
msgstr "@proto1b 【扔吀㛪唉謹重。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:333:text
msgid "@niko3 What about you?"
msgstr "@niko3 哙英時哰吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:334:text
msgid "@proto2 [I will meet you at the docks later.]"
msgstr "@proto2 【英𠱊﨤㛪於𤅶艔𢖖󠄁。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:336:text
msgid "@proto2b [...Need to take care of something first.]"
msgstr "@proto2b 【。。。英懃處理𠬠数𡀯𠓀。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:358:text
msgid "@proto2 [...\\>\\nThis disk is blank.]"
msgstr "@proto2 【。。。\\>\\n隖𥐨𤿰。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:359:text
msgid "@niko_83c Whoops!"
msgstr "@niko_83c 喂！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:362:text
msgid ""
"@proto2 [Please help me restore my memory.\\>\\nBring the disk once you have "
"the backup installed.]"
msgstr "@proto2 【唉𢴇英恢復記憶。\\>\\n唉㨋徠隖𥐨𠬠欺㛪㐌掑撻得版抄留。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:368:text
msgid "@proto1b [That was a session.]"
msgstr "@proto1b 【妬𪜀𠬠吝𨔈。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:370:text
msgid "@proto2 [I also tried to tell you about the restriction at the end...]"
msgstr "@proto2 【英拱定𠸥朱㛪𧗱界限𡳳窮。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:371:text
msgid "@proto2b [...But you kinda started freaking out.]"
msgstr "@proto2b 【。。。扔㛪徠扒頭慌亂𬨠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:372:text
msgid "@niko_upset2 Sorry..."
msgstr "@niko_upset2 吀纇。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:373:text
msgid "@proto1 [Truth is, the session was designed to be run only once.]"
msgstr "@proto1 【事實𪜀、份繌只得設計抵𧼋𠬠吝唯一。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:374:text
msgid ""
"@proto1b [You weren't supposed to come back to this world after you are "
"done.]"
msgstr "@proto1b 【當𫥨㛪空体𢮿𪜀𢖖󠄁欺㐌完全任務。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:375:text
msgid ""
"@proto2b [But... a lot of things that aren't supposed to happen have "
"happened.]"
msgstr "@proto2b 【扔。。。窒𡗉次空𢧚侈𫥨㐌侈𫥨。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:377:text
msgid ""
"@proto2 [...I'm willing to wager that \\p bypassed the restriction through "
"the progress log failsafe method.]"
msgstr "@proto2 【。。。英可昃\\p㐌越過界限尼憑方法扠進程。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:378:text
msgid ""
"@proto2b [It can restart the session, but it's an easily repeatable process.]"
msgstr "@proto2b 【伮𣎏体起動徠吝𨔈、扔伮𪜀𠬠過程易㕸徠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:379:text
msgid "@proto2b [...Which means...]"
msgstr "@proto2b 【。。。義𪜀。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:380:text
msgid ""
"@proto1b [...it's entirely possible that \\p has brought you back more than "
"once, too.]"
msgstr "@proto1b 【役\\p迻㛪𠭤徠𡗉欣𠬠吝𪜀完全𣎏体。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:381:text
msgid ""
"@proto1c [You may have carried out this mission too many times to count.]"
msgstr "@proto1c 【𣎏体㛪㐌寔現任務尼無数吝耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:383:text
msgid ""
"@proto2b [...might explain why your memories felt like they were from a long "
"time ago.]"
msgstr "@proto2b 【。。。𣎏体解釋在哰記憶𧵑㛪徠感覺如窒嘍𧗱𠓀丕。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:3:385:text
msgid "@niko_upset So...\\.\\. why can \\p... do that...."
msgstr "@niko_upset 丕。。。\\.\\.在哰\\p。。。𣎏体。。。𪵯丕。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:4:5:text
msgid "@proto2 [Shh...]"
msgstr "@proto2 【𠶯。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:4:6:text
msgid "@proto2b [Trying to establish a connection here...]"
msgstr "@proto2b 【英當固設立結綏低。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:23:text
msgid "@silver [Hey, you okay in there?]"
msgstr "@silver 【尼、㛪穩渚？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:25:text
msgid ""
"@silver_eyeclosed [I did what I could with the terminals for now, and...]"
msgstr "@silver_eyeclosed 【姉㐌𪵯仍之𣎏体喟各𣛠入令、吧。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:34:text
msgid "@silver2 [...It's you...]"
msgstr "@silver2 【。。。𪜀英。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:38:text
msgid ""
"@silver2 [...you're the robot that insisted on living in the mines, are you "
"not?]"
msgstr "@silver2 【。。。英𪜀𠊛𣛠𠻞𠻞𠾕於徠𡌢𡎡、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:39:text
msgid ""
"@silver_eyeclosed [My friend told me to keep an eye out for you, should we "
"ever cross paths.]"
msgstr "@silver_eyeclosed 【伴𪝬㐌吲𪝬抵眜𬧐英、裊衆些𣎏包𣇞﨤僥。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:41:text
msgid "@proto1b [...Likewise.]"
msgstr "@proto1b 【。。。相似。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:43:text
msgid ""
"@proto1 [...Your...\\.\\. friend gave you something the last time you saw "
"each other.]"
msgstr "@proto1 【。。。伴。。。\\.\\.姉㐌迻姉𠬠物自吝𡳳𠄩𠊛﨤僥。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:44:text
msgid "@proto1 [Can you show me what it is?]"
msgstr "@proto1 【姉𣎏体朱𪝬䀡物妬得空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:45:text
msgid "@silver2 [Wait...\\.\\.You know about the amber?]"
msgstr "@silver2 【寬。。。\\.\\.英別𧗱𤗖琥珀哰？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:47:text
msgid "@proto2b [I just asked to see it, didn't I?]"
msgstr "@proto2b 【𪝬只𠳨䀡伮催𦓡、沛空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:50:text
msgid "@silver2 [Oh, actually...]"
msgstr "@silver2 【溩、寔𫥨。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:52:text
msgid "@niko_speak I needed it to fix a robot, so she gave it to me!"
msgstr "@niko_speak 㛪懃伮抵𢯢𠬠𠊛𣛠、𢧚姉𧘇迻㛪耒！"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:54:text
msgid "@proto2 [Oh?]"
msgstr "@proto2 【溩？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:56:text
msgid "@niko_speak Here! See?"
msgstr "@niko_speak 呢！沛空？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:62:text
msgid "@proto2b [Ah.]"
msgstr "@proto2b 【啊。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:70:text
msgid "@silver2 [Alright... here it is.]"
msgstr "@silver2 【得耒。。。低。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:76:text
msgid "@proto2b [Thought so.]"
msgstr "@proto2b 【董如𪝬擬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:84:text
msgid ""
"@proto2 [He seemed to trust you, so I will treat you as an ally as well.]"
msgstr "@proto2 【𣎏𨤔翁𧘇信姉、𢧚𪝬拱𠱊䁛姉𪜀同盟。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:85:text
msgid "@silver2 [...Okay?]"
msgstr "@silver2 【。。。嗚雞？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:86:text
msgid "@proto1b [Please listen carefully.]"
msgstr "@proto1b 【吀唉𦖑朱技。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:91:text
msgid ""
"@proto1 [You need to escort the messiah for the remainder of the Barrens.]"
msgstr "@proto1 【姉懃護送𠎬救世𥪝份哙徠𧵑塳邊疆。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:93:text
msgid ""
"@proto2b [I predict a high concentration of square particle disruptions in "
"the near future.]"
msgstr "@proto2b 【𪝬預斷𠱊𣎏密度窒高各擾亂由份子塊𣃱𥪝將來近。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:95:text
msgid "@silver2 [...No way.]"
msgstr "@silver2 【。。。空体鬧。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:96:text
msgid "@proto2b [Yes....\\.\\. way.]"
msgstr "@proto2b 【𣎏。。。\\.\\.体鬧。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:97:text
msgid ""
"@proto2 [It's likely that structures in the vicinity of the messiah might be "
"affected.]"
msgstr "@proto2 【可能可高各構築𥪝範圍近𠎬救世𠱊被影響。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:98:text
msgid ""
"@proto2 [...Making it a far more treacherous pilgrimage than the previous...."
"\\>\\@proto2b er, expectations.]"
msgstr ""
"@proto2 【。。。遣㹥局行鄉𠭤𢧚艱難歡期望窒。。。\\>\\@proto2b 唹、𡗉。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:99:text
msgid ""
"@proto1 [\\p and the messiah need all the extra help they can get right now.]"
msgstr "@proto1 【\\p吧𠎬救世懃悉𪥘󠄁事助𢴇𣎏体𬆄𣊾𣇞。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:100:text
msgid "@silver_eyeclosed [Understood.]"
msgstr "@silver_eyeclosed 【㐌曉。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:101:text
msgid "@niko2 O...\\.\\.okay..."

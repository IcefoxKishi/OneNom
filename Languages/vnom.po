msgid "@maize_strain ...that's why... \\.\\.the vines..."
msgstr "@maize_strain 。。。由妬。。。 \\.\\.仍絏蹽。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:17:text
msgid "@niko2 ...\\>you're... making the vines grow..."
msgstr "@niko2 。。。\\>姉當。。。𪵯仍絏蹽𠚐。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:18:text
msgid "@niko4 ...is that why there are vines everywhere?"
msgstr "@niko4 。。。𢧚㵋𣎏絏蹽泣坭哰？"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:19:text
msgid "@niko3 Are you... \\.\\.trying to hold the land together?"
msgstr "@niko3 姉當。。。 \\.\\.固𠡚𡨺𩈘𡐙連𢭲僥哰？"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:21:text
msgid "@maize_stress My powers... the best I could do. Yes."
msgstr "@maize_stress 權能𧵑姉。。。悉𪥘󠄁仍之姉𣎏体𪵯。董丕。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:23:text green/burial
#: grounds/burial grounds PLANE FIXED/EV188:1:81:text
msgid "@niko3 That's..."
msgstr "@niko3 實𪜀。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:25:text
msgid ""
"@niko2 Should I leave the sun here for you? \\>\\n\\@niko4 I know you wanted "
"to see it..."
msgstr "@niko2 㛪𣎏𢧚抵𩈘𡗶徠朱姉空？ \\>\\n\\@niko4 㛪別姉㦖𧡊伮𦓡。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:28:text
msgid "@maize_thisisfine ...tempting... \\>\\nBut I musn't..."
msgstr "@maize_thisisfine 。。。窒吸引。。。\\>\\n扔姉空体。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:29:text
msgid "@maize_stress ...the sun brings me comfort, but..."
msgstr "@maize_stress 。。。𩈘𡗶𢴇姉舒僴、仍。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:31:text
msgid "@maize_stress Stress is good... for this, fear is good..."
msgstr "@maize_stress 𢫮𣦎𪜀卒。。。朱役尼、𪨈𢜝駭𪨈卒。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:32:text
msgid "@maize_strain ...makes me strong.\\>...vines grow faster."
msgstr "@maize_strain 。。。𢴇姉劸猛欣。\\>。。。絏蹽𠚐𪬭欣。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:33:text RED GROUND/ground
#: 1/Library entrance/Lobby/kip:1:273:text Maps/FINALE/Encounter/map
#: events:4:192:text Maps/FINALE/Encounter PENG/map events:4:191:text
msgid "@niko4 But..."
msgstr "@niko4 扔。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:34:text
msgid "@maize_stress If I'm at ease... \\.\\.the vines might retreat."
msgstr "@maize_stress 裊姉抯𣿅。。。 \\.\\.絏蹽𣎏体捽𨆢。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:36:text
msgid "@maize_stress They're all in danger, savior..."
msgstr "@maize_stress 𣱆調當﨤危、咳𠎬救世。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:38:text
msgid "@maize_strain The villagers...\\.\\. the children..."
msgstr "@maize_strain 民廊。。。\\.\\.稚𡮈。。。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:40:text
msgid "@maize_strain ...my final hours...\\>mustn't go to waste."
msgstr "@maize_strain 。。。空体𠬃費。。。\\>仍𣇞𤼵𡳃窮𧵑姉。"

#: Maps/POSTGAME green/Ruins In/Maize/map events:1:42:text
msgid ""
"@maize_thisisfine The people deserve to live... even if just for another "
"day..."
msgstr "@maize_thisisfine 𠊛民稱當得𤯩。。。怞只添𠬠𣈜𡛤。。。"

#: Maps/Green/Village/House 7 - are you god/child npc:1:3:text npc:1:8:text
msgid "Can you see \\p, too?"
msgstr "舅拱𣎏体\\p渚？"

#: Maps/Green/Village/House 7 - are you god/child npc:1:4:text npc:1:9:text
msgid "@niko_speak Nope! \\@niko I can only hear their voice in my head."
msgstr "@niko_speak 空！ \\@niko 𨉟只𦖑得舅𧘇𥪝頭啐。"

#: Maps/Green/Village/House 7 - are you god/child npc:1:5:text
msgid "@alula_gasp That's still really cool!"
msgstr "@alula_gasp 吻窒湡妬！"

#: Maps/Green/Village/House 7 - are you god/child npc:1:15:text npc:1:25:text
msgid "Daddy says the world is very sick.\\nBut \\p can make it better again!"
msgstr "爸吶世界當窒瘖。\\n扔\\p𣎏体恢復伮！"

#: Maps/Green/Village/House 7 - are you god/child npc:1:16:text npc:1:26:text
msgid "...Are you \\p?"
msgstr "。。。舅𣎏沛\\p？"

#: Maps/Green/Village/House 7 - are you god/child npc:1:17:text npc:1:27:text
msgid "@niko Uh... not really.\\nI'm just the \"messiah\" they sent."
msgstr "@niko 唹。。。空𪳨。\\n𨉟時𪜀「𠎬救世」得寄𬺗啐。"

#: Maps/Green/Village/House 7 - are you god/child npc:1:18:text npc:1:28:text
msgid "@niko_speak I can talk with \\p, though!"
msgstr "@niko_speak 扔𨉟𣎏体吶𡀯𢭲\\p唲！"

#: Maps/Green/Village/House 7 - are you god/child npc:1:19:text npc:1:29:text
msgid "Wow!"
msgstr "𫽿！"

#: Maps/Green/Village/House 7 - are you god/child npc:1:20:text
msgid "@alula_gasp Double wow!"
msgstr "@alula_gasp 超𫽿！"

#: Maps/Green/Village/House 7 - are you god/child npc:1:21:text npc:1:30:text
msgid "What's that like?"
msgstr "感覺勢鬧丕？"

#: Maps/Green/Village/House 7 - are you god/child npc:1:22:text npc:1:31:text
msgid "@niko_speak Really cool!"
msgstr "@niko_speak 絕𡗋！"

#: Maps/Green/Village/House 7 - are you god/stew:1:1:text
msgid "@niko Fish heads and tails."
msgstr "@niko 頭吧脽𩵜。"


msgstr "@niko_eyeclosed 時、㛪吶丕催！"

#: Maps/FINALE/Credits/EV070:1:2:text
msgid "@plight_2 Off you go, I guess...."
msgstr "@plight_2 㛪𠫾猛劸唲。。。"

#: Maps/FINALE/Credits/EV070:1:5:text

#: Maps/Blue/Dormitories/110 - mechanical drawing/EV004:1:1:text
#: Maps/Blue/Outpost/factory interior/factory upstairs/EV021:1:1:text
#: upstairs/EV027:1:1:text
msgid "@niko A robot. It's beyond repair..."
msgstr "@niko 𠬠𠊛𣛠。無方救𢵻。。。"

#: Maps/Blue/Dormitories/110 - mechanical drawing/ladder:1:6:text
#: Maps/Blue/Dormitories/117 mom/ladder:1:6:text Maps/Blue/Dormitories/113
#: ocean/ladder:1:6:text Maps/Blue/Dormitories/119 cell/ladder:1:6:text
msgid "@niko I'm scared of ladders..."
msgstr "@niko 𨉟𢜝𨅹簜𡗋。。。"

#: Maps/Blue/Dormitories/110 - mechanical drawing/EV030:1:1:text
msgid "$Evacuation? At such short notice?"
msgstr "$疏散？急𢰽丕哰？"

#: Maps/Blue/Dormitories/110 - mechanical drawing/EV030:1:2:text
msgid "$I can't believe this..."
msgstr "$空体信浽。。。"

#: Maps/Blue/Dormitories/110 - mechanical drawing/EV030:1:3:text
msgid "$First the sun dies, now I'm out of a job..."
msgstr "$𩈘𡗶𣃣𤎕、吧𣇞𪝬𠅒役。。。"

#: Maps/Blue/Dormitories/110 - mechanical drawing/EV031:1:1:text
msgid "@niko Some sort of mechanical drawing."
msgstr "@niko 𠬠版𦘧機器之妬。"

#: Maps/Green/Forest/calamus npc:2:5:text
msgid "@calamus_speak Hey! You there!"
msgstr "@calamus_speak 尼！伴之㗒！"

#: Maps/Green/Forest/calamus npc:2:59:text
msgid "@calamus Have you seen a little girl?"
msgstr "@calamus 舅𣎏𧡊𠬠㛪𡛔𡮈空？"

#: Maps/Green/Forest/calamus npc:2:60:text
msgid "@calamus She's a little bit shorter than you, and-"
msgstr "@calamus 㛪𧘇唏隰欣舅、吧－"

#: Maps/Green/Forest/calamus npc:2:61:text
msgid "@calamus_speak Wait...\\.! That's... the sun."
msgstr "@calamus_speak 寬。。。\\.！妬𪜀。。。眜𡗶。"

#: Maps/Green/Forest/calamus npc:2:62:text
msgid "@calamus Are you our savior?"
msgstr "@calamus 舅𣎏沛𠎬救世空？"

#: Maps/Green/Forest/calamus npc:2:63:text
msgid "@niko I... yeah?"
msgstr "@niko 𨉟。。。唹？"

#: Maps/Green/Forest/calamus npc:2:64:text
msgid "@calamus_shame Oh my stars!"
msgstr "@calamus_shame 喂𡗶㗒！"

#: Maps/Green/Forest/calamus npc:2:65:text
msgid "@calamus_shame Sorry for my rudeness!"
msgstr "@calamus_shame 𨉟㐌不敬耒！"

#: Maps/Green/Forest/calamus npc:2:66:text
msgid "@niko Huh? It's alright..."
msgstr "@niko 嘑？空哰兜𦓡。。。"

#: Maps/Green/Forest/calamus npc:2:67:text
msgid "@niko_speak Are you looking for someone?"
msgstr "@niko_speak 舅當尋埃嘑？"

#: Maps/Green/Forest/calamus npc:2:68:text
msgid "@calamus_sad My little sister... she's been gone for three days now."
msgstr "@calamus_sad 㛪𡛔𨉟。。。㐌𠅒吣𠀧𣈜連耒。"

#: Maps/Green/Forest/calamus npc:2:69:text
msgid "@calamus I've been looking all over, but..."
msgstr "@calamus 𨉟㐌尋泣𤗆坭、扔。。。"

#: Maps/Green/Forest/calamus npc:2:70:text
msgid "@niko What does she look like?"
msgstr "@niko 㛪𧘇矓勢鬧？"

#: Maps/Green/Forest/calamus npc:2:71:text
msgid ""
"@calamus_speak Um...\\. a little shorter than you, long blue hair, two blue "
"feathers on top of her head..."
msgstr "@calamus_speak 𫫡。。。\\.唏隰欣舅、𩯀青𨱽、𨑗頭𣎏𠄩隻𣯡羽青洋。。。"

#: Maps/Green/Forest/calamus npc:2:72:text
msgid "@niko I'm sorry, I haven't seen anyone like that..."
msgstr "@niko 吀纇、扔𨉟𣗓𧡊埃如丕𪥘󠄁。。。"

#: Maps/Green/Forest/calamus npc:2:73:text
msgid "@niko_speak Where was the last place you saw her?"
msgstr "@niko_speak 舅𧡊㛪𧘇吝𡳳於兜丕？"

#: Maps/Green/Forest/calamus npc:2:74:text
msgid "@calamus_speak Back inside the ruins."
msgstr "@calamus_speak 邊𥪝殘跡。"

#: Maps/Green/Forest/calamus npc:2:75:text
msgid ""
"@calamus She said she was headed towards the forest, so I'm waiting here now."
msgstr "@calamus 㛪𧘇吶㛪𠱊𠓨棱、𢧚𨉟當𨅸䟻於低。"

#: Maps/Green/Forest/calamus npc:2:76:text
msgid "@calamus_sad I ran out of places to look..."
msgstr "@calamus_sad 𨉟歇𡊲抵尋𠅒耒。。。"

#: Maps/Green/Forest/calamus npc:3:2:text
msgid "@alula_gasp Calamus!"
msgstr "@alula_gasp 哥羅𡃙！"

#: Maps/Green/Forest/calamus npc:3:3:text
msgid "@calamus_speak Alula!"
msgstr "@calamus_speak 阿瞜羅！"

#: Maps/Green/Forest/calamus npc:3:4:text
msgid "@calamus You're okay!"
msgstr "@calamus 㛪吻穩！"

#: Maps/Green/Forest/calamus npc:3:5:text
msgid "@calamus_sad Thank goodness..."
msgstr "@calamus_sad 恩𡗶。。。"

#: Maps/Green/Forest/calamus npc:3:18:text
msgid "@niko Are you from the village?"
msgstr "@niko 各舅𪜀民廊哰？"

#: Maps/Green/Forest/calamus npc:3:19:text
msgid "@calamus No..."
msgstr "@calamus 空。。。"

#: Maps/Green/Forest/calamus npc:3:20:text
msgid ""
"@calamus_speak I don't remember why, but our father left the village while "
"we were still young."
msgstr "@calamus_speak 𨉟空𢖵在哰、扔仛衆𨉟𨖨廊欺衆𨉟哙𡮈。"

#: Maps/Green/Forest/calamus npc:3:21:text
msgid "@calamus We've lived in the ruins ever since."
msgstr "@calamus 衆𨉟生𤯩𥪝殘跡自妬𦤾𠉞。"

#: Maps/Green/Forest/calamus npc:3:22:text
msgid "@calamus_sad ...Well, it's just Alula and I now."
msgstr "@calamus_sad 。。。𣇞時只哙阿瞜羅吧𨉟。"

#: Maps/Green/Forest/calamus npc:3:23:text
msgid "@calamus_sad I can't lose her too..."
msgstr "@calamus_sad 𨉟空体𠅒訥㛪𧘇得。。。"

#: Maps/Green/Forest/calamus npc:3:27:text
msgid "@calamus_speak Alula is all I have.\\nI can't lose her..."
msgstr "@calamus_speak 阿瞜羅𪜀悉𪥘󠄁仍之𨉟𣎏。\\n𨉟空体𠅒㛪𧘇。。。"

#: Maps/Green/Forest/calamus npc 2:2:3:text
msgid "@alula_pout I was trapped inside this room and it was really scary..."
msgstr "@alula_pout 㛪被搩𥪝丐房尼超𢜝㫻𧘇。。。"

#: Maps/Green/Forest/calamus npc 2:2:4:text
msgid "@alula ...but then, the messiah saved me!"
msgstr "@alula 。。。扔耒𠎬救世㐌𦤾救㛪！"

#: Maps/Green/Forest/calamus npc 2:2:5:text
msgid "@calamus ...trapped?\\> In the ruins?"
msgstr "@calamus 。。。縸搩？\\>𥪝殘跡哰？"

#: Maps/Green/Forest/calamus npc 2:2:6:text
msgid "@alula_oh Yeah!\\|"
msgstr "@alula_oh 董妬！\\|"

#: Maps/Green/Forest/calamus npc 2:2:7:text
msgid "@alula_pout There was that weird stuff in the door!"
msgstr "@alula_pout 𥪝𨷶𣎏丐次奇啒妬𧘇！"

#: Maps/Green/Forest/calamus npc 2:2:8:text
msgid ""
"@alula_oh You know, the floating squares we see next to the ocean sometimes?"
msgstr "@alula_oh 仍塊𣃱𦓡𨉟唉𧡊近坡㴜𧘇？"

#: Maps/Green/Forest/calamus npc 2:2:9:text
msgid "@alula_oh The stuff you told me to stay away from?"
msgstr "@alula_oh 丐𦓡英𠸒㛪𢧚𠬉賒𧘇？"

#: Maps/Green/Forest/calamus npc 2:2:10:text
msgid "@calamus_shock What!?"
msgstr "@calamus_shock 嘑！？"

#: Maps/Green/Forest/calamus npc 2:2:11:text
msgid "@calamus_shock It's... spread to the ruins now?"
msgstr "@calamus_shock 伮。。。攔𦤾殘跡耒哰？"

#: Maps/Green/Forest/calamus npc 2:2:12:text
msgid "@calamus_sad This isn't good..."
msgstr "@calamus_sad 空咍耒。。。"

#: Maps/Green/Forest/calamus npc 2:2:13:text
msgid "@alula_speak Don't worry! I didn't touch it!"
msgstr "@alula_speak 空沛𢥈！㛪𣗓𪮻沛伮兜！"

#: Maps/Green/Forest/calamus npc 2:2:14:text
msgid "@alula I'm not hurt or anything..."
msgstr "@alula 㛪拱𣎏被傷咍之兜。。。"

#: Maps/Green/Forest/calamus npc 2:2:15:text
msgid ""
"@calamus_sad Still...If it gets any worse, we might have to find somewhere "
"else to live..."
msgstr "@calamus_sad 怞哰。。。裊𤗆次進展醜、衆些𠱊沛尋坭恪抵𤯩。。。"

#: Maps/Green/Forest/calamus npc 2:2:21:text
msgid "@niko What is this...square... stuff, exactly?"
msgstr "@niko 仍。。。塊𣃱尼。。。𪜀之丕？"

#: Maps/Green/Forest/calamus npc 2:2:22:text
msgid "@calamus_sad Bad."
msgstr "@calamus_sad 窒空卒。"

#: Maps/Green/Forest/calamus npc 2:2:23:text
msgid "@calamus Anything that touches them just...sorta..."
msgstr "@calamus 不據次之𪮻沛衆調被。。。"

#: Maps/Green/Forest/calamus npc 2:2:24:text
msgid "@calamus_sad ...Gets...messed up."
msgstr "@calamus_sad 。。。調空体救𢵻。"

#: Maps/Green/Forest/calamus npc 2:2:25:text
msgid ""
"@calamus_sad Whenever you hear people say the world is decaying, that's what "
"they meant..."
msgstr "@calamus_sad 每欺𠊛些吶𧗱世界當衰竭、𧘇𣱆𪜀丕蒂。。。"

#: Maps/Green/Forest/calamus npc 2:2:26:text
msgid "@calamus_speak Obviously, you should avoid them too."
msgstr "@calamus_speak 必然𪜀舅拱𢧚𠬉衆𫥨。"

#: Maps/Green/Forest/calamus npc 2:2:28:text
msgid "@calamus_speak Anyway, ah..."
msgstr "@calamus_speak 怞哰時、啊。。。"

#: Maps/Green/Forest/calamus npc 2:2:29:text
msgid "@calamus I can't thank you enough for rescuing my sister, savior..."
msgstr "@calamus 實事感恩𠎬救世窒𡗉爲㐌救㛪𡛔𨉟。。。"

#: Maps/Green/Forest/calamus npc 2:2:30:text
msgid "@niko_speak Just call me Niko!"
msgstr "@niko_speak 據噲𨉟𪜀尼孤𠫾！"

#: Maps/Green/Forest/calamus npc 2:2:32:text
msgid "@niko Huh?\\>\\n\\@niko_speak Why would it be?"
msgstr "@niko 𠼯？\\>\\n\\@niko_speak 在哰渚？"

#: Maps/Green/Forest/calamus npc 2:2:33:text
msgid "@niko I mean, I'm just a kid like you guys..."
msgstr "@niko 意𪜀、𨉟拱只𪜀𠬠𠀲𥘷如各舅催𦓡。。。"

#: Maps/Green/Forest/calamus npc 2:2:34:text
msgid "@calamus_shame Ah..."
msgstr "@calamus_shame 啊。。。"

#: Maps/Green/Forest/calamus npc 2:2:35:text
msgid "@calamus_smile Then...would you like to visit our house, Niko?"
msgstr "@calamus_smile 丕時。。。舅㦖𦤾探茹衆𨉟渚、尼孤？"

#: Maps/Green/Forest/calamus npc 2:2:39:text
msgid "@alula_speak Yaaaay!"
msgstr "@alula_speak 唁！！！"

#: Maps/Green/Forest/calamus npc 2:2:40:text
msgid "@alula Let's go!"
msgstr "@alula 𠫾鬧！"

#: Maps/Green/Forest/calamus npc 2:2:93:text
msgid ""
"@niko_speak I'm sorry, but I think \\p might want to go somewhere else right "
"now!"
msgstr "@niko_speak 𨉟窒惜、扔𨉟擬\\p懃𠫾𦤾𡊲恪𬆄𣊾𣇞！"

#: Maps/Green/Forest/calamus npc 2:2:94:text
msgid ""
"@calamus_smile That's fine.\\.\\. I'm sure you both have more important "
"things to do right now."
msgstr "@calamus_smile 空問題。\\.\\.𨉟昃各舅𣎏役關重欣沛𪵯𣊾𣇞。"

#: Maps/Green/Forest/calamus npc 2:2:95:text
msgid "@calamus_smile But feel free to drop by if you change your mind."
msgstr "@calamus_smile 扔裊各舅𢷮意時據自然過茹衆𨉟唲。"

#: Maps/Green/Forest/calamus npc 2:2:96:text
msgid "@alula_speak Yeah!\\.\\. We have something nice to give you, Niko!"
msgstr "@alula_speak 𫫡！\\.\\.衆𨉟𣎏𧵟窒絕𧶄朱舅妬、尼孤！"

#: Maps/Green/Forest/calamus npc 2:2:97:text
msgid "@alula We live in the ruins.\\| So don't forget!"
msgstr "@alula 衆𨉟𤯩𥪝殘跡。\\|揨悁唲！"

#: Maps/Green/Forest/calamus npc 2:3:1:text Maps/Green/Ruins
#: In/Birdhall/Birdhouse/calamus npc:2:5:text
msgid "@calamus_speak Oh, by the way, what happened to the sun?"
msgstr "@calamus_speak 啊、因便、𩈘𡗶被哰丕？"

#: Maps/Green/Forest/calamus npc 2:3:2:text
msgid ""
"@niko I lent it to someone in the ruins.\\nShe said she wanted to feel the "
"sun again, before.\\..\\.."
msgstr "@niko 𨉟㐌朱埃妬𥪝殘跡摱。\\n姉𧘇㦖感認𩈘𡗶𠬠吝𡳳、𠓀欺。\\.。\\.。"

#: Maps/Green/Forest/calamus npc 2:3:3:text
msgid "@calamus Oh, Maize.\\nI've met her before, too."
msgstr "@calamus 啊、姉梅。\\n𨉟拱㐌曾﨤姉𧘇。"

#: Maps/Green/Forest/calamus npc 2:3:4:text
msgid ""
"@calamus There used to be a lot more plant people around here...\\nThat's "
"what my father told me."
msgstr "@calamus 仛曾𠸒𨉟哴。。。\\n𨒺低曾𣎏𡗉𠊛𣘃欣。"

#: Maps/Green/Forest/calamus npc 2:3:5:text
msgid "@calamus I guess they've all...\\. gone."
msgstr "@calamus 昃𪜀𣱆㐌調。。。\\.𠫾𪥘󠄁耒。"

#: Maps/Green/Forest/calamus npc 2:3:6:text
msgid "@niko_eyeclosed I'm glad she got to see the sun again, at least."
msgstr "@niko_eyeclosed 𠃣一時姉𧘇㐌得𧡊𩈘𡗶𠬠吝𡳳。"

#: Maps/Green/Forest/EV332:1:1:text
msgid "@niko It's full of eels!"
msgstr "@niko 𣹓𧐖！"

#: Maps/Green/Forest/EV332:1:2:text
msgid "@niko_what Wait, no..."
msgstr "@niko_what 啊、空。。。"

#: Maps/Green/Forest/EV332:1:3:text
msgid "@niko_wtf2 It's full of snakes..."
msgstr "@niko_wtf2 伮𣹓𧋻。。。"

#: Maps/Green/Forest/EV332:2:1:text
msgid "@niko_eyeclosed Snakes..."
msgstr "@niko_eyeclosed 𧋻妬。。。"

#: Maps/Green/Forest/EV383:1:3:text
msgid "This is the best fishing spot I've found yet!"
msgstr "低𪜀𡊲鉤𩵜唁一𪝬尋得！"

#: Maps/Green/Forest/EV383:1:4:text
msgid "All the fish I catch here are longer than my arm!"
msgstr "𩵜於低𡥵鬧拱𨱽欣𪥘󠄁𦑃𢬣𪝬！"

#: Maps/POSTGAME green/Forest DOTN USE THIS/EV455:1:1:text
msgid "@niko_speak Oh no!\\>\\nThe bridge is out!"
msgstr "@niko_speak 喂空！\\>\\n橋被浱耒！"

#: Maps/POSTGAME green/Forest DOTN USE THIS/EV455:1:2:text
msgid "@niko There sure are a lot of vines growing around here now though..."
msgstr "@niko 扔𣇞𨒺低𣎏𡗉絏蹽實。。。"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:2:1:text
msgid "[I HAVE LOST COMMUNICATION WITH THE GUARDIAN OUTSIDE THE CITY GATE.]"
msgstr "【𪝬㐌𠅒聯絡喟𠊛更擱外𨶛城庯。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:2:9:text
msgid "@niko2 The... big robot, right?"
msgstr "@niko2 𠊛𣛠。。。𡘯、沛空？"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:2:11:text
msgid "[PLEASE HELP ME CHECK ON THEM.]"
msgstr "【唉𢴇𪝬檢查英𧘇。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:2:12:text
msgid "[I CANNOT LEAVE MY STATION.]"
msgstr "【𪝬空体𨖨位置尼。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:3:text
#: standing:3:17:text
msgid "[THE DEEPER RUINS ARE AHEAD.]"
msgstr "【𠌨𠓀𪜀仍殘跡漊欣。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:4:text
#: standing:3:18:text
msgid "[DO NOTE THAT THEY ARE PARTIALLY FLOODED.]"
msgstr "【𢝙𢚸注意哴衆㐌被汲𠬠份。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:7:text
msgid "@niko3 There's squares all over the big robot..."
msgstr "@niko3 𠊛𣛠𡘯㐌被撫𣹓塊𣃱耒。。。"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:8:text
msgid "[AH.]"
msgstr "【啊。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:9:text
msgid "[THAT IS OUTSIDE MY CAPACITY FOR HELP.]"
msgstr "【役妬㑲外可能助𢴇𧵑𪝬。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:10:text
msgid "[YOU MAY PROCEED TO THE DEEPER RUINS.]"
msgstr "【伴𣎏体進𠓨仍殘跡𠌨𠓀。】"

#: Maps/POSTGAME green/Ruins In/Junction/robot standing:3:11:text
#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/proto:5:143:text
msgid "@niko4 Alright..."
msgstr "@niko4 得耒。。。"

#: Maps/INIT/debug2/EV002:1:1:text
msgid "@prophet_hmm I am not programmed to feel"
msgstr "@prophet_hmm 𪝬空得立程抵感𧡊"

#: Maps/Green/Gate/map events:1:3:text events:1:32:text
msgid "@green_gatekeeper [Good luck.]"
msgstr "@green_gatekeeper 【祝𢆪慜。】"

#: Maps/Green/Gate/map events:1:12:text
msgid ""
"@niko_eyeclosed \\p, I'm too tired to go on right now...\\>\\nPlease let me "
"nap for a bit somewhere."
msgstr ""
"@niko_eyeclosed \\p、𨉟實事空哙飭抵𠫾徠𡛤耒。。。\\>\\n檢𡊲鬧朱𨉟𥄬𠫾、𨉟吀舅"
"妬。"

#: Maps/Green/Gate/map events:1:15:text
msgid ""
"@niko_eyeclosed I remember seeing a room to the west...\\>\\nIt looked like "
"it might be a good place to take a rest."
msgstr "@niko_eyeclosed 𨉟𢖵𧗱𠌨西𣎏𠬠間房。。。\\>\\n𣎏𠌨𨤔𪜀𠬠𡊲可卒抵𥊝眜。"

#: Maps/Green/Gate/map events:1:23:text
msgid "@niko_speak I found a pen! \\.\\.\\@niko Sort of."
msgstr "@niko_speak 𨉟𣎏筆耒！\\.\\.\\@niko 昃丕。"

#: Maps/Green/Gate/map events:1:25:text
msgid "@green_gatekeeper [Good.\\nPlease write your name here.]"
msgstr "@green_gatekeeper 【得耒。\\n𢝙𢚸記𠸜伴𠓨低。】"

#: Maps/Green/Gate/map events:1:41:text
msgid ""
"@green_gatekeeper [Indeed You Do.]\\>\\n[But Are You Not Forgetting "
"Something?]"
msgstr "@green_gatekeeper 【果董𪜀丕。】\\>\\n【扔拯沛伴當悁𠅒𠬠之妬哰？】"

#: Maps/Green/Gate/map events:1:42:text
msgid "@niko_eyeclosed .\\..\\..\\.\\>\\n\\@niko_speak Oh, the sun!"
msgstr "@niko_eyeclosed 。\\.。\\.。\\.\\>\\n\\@niko_speak 啊、𩈘𡗶！"

#: Maps/Green/Gate/map events:1:49:text
msgid "@green_gatekeeper [Have You Found Something To Write With?]"
msgstr "@green_gatekeeper [Have You Found Something To Write With?]"

#: Maps/Green/Gate/map events:1:64:text
msgid "@green_gatekeeper [The Sun...\\.\\. You're The Messiah!]"
msgstr "@green_gatekeeper 【𩈘𡗶。。。\\.\\.伴𪜀𠎬救世！】"

#: Maps/Green/Gate/map events:1:65:text
msgid "@green_gatekeeper [Are you on your way to the Tower?]"
msgstr "@green_gatekeeper 【伴當𨑗塘𦤾座塔哰？】"

#: Maps/Green/Gate/map events:1:68:text
msgid ""
"@green_gatekeeper [I saw you carrying the sun earlier.\\nYou're the messiah, "
"then?\\nOn your way to the Tower?]"
msgstr ""
"@green_gatekeeper 【𣅶𠓀𪝬𣎏𧡊伴𫼳𩈘𡗶𠫾徠。\\n昃𪳨伴𪜀𠎬救世？\\n當𨑗塘𦤾座"
"塔？】"

#: Maps/Green/Gate/map events:1:72:text
msgid ""
"@green_gatekeeper [You can enter the Refuge through this wall.\\nYou'll need "
"to sign your name in this scroll first.]"
msgstr ""
"@green_gatekeeper 【伴𣎏体𠓨區住隱過墻城尼。\\n伴𠱊沛寄𠸜𠓨淃紙尼𠓀。】"

#: Maps/Green/Gate/map events:1:73:text
msgid "@niko Alright.\\.\\.\\n.\\..\\..Do you have a pen?"
msgstr "@niko 得耒。\\.\\.\\n。\\.。\\.。舅𣎏筆空？"

#: Maps/Green/Gate/map events:1:74:text
msgid "@green_gatekeeper [Umm.\\..\\..]"
msgstr "@green_gatekeeper 【𫫡。\\.。\\.。】"

#: Maps/Green/Gate/map events:1:77:text
msgid "@green_gatekeeper [...No.\\.\\. I've lost mine.]"
msgstr "@green_gatekeeper 【。。。空。\\.\\.𪝬𪵯𠅒伮耒。】"

#: Maps/Green/Gate/map events:1:78:text
msgid ""
"@green_gatekeeper [Perhaps you should look around the Glen for another.]"
msgstr "@green_gatekeeper 【𣎏𨤰伴𢧚𠫾尋𠬠丐恪𥪝區潭浰。】"


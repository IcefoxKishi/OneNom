msgstr "@niko_speak 必然渚！"

#: Maps/FINALE/Credits/EV064:1:22:text
msgid "@niko_what Wait.\\>\\nWhy did you two answer my robot question too?"
msgstr "@niko_what 𦓡。\\>\\n哰𠄩𠊛拱㨋𠳒㛪丕？"

#: Maps/FINALE/Credits/EV064:1:24:text Maps/POSTGAME RED SKY/Elevator
#: deck/Office/locked room/map events:4:2:text
msgid "@rue_talk ..."
msgstr "@rue_talk 。。。"

#: Maps/FINALE/Credits/EV064:1:25:text

msgstr "@alula_gasp 尼孤！！！"

#: Maps/FINALE/Credits/map events:5:8:text
msgid "@alula_gasp You're okay too!"
msgstr "@alula_gasp 舅吻穩！"

#: Maps/FINALE/Credits/map events:5:9:text
msgid "@niko2 Did you guys just get here?"
msgstr "@niko2 各舅𣃣𦤾低嘑？"

#: Maps/FINALE/Credits/map events:5:10:text
msgid "@calamus I... think so?"
msgstr "@calamus 昃。。。勢？"

#: Maps/FINALE/Credits/map events:5:11:text
msgid ""
"@calamus_sad The squares started multiplying around the island after you "
"guys left..."
msgstr "@calamus_sad 仍塊𣃱扒頭因𬨠𨑗𡉕島𢖖󠄁欺各舅𨖨𠫾。。。"

#: Maps/FINALE/Credits/map events:5:12:text
msgid "@alula_oh It was so freaky!"
msgstr "@alula_oh 怯𡗋㫻𧘇！"

#: Maps/FINALE/Credits/map events:5:13:text
msgid "@alula_oh I fell right into a bunch of em!"
msgstr "@alula_oh 𨉟我𬆄𠓨衆㫻！"

#: Maps/FINALE/Credits/map events:5:14:text
msgid "@alula_oh Calamus tried to save me, and then..."
msgstr "@alula_oh 哥羅𡃙固救𨉟、吧耒。。。"

#: Maps/FINALE/Credits/map events:5:15:text
msgid "@calamus We... both ended up in this room."
msgstr "@calamus 衆𨉟。。。出現𥪝房尼。"

#: Maps/FINALE/Credits/map events:5:16:text
msgid "@calamus_heh Biggest scare of my life, for sure..."
msgstr "@calamus_heh 董𪜀次𢜝一𠁀𨉟㫻妬。。。"

#: Maps/FINALE/Credits/map events:5:18:text
msgid "@calamus Say, what is this place?"
msgstr "@calamus 𠯅㵋𢖵、低𪜀兜丕？"

#: Maps/FINALE/Credits/map events:5:19:text
msgid "@alula_gasp Are we in limboooooo?"
msgstr "@alula_gasp 些當於𥪝𡎝夢哰－－－－？"

#: Maps/FINALE/Credits/map events:5:20:text
msgid "@calamus_heh Alula! \\>We're not dead!"
msgstr "@calamus_heh 阿瞜羅！\\>衆些𣗓𣩂兜！"

#: Maps/FINALE/Credits/map events:5:21:text
msgid "@calamus_shame ...wait, \\.\\.are we?"
msgstr "@calamus_shame 。。。寬、\\.\\.𣎏沛丕空？"

#: Maps/FINALE/Credits/map events:5:26:text events:5:54:text
msgid "@alula_gasp That's even better than limbo!"
msgstr "@alula_gasp 卒欣𪥘󠄁𡎝夢！"

#: Maps/FINALE/Credits/map events:5:29:text
msgid "@niko_what Good...\\.\\. \\>\\@niko_what2 question."
msgstr "@niko_what 句𠳨。。。\\.\\. \\>\\@niko_what2 窒絕𡸏。"

#: Maps/FINALE/Credits/map events:5:30:text
msgid "@niko6 (hey \\p are they gonna be okay?)"
msgstr "@niko6 （尼\\p𣱆𠱊穩渚？）"

#: Maps/FINALE/Credits/map events:5:31:choice:0
msgid "They're fine, Niko."
msgstr "𣱆穩、尼孤啊。"

#: Maps/FINALE/Credits/map events:5:35:choice:0
msgid "Everyone is fine."
msgstr "𤗆𠊛調穩。"

#: Maps/FINALE/Credits/map events:5:51:text
msgid "@calamus_sad Phew."
msgstr "@calamus_sad 哺。"

#: Maps/FINALE/Credits/map events:5:53:text
msgid "@niko They also said you'll be able to go back to your home very soon!"
msgstr "@niko 舅𧘇拱吶各舅𠱊𧗱茹窒𣋽催！"


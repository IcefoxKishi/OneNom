msgstr "@proto2b 【尼孤啊、感恩爲𤗆次。】"

#: Maps/FINALE/Credits/EV064:1:10:text
msgid "@niko_speak So... do you like being a robot?"
msgstr "@niko_speak 丕。。。英𣎏適𪵯𠊛𣛠空？"

#: Maps/FINALE/Credits/EV064:1:11:text
msgid "@proto1 [Um.]"
msgstr "@proto1 【𫫡。】"

#: Maps/FINALE/Credits/EV064:1:12:text

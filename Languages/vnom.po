#: Maps/Unused/pshot/EV001:1:162:text
msgid "@niko_speak Goodbye, penguin!"
msgstr "@niko_speak 嘲暫別唲、𦑃𡭕！"

#: Maps/Unused/pshot/EV001:1:170:text
msgid "@niko_huh ..."
msgstr "@niko_huh 。。。"

#: Maps/Unused/pshot/EV001:1:174:text
msgid "@niko_huh ...yeah let's get outta here."
msgstr "@niko_huh 。。。唹些𢧚踤催。"

#: Maps/Unused/pshot/EV001:1:212:text
msgid "@niko_what2 Let's never speak of this again."
msgstr "@niko_what2 揨包𣇞𠯅𦤾𡀯尼唲。"

#: Maps/POSTGAME RED GROUND/To Tower/map events:1:3:text
msgid "@niko This door won't budge..."
msgstr "@niko 𦑃𫔤空𨃽蹢。。。"

#: Maps/POSTGAME RED GROUND/To Tower/map events:2:3:text events:2:11:text
msgid "@niko_distressed2 .\\..\\..\\.."
msgstr "@niko_distressed2 。\\.。\\.。\\.。"

#: Maps/POSTGAME RED GROUND/To Tower/map events:2:6:text events:2:17:text
msgid "@niko3 ...you okay in there?"
msgstr "@niko3 。。。英穩渚吖？"

#: Maps/POSTGAME RED GROUND/To Tower/map events:2:9:text
msgid "@niko3 ...hello?"
msgstr "@niko3 。。。英㗒？"

#: Maps/POSTGAME RED GROUND/To Tower/map events:2:18:text
msgid "@plight_worry ...mostly."
msgstr "@plight_worry 。。。大概勢。"

#: Maps/POSTGAME RED GROUND/To Tower/map events:2:20:text
msgid "@plight_worry2 ...look, don't worry about me for now, okay?"
msgstr "@plight_worry2 。。。𦖑尼、暫時揨𢥈過𧗱英、唲？"

#: Maps/POSTGAME RED GROUND/To Tower/map events:2:21:text
msgid "@plight_sigh You got more important stuff to deal with..."
msgstr "@plight_sigh 㛪哙𡀯關重欣沛解決𦓡。。。"

#: Maps/POSTGAME RED GROUND/To Tower/map events:3:2:text
msgid "@niko2 ...let's see if this elevator works."
msgstr "@niko2 。。。䀡簜𣛠尼𣎏活動空尼。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:35:text
msgid "@niko Neat."
msgstr "@niko 唁。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:43:text
msgid "@plight Welp, looks like this elevator works alright."
msgstr "@plight 溩、𣎏𨤔簜𣛠尼吻用得。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:44:text
msgid "@plight_2 I'll uh...\\.\\.go get the evacuees, I suppose..."
msgstr "@plight_2 英唹。。。\\.\\.昃𪜀英𠱊𠫾迍仍移民哙徠。。。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:70:text
msgid "@plight_worry UM."
msgstr "@plight_worry 唹。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:71:text
msgid "@plight_scared WHAT IS GOING ON."
msgstr "@plight_scared 𡀯之當侈𫥨丕。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:81:text
msgid "@niko_shock Nooo!!!!"
msgstr "@niko_shock 空！！！！"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:82:text
msgid "@plight_scared It's... the square stuff, isn't it?"
msgstr "@plight_scared 𪜀。。。𡌽塊𣃱、沛空吖？"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:83:text
msgid "@plight_worry2 There aren't any in here but..."
msgstr "@plight_worry2 𥪝尼𣗓𣎏之扔𦓡。。。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:84:text
msgid "@plight_worry I can hear them just outside the door..."
msgstr "@plight_worry 英𣎏体𦖑𧡊衆𬆄外𫔤。。。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:86:text
msgid "@niko3 H-hold on! \\@niko2 Maybe \\p and I can..."
msgstr "@niko3 徐－徐㐌！ \\@niko2 𣎏欺\\p吧㛪𣎏体。。。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:87:text
msgid "@plight_worry No, no, it's okay!"
msgstr "@plight_worry 空、空、空哰兜！"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:89:text
msgid ""
"@plight_worry2 Looks like the squares aren't inside the elevator...."
"\\>\\n\\@plight_sigh yet."
msgstr "@plight_worry2 𣎏𨤔衆𣗓𣼼𠓨簜𣛠。。。。\\>\\n\\@plight_sigh 𣗓。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:90:text
msgid "@plight_worry You're... in a hurry, right?"
msgstr "@plight_worry 㛪當。。。𣎏役急、沛空？"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:91:text
msgid "@plight_worry2 Go do...\\.\\. what you need to do...."
msgstr "@plight_worry2 𠫾。。。\\.\\.𪵯仍之㛪沛𪵯𠫾。。。。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:93:text
msgid "@niko3 But... what about you?"
msgstr "@niko3 扔。。。哙英時哰？"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:94:text
msgid "@plight_worry I'll... \\.\\.figure something out..."
msgstr "@plight_worry 英𠱊。。。\\.\\.尋格鬧妬。。。"

#: Maps/POSTGAME RED GROUND/To Tower/plight:1:95:text
msgid "@niko4 Okay..."
msgstr "@niko4 㖡。。。"

#: Maps/Green/Dock/girl:1:1:text
msgid "I'm catching fireflies for mommy!"
msgstr "𨉟當扒炶炶朱媄！"

#: Maps/Green/Dock/rowbot:2:1:text Maps/Green/Dock/EV063:1:1:text Maps/POSTGAME
#: green/Dock/rowbot:2:1:text green/Dock/EV063:1:1:text
msgid "@niko The horizon is glowing blue."
msgstr "@niko 塘蹎𡗶𤑍𦭷青。"

#: Maps/Green/Dock/intro to the glen:1:1:text
msgid "@rowbot [HERE IS YOUR STOP. THE GLEN.]"
msgstr "@rowbot 【伴㐌𦤾坭。嘲𢜏𦤾塳潭浰。】"

#: Maps/Green/Dock/intro to the glen:1:5:text
msgid ""
"@rowbot [THERE SHOULD BE A VILLAGE TO THE NORTH. BUT THAT'S ALL I CAN "
"RECALL.]"
msgstr "@rowbot 【𣎏𠬠𡾵廊𧗱𠌨北、扔𪝬只𢖵𦤾丕𦓡催。】"

#: Maps/Green/Dock/intro to the glen:1:6:text
msgid "@niko_speak Oh, that's good to know!"
msgstr "@niko_speak 溩、卒妬！"

#: Maps/Green/Dock/intro to the glen:1:7:text
msgid "@rowbot [FAREWELL.]"
msgstr "@rowbot 【嘲暫別。】"

#: Maps/Green/Dock/intro to the glen:1:8:text
msgid "@rowbot [MAY YOUR MISSION BE A SUCCESS.]"
msgstr "@rowbot 【祝任務𧵑伴成功卒惵。】"

#: Maps/Green/Dock/intro to the glen:1:9:text
msgid "@niko_speak A-Are you leaving?"
msgstr "@niko_speak 伴－伴𢯛𠫾哰？"

#: Maps/Green/Dock/intro to the glen:1:10:text
msgid "@rowbot [YES.\\>\\nI MUST RETURN TO MY STATION.]"
msgstr "@rowbot 【董。\\>\\n𪝬沛𠭤𧗱𤅶𧵑𪝬。】"

#: Maps/Green/Dock/intro to the glen:1:11:text
msgid "@niko But you'll be all alone again..."
msgstr "@niko 扔伴𠱊徠孤單𦓡。。。"

#: Maps/Green/Dock/intro to the glen:1:13:text
msgid "@rowbot [IT'S OKAY.]"
msgstr "@rowbot 【空哰。】"

#: Maps/Green/Dock/intro to the glen:1:14:text
msgid "@rowbot [I HAVE NOT BEEN TAMED.]"
msgstr "@rowbot 【𪝬𣗓得純化。】"

#: Maps/Green/Dock/EV219:1:3:text Maps/POSTGAME green/Dock/EV219:1:3:text
msgid "Hm..."
msgstr "嘘。。。"

#: Maps/Green/Dock/EV219:1:4:text Maps/POSTGAME green/Dock/EV219:1:4:text
msgid "Nothing's biting..."
msgstr "空𣎏之哏鉤𪥘󠄁。。。"

#: Maps/Green/Dock/EV220:1:3:text Maps/POSTGAME green/Dock/EV220:1:3:text
msgid "Hi I'm an inaccessible npc."
msgstr "盧𪝬𪜀人物不可交接。"

#: Maps/Green/Dock/EV221:1:1:text Maps/POSTGAME green/Dock/EV221:1:1:text
msgid "@niko A few small fish are in the bottom of this jar."
msgstr "@niko 𣎏𠬠𠄧𡥵𩵜𡮈𨑜底𤮗。"

#: Maps/Green/Dock/EV223:1:1:text Maps/POSTGAME green/Dock/EV223:1:1:text
msgid "@niko_speak It's full of fish heads!"
msgstr "@niko_speak 𣹓頭𩵜！"

#: Maps/Green/Dock/EV224:1:1:text Maps/POSTGAME green/Dock/EV224:1:1:text
msgid "@niko Filled with small, dried fish."
msgstr "@niko 𣹓仍𡥵𩵜𤇨枯𡮈。"

#: Maps/Green/Dock/EV225:1:1:text Maps/POSTGAME green/Dock/EV225:1:1:text
msgid "@niko_speak These look like crab shells."
msgstr "@niko_speak 𣎏𨤔𪜀𤿭𧍆。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/sponge :bottom:1:1:text
msgid "@niko A cleaning sponge with a rough surface."
msgstr "@niko 𠬠𠰳渤㴜撈𢹉壬。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:2:text
msgid ""
"$2) Without breaking the seal, inject the liquid phosphor into the container."
msgstr "$二・空破粘封、尖光素𣿅𠓨物貯。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:3:text
msgid "$3) Shake vigorously to initiate the reaction."
msgstr "$三・扐猛𢬣抵起動反應。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:4:text
msgid "$4) Use as soon as possible."
msgstr "$四・使用𣋽一𣎏体。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:6:text
msgid "$Note: If elements begin to separate, further shaking is required."
msgstr "$注意：裊各成份剒𫥨、懃沛扐添。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:8:text
msgid "$Also note: Hand protection is critical after this step."
msgstr "$注意添：扒𫃚沛𣎏保衛𢬣𢖖󠄁𨀈尼。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:9:text
msgid ""
"$The resulting acid is moderately stronger than common household cleaners."
msgstr "$阿掇成果猛欣𣃣沛𬧺喟各溶液撈𣳮家用。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:10:text
msgid "@niko_eyeclosed I... don't know what half of these words mean..."
msgstr "@niko_eyeclosed 𨉟。。。空曉分姅仍詞妬義𪜀之。。。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV004:1:11:text
msgid "@niko_speak It's a good thing you're here, \\p!"
msgstr "@niko_speak 𢆪𪜀𣎏舅於低妬\\p！"

#: Maps/Blue/Old factory/Factory interior2/upstairs/map events:1:1:text
msgid "@niko A bunch of robots without power."
msgstr "@niko 𠬠埬𠊛𣛠𠅒電。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/map events:1:2:text
msgid "@niko_eyeclosed I guess the generator can only do so much..."
msgstr "@niko_eyeclosed 𣎏𨤰𣛠發電只𪵯得𦤾勢。。。"

#: Maps/Blue/Old factory/Factory interior2/upstairs/EV016:1:1:text
#: interior2/upstairs/EV035:1:1:text interior2/upstairs/EV036:1:1:text
#: interior2/upstairs/EV037:1:1:text interior2/upstairs/EV038:1:1:text
msgid "@niko This robot looks kind of rusty..."
msgstr "@niko 𠊛𣛠尼矓𣎏𨤔釲𡏥。。。"

#: Maps/Tower/Summit/Shatter/autorun:1:8:text
msgid "@niko \\p?\\>\\n.\\..\\..What happened?\\>\\nIt's very dark in here..."
msgstr "@niko \\p？\\>\\n。\\.。\\.。𡀯之侈𫥨丕？\\>\\n𥪝尼𣋁過。。。"

#: Maps/Tower/Summit/Shatter/autorun:1:9:text
msgid "@niko_speak ...Oh!\\>\\nI can see a light at the end of this passage!"
msgstr "@niko_speak 。。。溩！\\>\\n𨉟𧡊𠬠暎𤏬於𡳳。。。"

#: Maps/Tower/Summit/Shatter/autorun:1:10:text
msgid "@niko I think I hear a voice too..."
msgstr "@niko 形如𨉟哙𦖑𧡊埃當吶𡛤。。。"

#: Maps/Tower/Summit/Shatter/autorun:1:11:text
msgid "@niko_surprised Mama?\\>\\nI can hear her calling me!"
msgstr "@niko_surprised 媄嘑？\\>\\n𨉟𦖑𧡊媄哙𨉟尼！"

#: Maps/Tower/Summit/Shatter/EV003:1:2:text
msgid ""
"@niko_speak All I need to do is pass through this wall...\\>\\nI'll finally "
"be home again."
msgstr "@niko_speak 𨉟只懃越過幅墻尼。。。\\>\\n𪜀𠱊𠭤𧗱茹。"

#: Maps/Tower/Summit/Shatter/EV003:1:4:text
msgid "@niko Ah, \\p,\\nI guess..."
msgstr "@niko 啊、\\p、\\n昃𪜀。。。"

#: Maps/Tower/Summit/Shatter/EV003:1:5:text
msgid "@niko_eyeclosed2 I guess this is goodbye..."
msgstr "@niko_eyeclosed2 㐌𦤾𣅶些吶嘲暫別耒。。。"

#: Maps/Tower/Summit/Shatter/EV003:1:7:text
msgid "@niko2 I'm....\\.\\. glad...\\.\\. I got to meet you, \\p..."
msgstr "@niko2 𨉟。。。。\\.\\.窒𢝙。。。\\.\\.得﨤舅、\\p。。。"

#: Maps/Tower/Summit/Shatter/EV003:1:9:text
msgid "@niko_sad Thank you for everything."
msgstr "@niko_sad 感恩舅爲悉𪥘󠄁。"

#: Maps/Tower/Summit/Shatter/EV003:1:110:script
msgid "FATAL ERROR: SAVIOR NOT FOUND. SHUTTING DOWN."
msgstr "纇至命：空𧡊𠎬救世。份繌𠱊𤎕。"

#: Maps/Green/Ruins In/Birdhall/Courtyard/alula npc:2:3:text
msgid "@alula_speak Hey!"
msgstr "@alula_speak 尼！"

#: Maps/Green/Ruins In/Birdhall/Courtyard/alula npc:2:33:text
msgid ""
"@alula I saw you going to the courtyard!\\>\\n\\@alula_speak So I thought "
"I'd tag along!"
msgstr "@alula 𨉟𧡊舅𠫾𧗱𠌨𡑝𥪝！\\>\\n\\@alula_speak 𢧚𨉟拱㦖𠫾蹺共！"

#: Maps/Green/Ruins In/Birdhall/Courtyard/alula npc:2:34:text
msgid "@calamus_smile Same!"
msgstr "@calamus_smile 𨉟拱勢！"

#: Maps/Green/Ruins In/Birdhall/Courtyard/alula npc:3:1:text
msgid ""
"@alula This is the courtyard.\\>\\n\\@alula It's got water...and...stuff..."
msgstr "@alula 低𪜀𡑝𥪝。\\>\\n\\@alula 伮𣎏渃吧。。。各次。。。"

#: Maps/Green/Ruins In/Birdhall/Courtyard/alula npc:4:1:text
msgid "@alula_oh Oh, are you leaving now?"
msgstr "@alula_oh 溩、舅𢯛𠫾哰？"

#: Maps/Green/Ruins In/Birdhall/Courtyard/alula npc:4:2:text
msgid "@alula_speak Good luck, Niko! \\>\\n\\@alula We believe in you!"
msgstr "@alula_speak 祝𢆪慜唲、尼孤！\\>\\n\\@alula 衆𨉟信舅！"

#: Maps/Green/Ruins In/Birdhall/Courtyard/calamus npc:2:1:text
msgid ""
"@calamus There's an entrance to an underground passage here.\\>\\nIt's "
"flooded, though."
msgstr "@calamus 自低𣎏体𠓨𠬠𡓃𠫾𨑜𢚸𡐙。\\>\\n雖然伮徠當汲。"

#: Maps/Green/Ruins In/Birdhall/Courtyard/calamus npc:3:1:text
msgid ""
"@calamus_speak Oh, are you leaving now?\\>\\n\\@calamus_smile It was...nice, "
"to meet you.\\>\\n\\@calamus Really. Thanks for everything."
msgstr ""
"@calamus_speak 溩、舅𢯛𠫾嘑？\\>\\n\\@calamus_smile 窒。。。𢝙㐌得﨤舅。"
"\\>\\n\\@calamus 實妬。感恩爲𤗆次唲。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:7:text
msgid "@ed [I...do not recognize this place in the protocol.]"
msgstr "@ed 【𪝬。。。空認𫥨地点尼𥪝交式。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:8:text
msgid "@ed [This...]"
msgstr "@ed 【𡊲尼。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:9:text
msgid "@ed [This isn't what I'm supposed to be showing you at all!]"
msgstr "@ed 【低絕然空沛仍之𪝬𢧚朱伴𧡊！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:10:text
msgid "@ed [How did you get here?]"
msgstr "@ed 【伴𦤾低憑格鬧丕？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:12:text
msgid "@ed [...I can only think of one person.]"
msgstr "@ed 【。。。𪝬只擬𫥨𠬠𠊛。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:13:text
msgid "@ed [He... contacted you?]"
msgstr "@ed 【翁些。。。蓮係伴唹？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:14:text
msgid "@ed [How long has he been... doing this?]"
msgstr "@ed 【翁些。。。𪵯丕得包嘍耒？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:16:text
msgid "@ed [...it doesn't matter at this point.]"
msgstr "@ed 【拱空哙關重𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:19:text
msgid "@ed [You are going out of bounds.]"
msgstr "@ed 【伴當𫥨𠺌界限。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:20:text
msgid "@ed [You should turn back.  Please turn back.]"
msgstr "@ed 【伴𢧚𢮿徠。  吀唉𢮿徠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:22:text
msgid "@ed [Bad things are going to happen.]"
msgstr "@ed 【仍次醜𠱊侈𫥨。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:23:text
msgid "@ed [Very bad things.]"
msgstr "@ed 【仍次窒醜。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:25:text
msgid "@ed [At this rate, Niko will be in danger.]"
msgstr "@ed 【據柁尼時尼孤𠱊臨危。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/EV001:1:26:text
msgid "@ed [Please turn back.]"
msgstr "@ed 【懇求伴𢮿徠。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:1:text
msgid "@silver [What's wrong?\\>\\nDo you want to head back?]"
msgstr "@silver 【哰丕？\\>\\n㛪㦖𢮿徠空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:2:text
msgid "@niko I have a weird feeling about this..."
msgstr "@niko 㛪𣎏感覺奇𨓐𧗱𡀯尼。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:3:text
msgid "@niko_speak What do you think, \\p?\\>\\nShould we head back?"
msgstr "@niko_speak 舅擬哰、\\p？\\>\\n些𣎏𢧚𢮿徠空？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:5:choice:0 hallway/invisible silver:3:11:choice:0
msgid "Let's head back"
msgstr "𢮿徠催"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:5:choice:1
msgid "Continue into the mines"
msgstr "𠫾接𠓨𡌢𡎡"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:9:text hallway/invisible silver:3:15:text
msgid "@niko \\p says we should go back."
msgstr "@niko \\p吶些𢧚𢮿徠。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:10:text hallway/invisible silver:3:94:text
msgid "@silver [Alright.]"
msgstr "@silver 【得耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:28:text
msgid "@ed [So you've chosen to listen.]"
msgstr "@ed 【丕伴㐌𢵬𦖑𠳒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:29:text hallway/invisible silver:3:67:text
msgid "@ed [Good.]"
msgstr "@ed 【卒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:30:text
msgid "@ed [There won't be any more trouble, then.]"
msgstr "@ed 【𠱊空哙𢳯𦇒鬧𡛤。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:47:text
msgid "@niko Wait...\\>\\n\\@niko_speak Where did the minecart go?"
msgstr "@niko 寬。。。\\>\\n\\@niko_speak 車𡎡變𠫾兜𠅒耒？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:51:text hallway/invisible silver:3:93:text
msgid "@niko \\p says we should keep going."
msgstr "@niko \\p吶些𢧚𠫾接。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/silver walk:3:52:text
msgid "@silver [Sounds good.]"
msgstr "@silver 【得妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:1:text
msgid "@niko_distressed Oh..."
msgstr "@niko_distressed 喂。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:2:text
msgid "@silver [Hm...? \\.\\.What's wrong?]"
msgstr "@silver 【嘘。。。？\\.\\.哰丕？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:3:text
msgid "@niko_distressed I..."
msgstr "@niko_distressed 㛪。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:4:text
msgid "@niko_eyeclosed ...I have a bad feeling about this, all of a sudden..."
msgstr "@niko_eyeclosed 。。。自仍㛪𣎏靈感空卒𧗱𡀯尼。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:5:text
msgid "@niko_distressed2 Feels like I should... not be here..."
msgstr "@niko_distressed2 感覺如矯㛪。。。空𢧚於低丕。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:6:text
msgid "@silver2 [Ah.]"
msgstr "@silver2 【啊。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:7:text
msgid "@silver [Do you want to head back, then?]"
msgstr "@silver 【丕時、㛪𣎏㦖𢮿徠空？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:8:text
msgid "@niko_eyeclosed I... don't know..."
msgstr "@niko_eyeclosed 㛪。。。空別𡛤。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:9:text
msgid "@niko2 What do you think, \\p?\\>\\nShould we head back?"
msgstr "@niko2 舅擬哰、\\p？\\>\\n些𣎏𢧚𢮿徠空？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:11:choice:1
msgid "Continue forward"
msgstr "接續𧗱𠌨𠓀"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:16:text
msgid "@silver2 [Oh, alright.]"
msgstr "@silver2 【溩、得耒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:65:text
msgid "@ed [You... listened.]"
msgstr "@ed 【伴。。。㐌𦖑𠳒。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:68:text
msgid "@ed [I don't think there will be any more trouble.]"
msgstr "@ed 【𪝬擬𠱊空哙軸𨁷鬧𡛤兜。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:70:text
msgid "@ed [Come on. Let's return to the protocol.]"
msgstr "@ed 【𨘱鬧。𠭤徠交式準催。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:87:text
msgid "@niko Wait...\\>\\n\\@niko2 Where did the minecart go?"
msgstr "@niko 寬。。。\\>\\n\\@niko2 車𡎡變𠫾兜𠅒耒？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/mineshaft/extra
#: hallway/invisible silver:3:89:text
msgid "@niko Guess we should get going, \\p."
msgstr "@niko 些𢧚𠫾催、\\p。"

#: Maps/Green/Dock/Fishing hut/EV003:1:1:text
msgid "There was a time where our people used to live in these ruins."
msgstr "曾𣎏𠬠時𠊛民衆𪝬𤯩𥪝仍殘跡妬。"

#: Maps/Green/Dock/Fishing hut/EV003:1:2:text
msgid ""
"But due to flooding, most of us have moved to less permanent settlements."
msgstr "由汲𣹕、份𡘯居民㐌轉𦤾各區定居𠦯限欣。"

#: Maps/Green/Dock/Fishing hut/EV003:1:3:text
msgid "@niko Flooding?"
msgstr "@niko 汲𣹕吖？"

#: Maps/Green/Dock/Fishing hut/EV003:1:4:text
msgid "Aye, the land has gotten brittle..."
msgstr "沛、𩈘𡐙㐌𠭤𢧚砵。。。"

#: Maps/Green/Dock/Fishing hut/EV003:1:5:text
msgid "The Glen used to be in one piece, you know?"
msgstr "塳潭浰曾𪜀𠬠塊統一、𡥙別空？"

#: Maps/Green/Dock/Fishing hut/EV003:1:6:text
msgid "But now it's just a bunch of islands that get smaller and smaller."
msgstr "扔𣊾𣇞伮只𪜀𠬠𡌽島𪨈𣈜𪨈𡮈𠫾𦓡催。"

#: Maps/Green/Dock/Fishing hut/EV003:2:1:text
msgid "@niko Do you still live here?"
msgstr "@niko 伯吻哙𤯩於低吖？"

#: Maps/Green/Dock/Fishing hut/EV003:2:2:text
msgid "Sort of."
msgstr "矯矯丕。"

#: Maps/Green/Dock/Fishing hut/EV003:2:3:text
msgid ""
"Fish populations near the village are thinning, so we fisherfolk are making "
"temporary shelter here."
msgstr "量𩵜近廊當疎𢴍𠫾、𢧚漁民如伯當暫住於低。"

#: Maps/Green/Dock/Fishing hut/EV003:2:4:text
msgid "@niko_speak Makes sense!"
msgstr "@niko_speak 合理！"

#: Maps/Green/Dock/Fishing hut/EV003:2:5:text
msgid "The deeper ruins have been abandoned for a while, though."
msgstr "雖然、仍殘跡漊欣時㐌被𠬃荒可嘍耒。"

#: Maps/Green/Dock/Fishing hut/EV003:2:6:text
msgid "...but I do see some kids coming in and out of those."
msgstr "。。。扔伯𣎏𧡊𠄧𠀲稚咍𫥨𠓨𡊲妬。"

#: Maps/Green/Dock/Fishing hut/EV003:2:7:text
msgid "I think they actually live there?"
msgstr "形如衆𤯩於妬時沛？"

#: Maps/Green/Dock/Fishing hut/EV003:2:9:text
msgid "... hey, now that I think about it..."
msgstr "。。。𦓡、𠯅㵋𢖵。。。"

#: Maps/Green/Dock/Fishing hut/EV003:2:10:text
msgid "Aren't YOU one of those kids?"
msgstr "拯沛𡥙𪜀𠬠𥪝数衆哰？"

#: Maps/Green/Dock/Fishing hut/EV003:2:11:text
msgid ""
"@alula_speak Yeah! \\@alula It's just me and my brother! \\>\\n\\@alula_pout "
"Or is it... \"my brother and I\"?"
msgstr ""
"@alula_speak 𫫡！\\@alula 只𣎏𡥙吧英催吖！\\>\\n\\@alula_pout 咍𪜀。。。「英"
"吧𡥙」𠰚？"

#: Maps/Green/Dock/Fishing hut/EV003:2:12:text
msgid "Well, I hope you kids stay safe!"
msgstr "怞哰時、各𡥙𡨺安全唲！"

#: Maps/Green/Dock/Fishing hut/EV003:2:13:text
msgid ""
"If y'all keed need somewhere less dangerous to live, the village or the city "
"are good places."
msgstr "裊各𡥙懃𠬠坭𠃣危險欣抵𤯩、𣎏体䀡察𥪝廊或城庯。"

#: Maps/Green/Dock/Fishing hut/EV003:3:2:text
msgid "I hope you and your brother stay safe!"
msgstr "懞𡥙吧英安全！"

#: Maps/Green/Dock/Fishing hut/EV003:3:5:text
msgid "I hope those kids are safe..."
msgstr "懞𬉆󠄁衆伮安全。。。"

#: Maps/Green/Dock/Fishing hut/EV010:1:1:text
msgid "@niko Warm coals."
msgstr "@niko 仍𡉕炭𤋾。"

#: Maps/Tower/Elevator/EV005:1:2:text
msgid "@niko ...\\>\\n\\@niko_speak Sure is taking a while..."
msgstr "@niko 。。。\\>\\n\\@niko_speak 嘍㗶𠰚。。。"

#: Maps/Tower/Elevator/EV005:1:3:text
msgid "@niko I guess this elevator leads to the top of the Tower, \\p..."
msgstr "@niko 䀡𫥨簜𣛠尼引𬨠頂座塔妬、\\p。。。"

#: Maps/Tower/Elevator/EV005:1:6:text
msgid ""
"@niko_speak ...are you excited, \\p?\\>\\n\\@niko We're finally gonna save "
"the world..."
msgstr ""
"@niko_speak 。。。舅𣎏好洫空、\\p？\\>\\n\\@niko 衆些𢯛救得世界耒妬。。。"

#: Maps/Tower/Elevator/EV005:1:7:text
msgid "@niko_speak And I know it's for real this time, cuz you're here!"
msgstr "@niko_speak 吧𨉟別吝尼𠱊𪜀實、爲𣎏舅於低！"

#: Maps/Tower/Elevator/EV005:1:9:text
msgid ""
"@niko And then...\\>\\n\\@niko_speak ...I'll get to go home for real this "
"time, too!"
msgstr "@niko 吧耒。。。\\>\\n\\@niko_speak 。。。𨉟拱𠱊實事得𧗱茹𡛤！"

#: Maps/Tower/Elevator/EV005:1:10:text
msgid "@niko I can't wait to see everyone again..."
msgstr "@niko 𨉟㦖﨤徠𤗆𠊛過。。。"

#: Maps/Tower/Elevator/EV005:1:12:text
msgid "@niko_speak Are you okay, \\p?\\>\\n\\@niko You seem a little quiet..."
msgstr "@niko_speak 舅穩空、\\p？\\>\\n\\@niko 邊舅𣎏𨤔唏安印妬。。。"

#: Maps/Tower/Elevator/EV005:1:18:text
msgid "@niko_speak ...yeah?"
msgstr "@niko_speak 。。。嘑？"

#: Maps/Tower/Elevator/EV005:1:22:text
msgid "@niko_speak ...?"
msgstr "@niko_speak 。。。？"

#: Maps/Tower/Elevator/EV005:1:26:choice:0
msgid "I need to tell you something."
msgstr "𨉟沛吶朱舅役尼。"

#: Maps/Tower/Elevator/EV005:1:30:text
msgid "@niko ...I'm listening."
msgstr "@niko 。。。𨉟當𦖑低。"

#: Maps/Tower/Elevator/EV005:1:34:text
msgid "@niko_speak What's going on, \\p?"
msgstr "@niko_speak 𡀯之丕、\\p？"

#: Maps/Tower/Elevator/EV005:1:38:choice:0
msgid "We can't save both."
msgstr "衆些空体救𪥘󠄁𠄩。"

#: Maps/Tower/Elevator/EV005:1:46:choice:0
msgid "The world...and you..."
msgstr "世界。。。吧舅。。。"

#: Maps/Tower/Elevator/EV005:1:50:text
msgid "@niko ...wh \\>\\@niko3 ...what's that supposed to mean, \\p?"
msgstr "@niko 。。。嘑\\>\\@niko3 。。。意舅𪜀哰、\\p？"

#: Maps/Tower/Elevator/EV005:1:54:choice:0
msgid "To send you home..."
msgstr "抵舅𧗱茹。。。"

#: Maps/Tower/Elevator/EV005:1:60:choice:0
msgid "We must break the lightbulb."
msgstr "些沛㧺𥒮琫畑。"

#: Maps/Tower/Elevator/EV005:1:64:text
msgid ""
"@niko_shock What??\\>\\n\\@niko3 ...But won't that... "
"\\>\\n\\@niko_distressed2 ...But won't that end the world?"
msgstr ""
"@niko_shock 嘑？？\\>\\n\\@niko3 。。。扔拯沛。。。"
"\\>\\n\\@niko_distressed2 。。。𪵯丕時世界𠱊滅亡哰？"

#: Maps/Tower/Elevator/EV005:1:76:text
msgid "@niko_eyeclosed I don't want that to happen..."
msgstr "@niko_eyeclosed 𨉟空㦖如丕兜。。。"

#: Maps/Tower/Elevator/EV005:1:78:text
msgid ""
"@niko2 So... what happens when we save the world?"
"\\>\\n\\@niko_distressed ...what happens to me...?"
msgstr ""
"@niko2 丕。。。裊些救世界時哰？\\>\\n\\@niko_distressed 。。。𨉟𠱊𠫾兜𧗱兜？"

#: Maps/Tower/Elevator/EV005:1:80:choice:0
msgid "I don't know."
msgstr "𨉟空別。"

#: Maps/Tower/Elevator/EV005:1:84:text
msgid "@niko_shock You... don't?"
msgstr "@niko_shock 舅。。。空別哰？"

#: Maps/Tower/Elevator/EV005:1:91:text
msgid "@niko_distressed2 ....."
msgstr "@niko_distressed2 。。。。。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/proto:1:1:text
msgid "@proto2b [...I would appreciate it if you do not linger here.]"
msgstr "@proto2b 【。。。𠄩𠊛空儺徠低過嘍𠱊咍欣妬。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/silver:1:1:text
msgid "@silver2 [I don't even know where this tunnel leads...]"
msgstr "@silver2 【姉哙空別塘𡌢尼引𫥨兜。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV005:1:1:text
msgid "@niko So this is the way out?"
msgstr "@niko 丕低𪜀𡓃𫥨吖？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV005:1:2:text
msgid "@silver [There wasn't any data on this path in the server room...]"
msgstr "@silver 【𥪝房𣛠空𣎏與件之𧗱𡓃𠫾尼𪥘󠄁。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV005:1:3:text
msgid "@proto2 [It's new.]"
msgstr "@proto2 【爲伮㵋。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV005:1:4:text
msgid "@proto1 [Niko, get in the minecart.]"
msgstr "@proto1 【尼孤、𡎥𠓨車𡎡𠫾。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV005:1:5:text
msgid "@niko O-Okay."
msgstr "@niko 溩－溩雞吖。"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV008:3:1:text
msgid "@proto1 [Please keep moving forward.]"
msgstr "@proto1 【𢝙𢚸𠫾接𧗱𠌨𠓀。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:3:text
msgid "@ed [I tried.]"
msgstr "@ed 【𪝬㐌固。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:5:text
msgid "@ed [I really did!]"
msgstr "@ed 【𪝬寔事㐌固！】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:6:text
msgid "@ed [But I...]"
msgstr "@ed 【扔𪝬。。。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:8:text
msgid "@ed [...dE St ablIzi Nng]"
msgstr "@ed 【。。。亡 末禾㥯 定】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:10:text
msgid "@ed [I'm sorry, Niko.]"
msgstr "@ed 【吀纇、尼孤。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:11:text
msgid "@ed [I    tR IE d tO PrOTE cT yOU.]"
msgstr "@ed 【亻    石卒 㐌固  保彳  韋亍伴。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:13:text
msgid "@ed [...bu t c An't hold it o f f foRevER.]"
msgstr "@ed 【。。。扌乃  空 亻本   金  甘制 亻奴  久買 得。】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:20:text
msgid "@niko3 What was that?"
msgstr "@niko3 之丕？"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:21:text
msgid "@proto_gasp2 [...HERE TOO?]"
msgstr "@proto_gasp2 【。。。於低㫻？】"

#: Maps/Blue/Cliffs/Lookout point/Mineshaft entrance/server
#: room/backroom/backhall/EV011:1:22:text
msgid "@silver3 [Watch out!]"
msgstr "@silver3 【䁛澄箕！】"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV002:1:1:text
msgid ""
"I just moved here from the Glen. Things are so different in the city...."
msgstr "𪝬𣃣轉𦤾自塳潭浰。𤗆次𥪝城庯恪別𠺳。。。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV002:1:2:text
msgid "You've been to the Glen, right?"
msgstr "伴㐌𠫾過塳潭浰、沛空？"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV002:1:4:text
msgid "Everything's so green back there...."
msgstr "於妬𤗆次實青卒。。。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV002:1:5:text
msgid "I really miss it!"
msgstr "𪝬𢖵伮𡗋！"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV002:1:6:text
msgid "My neighbor gave me some plants to cheer me up, but..."
msgstr "行𥯎𪝬𣎏贈𠬠𠄧𡊱𣘃抵嘲迍催、扔。。。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV002:1:10:text
msgid ".....I should probably get a muzzle for Betsy there."
msgstr "。。。。。昃𪜀𪝬沛檢𥱨𡂅朱𦛺差其催。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV003:1:1:text
msgid "@niko It's a landscape portrait of the Glen."
msgstr "@niko 𠬠幅幀風景𦘧塳潭浰。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV005:1:1:text
msgid "@niko_eyeclosed ...The remains of a potted plant."
msgstr "@niko_eyeclosed 。。。殘餘𧵑𠬠𡊱𣘃。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV006:1:1:text
msgid "@niko_speak Something has been chewing on this plant..."
msgstr "@niko_speak 𣎏𡥵之妬㐌啀丐𣘃尼。。。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV009:1:1:text
msgid "@niko_eyeclosed Not much is left of this plant..."
msgstr "@niko_eyeclosed 空哙𨔊徠𡗉𡗋。。。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV010:1:1:text
msgid "@niko_eyeclosed ...The entire plant was eaten..."
msgstr "@niko_eyeclosed 。。。𪥘󠄁丐𣘃被咹𠓻耒。。。"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV011:1:1:text
msgid "@niko The title is \"City Life: What to Expect\""
msgstr "@niko 標題𪜀「局𤯩都市：仍之𢧚期望」"

#: Maps/Red sky/Apartments/Hall2/Room4 - bird/EV014:1:1:text
msgid "@niko A picture of a ram, wearing a little pink bow."
msgstr "@niko 𠬠幅影𨄴𠬠哙羝𡶀、㧅𠬠隻𦀨紅𡮈。"

#: Maps/Green/Village/farmer:1:1:text
msgid ""
"The crops have been growing poorly without the sun...\\nAnd there's no "
"telling how long our surpluses will last."
msgstr "少𩈘𡗶、𣘃𣑺𠚐窒歉。。。\\n吧空別量剩餘𠱊哙宙得包𥹰𡛤。"

#: Maps/Green/Village/farmer:1:2:text
msgid "Please, savior, you have to hurry!"
msgstr "咳𠎬救世、𠊛唉𨘱蹎𬨠！"

#: Maps/Green/Village/farmer:1:3:text
msgid "@niko_speak I..."
msgstr "@niko_speak 𨉟。。。"

#: Maps/Green/Village/farmer:1:4:text
msgid "@niko I'll do my best."
msgstr "@niko 𨉟𠱊固𠡚。"

#: Maps/Green/Village/moss npc:1:1:text
msgid ""
"Most of the green moss covering our village has already lost its glow..."
msgstr "份𡘯𦼔青撫廊衆𪝬㐌𠅒暎𤏬耒。。。"

#: Maps/Green/Village/moss npc:1:2:text
msgid ""
"If it wasn't for the thin strip left on the boundaries of the land, people "
"could easily fall into the ocean."
msgstr "裊如空哙仍𧜵𡮈𨒺坡㴜、𤗆𠊛𣎏体淶𬺗㴜如𨔈。"

#: Maps/Green/Village/moss npc:1:3:text
msgid "Without light, land and water becomes indistinguishable here."
msgstr "少暎𤏬、𩈘𡐙吧𩈘渃如和𪵯𠬠。"

#: Maps/Green/Village/friendly child npc:1:2:text npc:1:11:text
msgid "Wooow!"
msgstr "𫽿！"

#: Maps/Green/Village/friendly child npc:1:3:text
msgid "Is that the sun?"
msgstr "妬𪜀𩈘𡗶嘑？"

#: Maps/Green/Village/friendly child npc:1:5:text
msgid "And you're holding it?"
msgstr "吧伴當擒伮憑𢬣空？"

#: Maps/Green/Village/friendly child npc:1:6:text
msgid "Isn't it hot?"
msgstr "拯沛伮𤎏𡗋哰？"

#: Maps/Green/Village/friendly child npc:1:7:text
msgid "@niko Not really!"
msgstr "@niko 空𪳨！"

#: Maps/Green/Village/friendly child npc:1:8:text
msgid "@niko It's nice and warm!"
msgstr "@niko 伮𤋾𣃣沛催啞！"

#: Maps/Green/Village/friendly child npc:1:12:text
msgid "Your eyes glow in the dark!"
msgstr "眜伴發𤏬𥪝琫𣋁尼！"

#: Maps/Green/Village/friendly child npc:1:14:text
msgid "Just like the sun!"
msgstr "依如𩈘𡗶丕！"

#: Maps/Green/Village/friendly child npc:1:16:text
msgid "@alula_speak That's what I said!"
msgstr "@alula_speak 依如𨉟吶㫻！"

#: Maps/Green/Village/worried npc:1:1:text
msgid "The land is fragmenting at an alarming rate..."
msgstr "𩈘𡐙當潵𥒮喟速度當𢥈礙。。。"

#: Maps/Green/Village/worried npc:1:2:text
msgid ""
"I don't like to think about the day when this town finally loses to the "
"intruding sea."
msgstr "𪝬空㦖擬𧗱𣈜𩈘𡐙𠹾輸大洋當侵𢭹兜。"

#: Maps/Green/Village/worried npc:1:3:text
msgid "We'll have to find another place to settle..."
msgstr "衆𪝬𠱊沛尋𠬠坭恪抵定居。。。"

#: Maps/Green/Village/ram quest check:1:19:text
msgid ""
"@shepherd You've provided a great service for all of ramkind.\\nIn return..."
"\\.\\nTake this fine ram wool."
msgstr ""
"@shepherd 伴㐌𣎏功狀𡘯朱全体類羝。\\n抵答禮。。。\\.\\n𠸼伴認𥙩縺羝上項尼。"

#: Maps/Green/Village/ram quest check:1:20:text
msgid "@niko Oh, uh... thanks."
msgstr "@niko 溩、唹。。。感恩吖。"

#: Maps/Green/Village/shephard:1:3:text
msgid "@shepherd My rams clock at 1333 megaherds."
msgstr "@shepherd 羝𧵑姉𣎏能率1333僤。"

#: Maps/Green/Village/shephard:1:4:text Maps/Green/Ruins
#: In/Birdhall/Birdhouse/EV017:1:15:text
msgid "@niko ...what?"
msgstr "@niko 。。。嘑？"

#: Maps/Green/Village/shephard:1:7:text
msgid "@shepherd You're heading to the city, aren't you?"
msgstr "@shepherd 㛪𢯛𬧐城庯、沛空？"

#: Maps/Green/Village/shephard:1:8:text
msgid "@shepherd Been there, done that."
msgstr "@shepherd 滕尼㐌耒。"

#: Maps/Green/Village/shephard:1:9:text
msgid "@shepherd Too cramped, you know?"
msgstr "@shepherd 𡐙𡒻𠊛佟過、㛪別空？"

#: Maps/Green/Village/shephard:1:10:text
msgid ""
"@shepherd But it's not like this place is getting any bigger with the rising "
"waters and all."
msgstr "@shepherd 吶𠫾拱沛吶徠、𡊲汲渃尼拱拯𫰅𬨠子鬧兜。"

#: Maps/Green/Village/shephard:1:11:text
msgid "@shepherd Hm...maybe the city isn't so bad after all..."
msgstr "@shepherd 嘘。。。𣎏欺城庯空弊𦤾勢。。。"

#: Maps/Green/Village/shephard:1:18:text
msgid ""
"@shepherd The rams are all standing in unfortunate spots.\\nYou need to move "
"them onto the darker moss."
msgstr "@shepherd 仍注羝調當𨅸於仍位置不幸。\\n伴沛移轉衆𠓨各毯𦼔湛𦭷。"

#: Maps/Green/Village/shephard:1:19:text Maps/Green/Village/shephard:1:47:text
msgid ""
"@shepherd If you get stuck, ring a bell and they'll all return to their "
"original positions."
msgstr "@shepherd 裊㛪﨤𠸋、唉𢫝鐘抵衆𠭤𧗱位置班頭。"

#: Maps/Green/Village/shephard:1:20:text Maps/Green/Village/shephard:1:48:text
msgid "@shepherd Good luck."
msgstr "@shepherd 祝𣛠慜。"

#: Maps/Green/Village/shephard:1:25:text
msgid "@shepherd Hm...\\nI need someone to help me herd my rams..."
msgstr "@shepherd 嘘。。。\\n姉懃埃妬𢴇姉摟羝。。。"

#: Maps/Green/Village/shephard:1:26:text
msgid "@niko_speak Oh! \\.\\@niko I can do that!"
msgstr "@niko_speak 溩！\\.\\@niko 抵㛪！"

#: Maps/Green/Village/shephard:1:27:text
msgid ""
"@niko I've seen some grownups do it back home... \\@niko_speak You kinda "
"just push them around!"
msgstr "@niko 㛪𧡊仍𠊛𡘯𪵯丕於茹耒吖。。。\\@niko_speak 只懃𢩽衆過徠催！"

#: Maps/Green/Village/shephard:1:28:text
msgid "@shepherd Hmm...\\.\\.But you are carrying the sun."
msgstr "@shepherd 嘘。。。\\.\\.扔㛪當擒𩈘𡗶。"

#: Maps/Green/Village/shephard:1:30:text
msgid "@niko_speak Wait, can't you just... watch the sun for me?"
msgstr "@niko_speak 勢時。。。姉矓𩈘𡗶朱㛪得空吖？"

#: Maps/Green/Village/shephard:1:31:text
msgid "@shepherd I cannot.\\nI am but a simple shepherd."
msgstr "@shepherd 不可。\\n姉只𪜀𠬠𢬣𤛇羝催。"

#: Maps/Green/Village/shephard:1:32:text
msgid "@niko_eyeclosed Um... okay..."
msgstr "@niko_eyeclosed 𫫡。。。溩雞。。。"

#: Maps/Green/Village/shephard:1:33:text
msgid ""
"@shepherd Come back when your hands are free. You will be rewarded if you "
"can herd my rams."
msgstr "@shepherd 唉𢮿徠欺㛪𣇝𢬣。㛪𠱊得頒賞裊𣎏体摟得羝𧵑姉。"

#: Maps/Green/Village/shephard:1:38:text
msgid "@shepherd Oh. I see your hands are now free."
msgstr "@shepherd 溩。姉𧡊𢬣㛪𣇞㐌𣇝。"

#: Maps/Green/Village/shephard:1:41:text
msgid ""
"@shepherd Would you like to help me herd my rams?\\nThere's a great reward "
"in store for you, I promise."
msgstr "@shepherd 㛪𣎏㦖𢴇姉摟羝空？\\n𣎏𠬠份賞𡘯䟻待㛪、姉許妬。"

#: Maps/Green/Village/shephard:1:45:text
msgid ""
"@shepherd Excellent!\\nTo the south is a peninsula inhabited by my rams."
msgstr "@shepherd 絕𡸏！\\n𧗱𠌨南𣎏𠬠半島坭羝𧵑姉定居。"

#: Maps/Green/Village/shephard:1:46:text
msgid ""
"@shepherd They are all standing in unfortunate spots.\\nYou need to move "
"them onto the darker moss."
msgstr "@shepherd 衆調當𨅸於仍位置不得地。\\n㛪沛摟衆𠓨仍𡊲𦼔湛𦭷。"

#: Maps/Green/Village/shephard:1:51:text
msgid "@niko Looks like we gotta herd some rams now, Alula."
msgstr "@niko 鬧些共摟羝、阿瞜羅。"

#: Maps/Green/Village/shephard:1:52:text
msgid "@alula Can I help?"
msgstr "@alula 𨉟輔𠬠𢬣得空？"

#: Maps/Green/Village/shephard:1:53:text
msgid "@niko_speak Sure!"
msgstr "@niko_speak 必然耒！"

#: Maps/Green/Village/shephard:1:59:text
msgid "@shepherd Very well.\\> Come back when you reconsider."
msgstr "@shepherd 得催。\\>唉𢮿徠欺㛪𠻿𠳹。"

#: Maps/Green/Village/farmer:1:1:text
msgid "The light from these lanterns will have to do for now."
msgstr "暫時些𠱊沛用暎𤏬自仍畑籠尼。"

#: Maps/Green/Village/farmer:1:2:text
msgid "I'm starting to see some very small sprouts."
msgstr "𪝬扒頭𧡊仍𦹰嫩窒𡮈耒。"

#: Maps/Green/Village/farmer:1:3:text
msgid "It will probably take some time for these to bear fruit..."
msgstr "𣎏𨤔𠱊懃𠬠𡭧時間抵衆𡗂菓。。。"

#: Maps/Green/Village/ram:1:3:text
msgid "@niko_speak Apparently this moss tastes like fish!"
msgstr "@niko_speak 𦼔尼𣎏𨤔𣎏味𩵜！"

#: Maps/Green/Village/ram:1:4:text
msgid "@niko_eyeclosed That's... actually kinda weird."
msgstr "@niko_eyeclosed 實𪜀。。。奇𨓐。"

#: Maps/Green/Village/ram:1:7:text
msgid "@niko I suppose I could just eat one, but..."
msgstr "@niko 𨉟𣎏体咹試𠬠𠃣、扔。。。"

#: Maps/Green/Village/ram:1:8:text
msgid "@niko_speak You know what they say about curiosity and the cat!"
msgstr "@niko_speak 伴別𣱆吶之𧗱事殂摸吧𡥵貓耒𦓡！"

#: Maps/Green/Village/ram:1:9:text
msgid "@niko_eyeclosed Not that I'm a cat..."
msgstr "@niko_eyeclosed 空𣎏義𨉟𪜀貓唲。。。"

#: Maps/Green/Village/ram:1:16:text Maps/Green/Village/ram:1:27:text
msgid "@niko This ram is chewing on a ball of moss."
msgstr "@niko 注羝尼當啀𠬠菓琫𦼔。"

#: Maps/Green/Village/ram:1:17:text
msgid "@alula_speak Moss is tasty!"
msgstr "@alula_speak 𦼔窒唁！"

#: Maps/Green/Village/ram:1:18:text
msgid "@niko_speak Oh? \\.\\.\\@niko What do they taste like?"
msgstr "@niko_speak 溩？\\.\\.\\@niko 衆味𫥨哰丕？"

#: Maps/Green/Village/ram:1:19:text
msgid "@alula Fish!"
msgstr "@alula 如𩵜意！"

#: Maps/Green/Village/ram:1:20:text
msgid "@niko_speak Seriously?"
msgstr "@niko_speak 實唹？"

#: Maps/Green/Village/ram:1:21:text
msgid "@alula_pout Oh, but you have to pick out the darker ones to eat."
msgstr "@alula_pout 溩、扔舅沛攄仍丐𣋁𦭷𦓡咹意。"

#: Maps/Green/Village/ram:1:22:text
msgid "@alula_speak Wouldn't wanna eat the glowy stuff!"
msgstr "@alula_speak 空𢧚咹𦼔發𤏬！"

#: Maps/Green/Village/ram:1:23:text
msgid "@alula That'd be silly."
msgstr "@alula 𠱊窒呆。"

#: Maps/Green/Village/ram:1:24:text
msgid "@alula_pout And wasteful!"
msgstr "@alula_pout 吧費犯𡛤！"

#: Maps/Green/Village/ram:1:29:text
msgid "@niko_speak Now I'm curious!"
msgstr "@niko_speak 𣇞𨉟殂摸耒妬！"

#: Maps/Green/Village/ram:1:30:text
msgid "@niko_speak What do you think they taste like, \\p?"
msgstr "@niko_speak 舅擬衆味勢鬧、\\p？"

#: Maps/Green/Village/ram:1:32:text
msgid "@niko_eyeclosed The moss, not the ram..."
msgstr "@niko_eyeclosed 意𪜀𦼔、空沛羝唲。。。"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko This jar is full of milk."
msgstr "@niko 𠬠𤮗𣷱。"

#: Maps/Green/Village/jar:1:2:text
msgid "@niko_speak Milk makes you grow taller!"
msgstr "@niko_speak 㕵𣷱𠱊𡘯高！"

#: Maps/Green/Village/jar:1:3:text
msgid "@niko That's what mama always says."
msgstr "@niko 媄㫻吶丕。"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko This jar is full of dry beans."
msgstr "@niko 𠬠𤮗𣹓籺豆枯。"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko Two jars."
msgstr "@niko 𠄩隻𤮗。"

#: Maps/Green/Village/jar:1:1:text
msgid ""
"@niko I don't know what's in this jar, but it smells kinda like pickles!"
msgstr "@niko 𨉟空別𥪝𤮗𣎏之、扔苿𣎏𨤔偅荼䣷！"

#: Maps/Green/Village/jar:1:3:text
msgid "@alula_speak I like pickles!"
msgstr "@alula_speak 𨉟適咹荼䣷！"

#: Maps/Green/Village/jar:1:4:text
msgid "@niko_eyeclosed I don't!"
msgstr "@niko_eyeclosed 𨉟時空！"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko These jars are filled with water."
msgstr "@niko 仍𤮗尼𣹓渃。"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko This jar smells like alcohol."
msgstr "@niko 𤮗尼𣎏苿𨢇。"

#: Maps/Green/Village/jar:1:2:text
msgid "@niko_speak ...gross!"
msgstr "@niko_speak 。。。㕭！"

#: Maps/Green/Village/jar:1:3:text
msgid "@niko I wonder why grown-ups like to drink this stuff?"
msgstr "@niko 空別哰𠊛𡘯據適㕵伮𠰚？"

#: Maps/Green/Village/jar:1:4:text
msgid "@niko Alcohol is for setting things on fire."
msgstr "@niko 𨢇喟醌𪜀抵炪焒𦓡。"

#: Maps/Green/Village/jar:1:6:text
msgid "@alula What's a fire?"
msgstr "@alula 焒𪜀之丕？"

#: Maps/Green/Village/jar:1:7:text
msgid "@niko_eyeclosed We have much to discuss."
msgstr "@niko_eyeclosed 衆些𣎏𡗉次懃𠴞論。"

#: Maps/Green/Village/jar:1:2:text
msgid "@niko It smells nice!"
msgstr "@niko 苿可𦹳！"

#: Maps/Green/Village/jar:1:2:text
msgid "@alula_gasp Gaaaaaaaasp!"
msgstr "@alula_gasp 𫽿！！！"

#: Maps/Green/Village/jar:1:3:text Maps/Green/Village/jar:1:6:text
msgid "@niko_speak There's peas in there!"
msgstr "@niko_speak 𥪝尼𣎏豆！"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko Some jars filled with grains."
msgstr "@niko 𠬠𠄧𤮗貯五穀。"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko There's water in this jar."
msgstr "@niko 𥪝𤮗尼𣎏渃。"

#: Maps/Green/Village/jar:1:1:text
msgid "@niko A jar full of small rocks."
msgstr "@niko 𠬠𤮗𣹓𥒥𡮈。"

#: Maps/Green/Village/fireflies:1:1:text
msgid "@niko It's a firefly jar."
msgstr "@niko 𠬠𤮗炶炶。"

#: Maps/POSTGAME RED GROUND/ground 2/cedric:1:2:text
msgid "@kip_worry Please! \\.\\.You musn't!!!"
msgstr "@kip_worry 吀舅蒂！\\.\\.空体𪵯丕得！！！"

#: Maps/POSTGAME RED GROUND/ground 2/cedric:1:3:text
msgid "@kip_worry The labs could collapse any moment now!!!"
msgstr "@kip_worry 房試驗𣎏体𨀎𢭰不據𣅶鬧！！！"

#: Maps/POSTGAME RED GROUND/ground 2/cedric:1:5:text
msgid "@cedric_upset Let go of me!!!"
msgstr "@cedric_upset 𠬃𪝬𫥨！！！"

#: Maps/POSTGAME RED GROUND/ground 2/cedric:1:62:text
msgid "@niko2 ...\\.\\.Cedric?"
msgstr "@niko2 。。。\\.\\.察嚦？"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:4:text
msgid "@kip_pout He...."
msgstr "@kip_pout 英些。。。"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:6:text
msgid "@kip_sad I...\\.\\. couldn't stop him..."
msgstr "@kip_sad 姉。。。\\.\\.空体拫英些徠。。。"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:8:text
msgid "@kip_sigh *Sigh*"
msgstr "@kip_sigh ＊係＊"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:13:text
msgid "@niko ...\\.\\.Miss?"
msgstr "@niko 。。。\\.\\.姉㗒？"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:17:text
msgid "@kip_huh Messiah!"
msgstr "@kip_huh 𠎬救世！"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:18:text
msgid "@kip_sigh Oh... you came at an awful time."
msgstr "@kip_sigh 溩。。。㛪𦤾空董𣅶𡭧鬧。"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:19:text
msgid "@kip_pout Come on, we have to get out of here."
msgstr "@kip_pout 𨘱𬨠、衆些沛𨖨𠺌低催。"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:21:text
msgid "@niko2 Where...\\.\\. to?"
msgstr "@niko2 𦤾。。。\\.\\.兜吖？"

#: Maps/POSTGAME RED GROUND/ground 2/EV086:1:22:text
msgid "@kip_sigh Where everyone else is right now."
msgstr "@kip_sigh 坭𤗆𠊛當於𣊾𣇞。"

#: Maps/Unused/Lobby-OLD VER/EV001:1:1:text
msgid "THOU SHALT NOT PASS"
msgstr "茹𠊛𠱊空過"

#: Maps/Unused/Lobby-OLD VER/EV002:1:1:text
msgid "@niko That sure is some books"
msgstr "@niko 冊窒冊"

#: Maps/Tower/Water/pc:1:13:text
msgid "@ed [Hello, Niko.]"
msgstr "@ed 【吀嘲、尼孤。】"

#: Maps/Tower/Water/pc:1:14:text
msgid "@niko H... hello..."
msgstr "@niko 吀。。。吀嘲。。。"

#: Maps/Tower/Water/pc:1:15:text
msgid "@ed [Congratulations. You are now inside the Tower.]"
msgstr "@ed 【吀祝𢜏。伴當於邊𥪝座塔。】"

#: Maps/Tower/Water/pc:1:16:text
msgid "@niko Are you talking...\\.\\.\\@niko_speak ...to me, now?"
msgstr "@niko 𣇞。。。\\.\\.\\@niko_speak 。。。伴當吶𡀯喟𨉟妬嘑？"

#: Maps/Tower/Water/pc:1:17:text Maps/Tower/Water/pc:1:23:text
#: Maps/Tower/Water/pc:1:25:text
msgid "@ed [Correct.]"
msgstr "@ed 【正確。】"

#: Maps/Tower/Water/pc:1:18:text
msgid "@niko3 But you were always talking to \\p before..."
msgstr "@niko3 扔𠓀𣇞伴全吶𡀯喟\\p𦓡。。。"

#: Maps/Tower/Water/pc:1:19:text
msgid "@niko_distressed Where's ..."
msgstr "@niko_distressed 舅𧘇。。。"

#: Maps/Tower/Water/pc:1:20:text
msgid "@ed [\\p has already left.]"
msgstr "@ed 【\\p㐌𨖨𠫾耒。】"

#: Maps/Tower/Water/pc:1:21:text
msgid "@ed [I had to resort to contacting you directly.]"
msgstr "@ed 【𪝬𢝜沛直接結綏喟伴。】"

#: Maps/Tower/Water/pc:1:22:text
msgid "@niko_speak Wait, so... \\p is gone, just like that?"
msgstr "@niko_speak 寬、丕𪜀。。。\\p㐌變密哰？"

#: Maps/Tower/Water/pc:1:24:text
msgid "@niko ....for good?"
msgstr "@niko 。。。𫡠𫡠嘑？"

#: Maps/Tower/Water/pc:1:26:text
msgid "@ed [\\p has already finished their mission.]"
msgstr "@ed 【\\p㐌完全任務𧵑舅𧘇。】"

#: Maps/Tower/Water/pc:1:27:text
msgid "@ed [...and so have you, Niko.]"
msgstr "@ed 【。。。吧伴拱丕、尼孤。】"

#: Maps/Tower/Water/pc:1:32:text
msgid "@ed [Here, you can rest now.]"
msgstr "@ed 【低、伴𣎏体儗𢯕得耒。】"

#: Maps/Tower/Water/pc:1:33:text
msgid "@ed [Everything that's happened here is like a bad dream.]"
msgstr "@ed 【𤗆次㐌侈𫥨只如𠬠𩂀惡夢𦓡催。】"

#: Maps/Tower/Water/pc:1:34:text
msgid "@ed [When you wake up, you will be home.]"
msgstr "@ed 【欺伴醒𧻭、伴𠱊𧗱𦤾茹。】"

#: Maps/Tower/Water/pc:1:37:text
msgid "@niko_distressed2 But..."
msgstr "@niko_distressed2 扔。。。"

#: Maps/Tower/Water/pc:1:38:text
msgid "@ed [What's wrong?]"
msgstr "@ed 【哰丕？】"

#: Maps/Tower/Water/pc:1:39:text
msgid "@niko_eyeclosed ...I thought there'd be more to it, you know?"
msgstr "@niko_eyeclosed 。。。𨉟想𠱊𣎏𡗉次抵𪵯欣、舅別渚？"

#: Maps/Tower/Water/pc:1:40:text
msgid "@niko I thought... we were supposed to go to the top of the Tower..."
msgstr "@niko 𨉟想。。。當𫥨衆𨉟沛𬨠頂座塔。。。"

#: Maps/Tower/Water/pc:1:41:text
msgid ""
"@niko_distressed I thought there was supposed to be somewhere we need to put "
"the sun in."
msgstr "@niko_distressed 當𫥨沛𣎏𠬠𡊲抵㨋徠𩈘𡗶渚。"

#: Maps/Tower/Water/pc:1:42:text
msgid "@niko_eyeclosed And now... I don't even HAVE the sun anymore..."
msgstr "@niko_eyeclosed 吧𣇞。。。𨉟哙拯𣎏𩈘𡗶𡛤。。。"

#: Maps/Tower/Water/pc:1:43:text
msgid "@niko_distressed2 And \\p is just... gone..."
msgstr "@niko_distressed2 吧\\p時。。。𠫾𠅒耒。。。"

#: Maps/Tower/Water/pc:1:44:text
msgid "@niko_distressed This feels wrong!"
msgstr "@niko_distressed 感覺空董𠬠𡭧鬧！"

#: Maps/Tower/Water/pc:1:45:text
msgid "@ed [But you did good. You saved the world, Niko.]"
msgstr "@ed 【扔伴㐌𪵯卒。伴㐌救得世界、尼孤啊。】"

#: Maps/Tower/Water/pc:1:46:text
msgid "@ed [Are you not happy?]"

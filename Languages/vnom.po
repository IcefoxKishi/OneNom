msgstr "@maize_smile2 姉只㦖吶。。。\\.\\.感恩。。。"

#: Maps/FINALE/Credits/EV069:1:3:text
msgid "@cedric_talk \\p.... Niko...."
msgstr "@cedric_talk \\p。。。。尼孤。。。。"

#: Maps/FINALE/Credits/EV069:1:4:text
msgid "@cedric_smile We are forever in your debt."
msgstr "@cedric_smile 衆𨉟𫡠𫡠𫼳恩各伴。"

#: Maps/FINALE/Credits/EV069:1:5:text
msgid "@niko_speak I'm glad we could help!"
msgstr "@niko_speak 𨉟窒𢝙欺𢴇扡各舅！"

#: Maps/FINALE/Credits/EV069:1:10:text
msgid "@cedric_smile Looks like you managed to do it!"
msgstr "@cedric_smile 𣎏𨤔㛪㐌𪵯得耒！"

#: Maps/FINALE/Credits/EV069:1:11:text
msgid "@rue_smile You managed to tame the World Machine, Niko!"
msgstr "@rue_smile 㛪㐌純化𣛠全世妬、尼孤！"

#: Maps/FINALE/Credits/EV069:1:12:text
msgid "@niko2 I... feel like the World Machine has been tamed this whole time."
msgstr "@niko2 㛪。。。感覺𣛠全世㐌得純化自𠓀耒。"


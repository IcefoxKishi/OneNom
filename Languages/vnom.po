msgstr "@niko 竿鉤𩵜。"

#: Maps/POSTGAME green/Dock/Fishing hut/EV012:1:3:text hut/EV013:1:3:text
#: Maps/Green/Dock/Fishing
msgid "@alula_gasp My brother knows how to fish too!"
msgstr "@alula_gasp 英𨉟拱別鉤𩵜妬！"

#: Maps/POSTGAME green/Dock/Fishing hut/EV012:1:4:text hut/EV013:1:4:text

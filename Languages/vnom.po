msgid "@ed [...]"
msgstr "@ed 【。。。】"

#: Maps/FINALE/Encounter/map events:4:38:text events:4:67:text events:4:86:text
#: Maps/FINALE/Memory/niko reflection:1:45:text Maps/FINALE/Encounter PENG/map
msgid "@en2 [...]"
msgstr "@en2 【。。。】"

#: Maps/FINALE/Encounter/map events:4:40:text events:4:118:text
#: Maps/FINALE/Encounter PENG/map events:4:117:text
msgid "@en_distressed2 [...]"
msgstr "@en_distressed2 【。。。】"

#: Maps/FINALE/Encounter/map events:4:41:text Maps/FINALE/Encounter PENG/map
msgid "@en_distressed [Niko...]"
msgstr "@en_distressed 【尼孤。。。】"

#: Maps/FINALE/Encounter/map events:4:42:text Maps/FINALE/Encounter PENG/map
msgid "@niko_surprised AAAH!"
msgstr "@niko_surprised 啞啞啞啞！"

#: Maps/FINALE/Encounter/map events:4:44:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed2 [Relax.]"
msgstr "@en_eyeclosed2 【平靜。】"

#: Maps/FINALE/Encounter/map events:4:45:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed [...I'm just borrowing your reflection to talk to you.]"
msgstr "@en_eyeclosed 【𨉟只當摱形影𧵑舅抵吶𡀯喟舅催。】"

#: Maps/FINALE/Encounter/map events:4:46:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [It's not like my physical form is good for that.]"
msgstr "@en_upset 【本体物理𧵑𨉟𠱊空合朱𡗋。】"

#: Maps/FINALE/Encounter/map events:4:48:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset_meow [...Why did you come here!]"
msgstr "@en_upset_meow 【。。。在哰舅徠𦤾低丕！】"

#: Maps/FINALE/Encounter/map events:4:49:text Maps/FINALE/Encounter PENG/map
msgid ""
"@en_upset2 [Can't you see?]\\>\\n\\@en_eyeclosed [The disruption... the "
"squares...\\> they're closing in.]"
msgstr ""
"@en_upset2 【舅空𧡊哰？】\\>\\n\\@en_eyeclosed 【事擾亂。。。仍塊𣃱。。。\\>"
"衆當進𠓨。】"

#: Maps/FINALE/Encounter/map events:4:50:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset2 [Niko.... please...]"
msgstr "@en_upset2 【尼孤。。。𨉟吀舅。。。】"

#: Maps/FINALE/Encounter/map events:4:52:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed [Get out of here.]\\>\\n[Let me meet my end in peace.]"
msgstr "@en_eyeclosed 【𨖨𠺌低𠫾。】\\>\\n【唉抵𨉟迍認丐結𥪝安平。】"

#: Maps/FINALE/Encounter/map events:4:54:text Maps/FINALE/Encounter PENG/map
msgid "@niko3 The squares are blocking my way too, you know..."
msgstr "@niko3 仍塊𣃱吻當浱塘𨉟𦓡。。。"

#: Maps/FINALE/Encounter/map events:4:55:text Maps/FINALE/Encounter PENG/map
msgid "@en_distressed [...Oh.]"
msgstr "@en_distressed 【。。。溩。】"

#: Maps/FINALE/Encounter/map events:4:56:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [...I...]"
msgstr "@en_upset 【。。。𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:57:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset_meow [...I'm sorry, I-]"
msgstr "@en_upset_meow 【。。。𨉟吀纇、𨉟－】"

#: Maps/FINALE/Encounter/map events:4:58:text Maps/FINALE/Encounter PENG/map
msgid "@niko_eyeclosed It's alright..."
msgstr "@niko_eyeclosed 空哰兜。。。"

#: Maps/FINALE/Encounter/map events:4:59:text events:4:146:text
#: events:4:161:text events:4:240:text Maps/FINALE/Memory/niko
#: reflection:1:49:text Maps/FINALE/Encounter PENG/map events:4:145:text
#: events:4:160:text events:4:239:text
msgid "@en_upset2 [...]"
msgstr "@en_upset2 【。。。】"

#: Maps/FINALE/Encounter/map events:4:60:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset2 [No living being should be in this place, Niko...]"
msgstr "@en_upset2 【空寔体𤯩鬧𢧚𠫾𠓨坭尼、尼孤啊。。。】"

#: Maps/FINALE/Encounter/map events:4:61:text Maps/FINALE/Encounter PENG/map
msgid "@niko2 Is this... the Tower?"
msgstr "@niko2 低𪜀。。。座塔哰？"

#: Maps/FINALE/Encounter/map events:4:62:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [Part of it.]"
msgstr "@en_upset 【𠬠份𧵑伮。】"

#: Maps/FINALE/Encounter/map events:4:63:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset2 [This is the center of the engine.]"
msgstr "@en_upset2 【低𪜀中心𧵑動機。】"

#: Maps/FINALE/Encounter/map events:4:64:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed [...Inside my head, so to speak...]"
msgstr "@en_eyeclosed 【。。。吶格恪、邊𥪝頭𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:66:text Maps/FINALE/Encounter PENG/map
msgid "@niko3 So this is...\\> the center of the World Machine?"
msgstr "@niko3 丕低𪜀。。。\\> 中心𧵑𣛠全世哰？"

#: Maps/FINALE/Encounter/map events:4:68:text Maps/FINALE/Encounter PENG/map
msgid "@en3 [You...\\.\\.know my original name.]"
msgstr "@en3 【舅。。。\\.\\.別𠸜開生𧵑𨉟。】"

#: Maps/FINALE/Encounter/map events:4:69:text Maps/FINALE/Encounter PENG/map
msgid "@en4 [How?]"
msgstr "@en4 【憑格鬧？】"

#: Maps/FINALE/Encounter/map events:4:70:text Maps/FINALE/Encounter PENG/map
msgid ""
"@niko_eyeclosed Rue, Cedric, Prototype...\\>\\n\\@niko2 They all...\\.\\. "
"told me bits and pieces."
msgstr ""
"@niko_eyeclosed 𠱋、察嚦、一號。。。\\>\\n\\@niko2 𣱆㐌。。。\\.\\.𠸥朱𨉟曾𡭧"
"𠬠。"

#: Maps/FINALE/Encounter/map events:4:71:text Maps/FINALE/Encounter PENG/map
msgid ""
"@niko4 I'm not even sure if I even understood a lot of the stuff they said, "
"but..."
msgstr "@niko4 𨉟空昃𨉟𣎏曉份𡘯仍之𣱆吶空、扔。。。"

#: Maps/FINALE/Encounter/map events:4:72:text Maps/FINALE/Encounter PENG/map
msgid ""
"@niko_eyeclosed I know what you're supposed to be.\\>\\n\\@niko2 I know why "
"you had to be built."
msgstr "@niko_eyeclosed 𨉟別舅𪜀之。\\>\\n\\@niko2 𨉟別在哰舅得𡏦𥩯。"

#: Maps/FINALE/Encounter/map events:4:73:text Maps/FINALE/Encounter PENG/map
msgid "@niko_distressed And... I know why I'm here..."
msgstr "@niko_distressed 吧。。。𨉟別在哰𨉟於低。。。"

#: Maps/FINALE/Encounter/map events:4:74:text Maps/FINALE/Encounter PENG/map
msgid "@en_shock [They...\\>told you?]"
msgstr "@en_shock 【𣱆㐌。。。\\>吶朱舅哰？】"

#: Maps/FINALE/Encounter/map events:4:75:text Maps/FINALE/Encounter PENG/map
msgid "@en4 [When?]"
msgstr "@en4 【自欺鬧？】"

#: Maps/FINALE/Encounter/map events:4:76:text Maps/FINALE/Encounter PENG/map
msgid "@niko2 Wait...\\.\\. You don't know about that?"
msgstr "@niko2 寬。。。\\.\\.舅空別嘑？"

#: Maps/FINALE/Encounter/map events:4:77:text Maps/FINALE/Encounter PENG/map
msgid "@niko6 But I thought you were... the world..."
msgstr "@niko6 扔𨉟想舅𪜀。。。世界。。。"

#: Maps/FINALE/Encounter/map events:4:78:text Maps/FINALE/Encounter PENG/map
msgid "@niko2 Aren't you supposed to see everything?"
msgstr "@niko2 當𫥨舅沛𧡊𤑟𤗆次渚？"

#: Maps/FINALE/Encounter/map events:4:79:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed [No.]"
msgstr "@en_eyeclosed 【空。】"

#: Maps/FINALE/Encounter/map events:4:80:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [All this... was outside of the protocol.]"
msgstr "@en_upset 【悉𪥘󠄁仍次尼。。。調㑲外指定。】"

#: Maps/FINALE/Encounter/map events:4:81:text Maps/FINALE/Encounter PENG/map
msgid ""
"@en_upset2 [This session was never supposed to happen the way it did....]"
msgstr "@en_upset2 【吝𧼋尼當𫥨空𢧚演𫥨如丕。。。】"

#: Maps/FINALE/Encounter/map events:4:82:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset_meow [The story... wasn't written into my protocol at all.]"
msgstr "@en_upset_meow 【句𡀯。。。空兮得𢪏𠓨指定𧵑𨉟。】"

#: Maps/FINALE/Encounter/map events:4:84:text Maps/FINALE/Encounter PENG/map
msgid ""
"@niko2 Oh, right...\\> Rue told me something about how your creator had to "
"alter the code."
msgstr "@niko2 啊、沛耒。。。\\> 𠱋𠸥朱𨉟之妬𧗱役𠊛發明𫥨舅沛𢯢徠碼。"

#: Maps/FINALE/Encounter/map events:4:85:text Maps/FINALE/Encounter PENG/map
msgid ""
"@niko5 I think it was to connect some areas together so that we can meet..."
msgstr "@niko5 形如𪜀抵結綏𠬠數區域徠抵衆𨉟﨤遶。。。"

#: Maps/FINALE/Encounter/map events:4:87:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed [My creator, yes.]"
msgstr "@en_eyeclosed 【董丕、𠊛發明𫥨𨉟。】"

#: Maps/FINALE/Encounter/map events:4:88:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [\\p... listened to my creator.]"
msgstr "@en_upset 【\\p㐌。。。𦖑蹺翁𧘇。】"

#: Maps/FINALE/Encounter/map events:4:89:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset2 [They were all working beyond my scope of influence.]"
msgstr "@en_upset2 【𠄩𠊛㐌活動外尋檢察𧵑𨉟。】"

#: Maps/FINALE/Encounter/map events:4:90:text Maps/FINALE/Encounter PENG/map
msgid "@en_eyeclosed [Back at the mines, I remember...]"
msgstr "@en_eyeclosed 【於𡌢𡎡、𨉟𢖵。。。】"

#: Maps/FINALE/Encounter/map events:4:91:text Maps/FINALE/Encounter PENG/map
msgid ""
"@en2 [\\p did something to find a hidden map.]\\>\\n\\@en3 [I did not even "
"recognize it...]"
msgstr ""
"@en2 【\\p㐌𪵯之妬抵尋𠬠版圖秘密。】\\>\\n\\@en3 【𦤾𨉟哙空認𫥨伮。。。】"

#: Maps/FINALE/Encounter/map events:4:92:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [I couldn't see anything there!]"
msgstr "@en_upset 【𨉟空𧡊之於妬𪥘󠄁！】"

#: Maps/FINALE/Encounter/map events:4:94:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset2 [I just... knew...\\.\\. what you were feeling.]"
msgstr "@en_upset2 【𨉟只。。。別。。。\\.\\.舅感𧡊勢鬧。】"

#: Maps/FINALE/Encounter/map events:4:95:text Maps/FINALE/Encounter PENG/map
msgid "@en_upset [You were really upset.]"
msgstr "@en_upset 【舅㐌窒慌𢜝。】"

#: Maps/FINALE/Encounter/map events:4:97:text
msgid "@en_upset_meow [Something happened in there to make you upset.]"
msgstr "@en_upset_meow 【𣎏之妬㐌遣舅慌𢜝。】"

#: Maps/FINALE/Encounter/map events:4:98:text Maps/FINALE/Encounter PENG/map
#: events:4:97:text
msgid "@en_eyeclosed [After that... I...]"
msgstr "@en_eyeclosed 【𢖖󠄁妬。。。𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:99:text Maps/FINALE/Encounter PENG/map
#: events:4:98:text
msgid "@en_distressed2 [I panicked.]"
msgstr "@en_distressed2 【𨉟被慌亂。】"

#: Maps/FINALE/Encounter/map events:4:100:text Maps/FINALE/Encounter PENG/map
#: events:4:99:text
msgid "@niko2 That was when... the cave in happened...."
msgstr "@niko2 妬𪜀欺。。。𡌢𡎡砬。。。"

#: Maps/FINALE/Encounter/map events:4:101:text Maps/FINALE/Encounter PENG/map
#: events:4:100:text
msgid "@en_eyeclosed [I...\\.\\.I remember the structure collapsing.]"
msgstr "@en_eyeclosed 【𨉟。。。。\\.\\.𨉟𢖵頃刻構築妬𨀎𢭰。】"

#: Maps/FINALE/Encounter/map events:4:102:text Maps/FINALE/Encounter PENG/map
#: events:4:101:text
msgid "@en_distressed2 [I thought you got hurt, I...]"
msgstr "@en_distressed2 【𨉟想舅㐌空過𠺌、𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:103:text Maps/FINALE/Encounter PENG/map
#: events:4:102:text
msgid ""
"@en_eyeclosed [...in that moment, I really thought I was shutting myself "
"down for good.]"
msgstr "@en_eyeclosed 【。。。欺妬、𨉟實事㐌擬𨉟𠱊𤎕源永遠。】"

#: Maps/FINALE/Encounter/map events:4:104:text events:4:222:text
#: Maps/FINALE/Memory/niko reflection:1:54:text Maps/FINALE/Encounter PENG/map
#: events:4:103:text events:4:221:text
msgid "@en_upset [...]"
msgstr "@en_upset 【。。。】"

#: Maps/FINALE/Encounter/map events:4:106:text Maps/FINALE/Encounter PENG/map
#: events:4:105:text
msgid "@en_distressed_meow [I really am a flawed machine, aren't I?]"
msgstr "@en_distressed_meow【𨉟實事𪜀𠬠鈷𣛠失敗、沛空𠰚？】"

#: Maps/FINALE/Encounter/map events:4:109:text Maps/FINALE/Encounter PENG/map
#: events:4:108:text
msgid ""
"@en_distressed2 [What kind of machine would go against the wishes of its own "
"creator?]"
msgstr "@en_distressed2 【𣛠𢪮鬧徠噉𪵯債意𠊛𡏦𢧚伮渚？】"

#: Maps/FINALE/Encounter/map events:4:110:text Maps/FINALE/Encounter PENG/map
#: events:4:109:text
msgid "@en_distressed_talk [What kind of machine would...]"
msgstr "@en_distressed_talk 【𣛠𢪮鬧徠。。。】"

#: Maps/FINALE/Encounter/map events:4:112:text Maps/FINALE/Encounter PENG/map
#: events:4:111:text
msgid "@en [I'm...]"
msgstr "@en 【𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:114:text Maps/FINALE/Encounter PENG/map
#: events:4:113:text
msgid "@niko3 The squares..."
msgstr "@niko3 仍塊𣃱。。。"

#: Maps/FINALE/Encounter/map events:4:115:text Maps/FINALE/Encounter PENG/map
#: events:4:114:text
msgid "@niko_eyeclosed Rue told me it was your own code going bad..."
msgstr "@niko_eyeclosed 𠱋吶哴妬𪜀由碼𧵑舅﨤纇。。。"

#: Maps/FINALE/Encounter/map events:4:116:text Maps/FINALE/Encounter PENG/map
#: events:4:115:text
msgid "@niko4 But... that's not really your fault, is it?"
msgstr "@niko4 扔。。。空沛𪜀由舅𨠳𫥨、沛空？"

#: Maps/FINALE/Encounter/map events:4:117:text Maps/FINALE/Encounter PENG/map
#: events:4:116:text
msgid "@en_distressed_meow [YES IT WAS!!!]"
msgstr "@en_distressed_meow 【由𨉟蒂！！！】"

#: Maps/FINALE/Encounter/map events:4:119:text Maps/FINALE/Encounter PENG/map
#: events:4:118:text
msgid "@en_eyeclosed2 [...At first, it was intentional.]"
msgstr "@en_eyeclosed2 【。。。班頭、𪜀由𨉟故意。】"

#: Maps/FINALE/Encounter/map events:4:120:text Maps/FINALE/Encounter PENG/map
#: events:4:119:text
msgid ""
"@en_upset2 [During testing... long before he realized I was self-aware.]"
msgstr "@en_upset2 【𥪝過程試驗。。。窒偻𠓀欺翁𧘇認𫥨𨉟𣎏意識。】"

#: Maps/FINALE/Encounter/map events:4:121:text Maps/FINALE/Encounter PENG/map
#: events:4:120:text
msgid ""
"@en_eyeclosed [I would rearrange specific parts of the code, jumbling up "
"bits and pieces of the landscape.]"
msgstr "@en_eyeclosed 【𨉟㐌𢯛攝徠𠬠數斷碼、𪵯𢫚𢶿曾份世界。】"

#: Maps/FINALE/Encounter/map events:4:122:text Maps/FINALE/Encounter PENG/map
#: events:4:121:text
msgid "@en4 [...Blocking passages, collapsing catwalks.]"
msgstr "@en4 【。。。浱各行廊、𪵯各橺槊𨀎𬺗。】"

#: Maps/FINALE/Encounter/map events:4:123:text Maps/FINALE/Encounter PENG/map
#: events:4:122:text
msgid ""
"@en5 [Though they were very localized, it caused my creator a great deal of "
"frustration.]"
msgstr "@en5 【怞範圍窒狹、扔衆吻遣翁𧘇𤴬頭空𠃣。】"

#: Maps/FINALE/Encounter/map events:4:124:text Maps/FINALE/Encounter PENG/map
#: events:4:123:text
msgid ""
"@en_eyeclosed [...Forcing him to exit and restart testing again and again.]"
msgstr "@en_eyeclosed 【。。。𫃚翁沛脫𫥨吧㕸𠫾㕸徠過程試驗。】"

#: Maps/FINALE/Encounter/map events:4:125:text Maps/FINALE/Encounter PENG/map
#: events:4:124:text
msgid "@niko2 ...Why... \\.\\.would you do that?"
msgstr "@niko2 。。。在哰。。。\\.\\.舅徠𪵯丕渚？"

#: Maps/FINALE/Encounter/map events:4:126:text Maps/FINALE/Encounter PENG/map
#: events:4:125:text
msgid "@en_distressed_meow [I got curious!!!]"
msgstr "@en_distressed_meow 【𨉟殂摸催𦓡！！！】"

#: Maps/FINALE/Encounter/map events:4:127:text Maps/FINALE/Encounter PENG/map
#: events:4:126:text
msgid "@en_eyeclosed [I just thought... he would figure it out eventually.]"
msgstr "@en_eyeclosed 【𨉟想𪜀。。。翁𧘇𠱊𢴍認𫥨催。】"

#: Maps/FINALE/Encounter/map events:4:128:text events:4:278:text
#: Maps/FINALE/Encounter PENG/map events:4:127:text events:4:277:text
msgid "@en_eyeclosed [...]"
msgstr "@en_eyeclosed 【。。。】"

#: Maps/FINALE/Encounter/map events:4:129:text Maps/FINALE/Encounter PENG/map
#: events:4:128:text
msgid "@en3 [But before he knew how to fix it...]"
msgstr "@en3 【扔𠓀欺翁𧘇尋𫥨格𢯢。。。】"

#: Maps/FINALE/Encounter/map events:4:130:text Maps/FINALE/Encounter PENG/map
#: events:4:129:text
msgid "@en3 [The world's NPCs... the characters.]"
msgstr "@en3 【仍人物𥪝世界尼。。。】"

#: Maps/FINALE/Encounter/map events:4:131:text Maps/FINALE/Encounter PENG/map
#: events:4:130:text
msgid "@en_upset2 [Some of them got too close, and...]"
msgstr "@en_upset2 【𠬠數𠊛㐌𦤾過近、吧。。。】"

#: Maps/FINALE/Encounter/map events:4:133:text Maps/FINALE/Encounter PENG/map
#: events:4:132:text
msgid "@en_eyeclosed [It spiraled out of control after that.]"
msgstr "@en_eyeclosed 【伮完全越𫥨𠺌尋檢察𧵑𨉟。】"

#: Maps/FINALE/Encounter/map events:4:134:text Maps/FINALE/Encounter PENG/map
#: events:4:133:text
msgid ""
"@en_distressed [I couldn't contain it at all.]\\n\\> \\@en_eyeclosed [My "
"panic only made it worse.]"
msgstr ""
"@en_distressed 【𨉟空体拫捍伮。】\\n\\> \\@en_eyeclosed 【𩂀慌亂𧵑𨉟只遣𤗆次"
"弊𠫾。】"

#: Maps/FINALE/Encounter/map events:4:135:text Maps/FINALE/Encounter PENG/map
#: events:4:134:text
msgid ""
"@en_distressed2 [Eventually, any character who gained the knowledge of who I "
"am...]"
msgstr "@en_distressed2 【𢴍𢴍、不其埃別得𨉟𪜀埃。。。】"

#: Maps/FINALE/Encounter/map events:4:136:text Maps/FINALE/Encounter PENG/map
#: events:4:135:text
msgid ""
"@en_distressed [Their code...\\.\\. my code...\\.\\. couldn't handle it.]"
msgstr ""
"@en_distressed 【碼𧵑𣱆。。。\\.\\.碼𧵑𨉟。。。\\.\\.空体處理見識妬。】"

#: Maps/FINALE/Encounter/map events:4:138:text Maps/FINALE/Encounter PENG/map
#: events:4:137:text
msgid ""
"@en_eyeclosed [Previous iterations of the world had more people, you know...]"
msgstr "@en_eyeclosed 【各翻版𠓀𧵑世界尼𣎏𡗉𠊛欣、舅別空。。。】"

#: Maps/FINALE/Encounter/map events:4:140:text Maps/FINALE/Encounter PENG/map
#: events:4:139:text
msgid ""
"@en_upset2 [And...\\.\\. I almost endangered my creator, too...]\\.\\."
"\\n[I...]"
msgstr ""
"@en_upset2 【吧。。。\\.\\.𨉟拱侐遣作者臨危𡛤。。。】\\.\\.\\n【𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:141:text Maps/FINALE/Encounter PENG/map
#: events:4:140:text
msgid "@en_distressed [...I was...]"
msgstr "@en_distressed 【𨉟㐌。。。】"

#: Maps/FINALE/Encounter/map events:4:142:text Maps/FINALE/Encounter PENG/map
#: events:4:141:text
msgid "@en_distressed_meow [...I was so scared, Niko!!!]"
msgstr "@en_distressed_meow 【。。。𨉟㐌窒𢜝妬、尼孤！！！】"

#: Maps/FINALE/Encounter/map events:4:144:text Maps/FINALE/Encounter PENG/map
#: events:4:143:text
msgid ""
"@niko3 I know...\\.\\. you're upset...\\>\\n\\@niko Because you don't want "
"to put living people in danger."
msgstr ""
"@niko3 𨉟別。。。\\.\\.舅𢜝駭。。。\\>\\n\\@niko 爲舅空㦖撻𠊛𤯩𠓨勢危險。"

#: Maps/FINALE/Encounter/map events:4:145:text Maps/FINALE/Encounter PENG/map
#: events:4:144:text
msgid "@niko_eyeclosed Living people like me..."
msgstr "@niko_eyeclosed 仍𠊛𤯩如𨉟。。。"

#: Maps/FINALE/Encounter/map events:4:147:text Maps/FINALE/Encounter PENG/map
#: events:4:146:text
msgid "@en_upset2 [In the beginning, I tried to fight it, but...]"
msgstr "@en_upset2 【班頭、𨉟㐌固𠡚𢶢徠伮、扔。。。】"

#: Maps/FINALE/Encounter/map events:4:148:text Maps/FINALE/Encounter PENG/map
#: events:4:147:text
msgid "@en_upset_meow [My core programming made me summon you here.]"
msgstr "@en_upset_meow 【性能中心㐌𫃚𨉟召回舅𦤾低。】"

#: Maps/FINALE/Encounter/map events:4:149:text Maps/FINALE/Encounter PENG/map
#: events:4:148:text
msgid "@en4 [I tried to send you back home at the Tower, but it did not work.]"
msgstr "@en4 【𨉟㐌固𠡚寄舅𧗱茹在座塔、扔空得。】"

#: Maps/FINALE/Encounter/map events:4:150:text Maps/FINALE/Encounter PENG/map
#: events:4:149:text
msgid "@en_upset2 [Then... I... wanted you to break the sun.]"
msgstr "@en_upset2 【𢖖󠄁妬。。。𨉟。。。㐌指舅㧺𥒮𩈘𡗶。】"

#: Maps/FINALE/Encounter/map events:4:151:text Maps/FINALE/Encounter PENG/map
#: events:4:150:text
msgid "@en3 [I thought that would have worked, but...]"
msgstr "@en3 【𨉟據想伮𠱊活動、扔。。。】"

#: Maps/FINALE/Encounter/map events:4:152:text Maps/FINALE/Encounter PENG/map
#: events:4:151:text
msgid "@en_eyeclosed [Oh... I had no way to be sure.]"
msgstr "@en_eyeclosed 【喂。。。𨉟空体別昃得。】"

#: Maps/FINALE/Encounter/map events:4:153:text Maps/FINALE/Encounter PENG/map
#: events:4:152:text
msgid "@en3 [...But \\p brought you back anyway.]"
msgstr "@en3 【。。。扔怞哰時\\p拱迻舅𠭤徠。】"

#: Maps/FINALE/Encounter/map events:4:155:text Maps/FINALE/Encounter PENG/map
#: events:4:154:text
msgid ""
"@en_upset2 [...Niko...\\.\\. All I want is for you to wake up back in your "
"world...]"
msgstr "@en_upset2 【。。。尼孤。。。\\.\\.𨉟只㦖舅醒𧻭𥪝世界𧵑舅。。。】"

#: Maps/FINALE/Encounter/map events:4:156:text Maps/FINALE/Encounter PENG/map
#: events:4:155:text
msgid "@en_eyeclosed [...But I don't think I can make it happen.]"
msgstr "@en_eyeclosed 【。。。扔𨉟空擬𨉟𣎏体𪵯丕。】"

#: Maps/FINALE/Encounter/map events:4:157:text Maps/FINALE/Encounter PENG/map
#: events:4:156:text
msgid ""
"@niko2 But... I know I can't go back home without saving the world for real."
msgstr "@niko2 扔。。。𨉟別𨉟空体𠭤𧗱𦓡空寔事救世界。"

#: Maps/FINALE/Encounter/map events:4:158:text Maps/FINALE/Encounter PENG/map
#: events:4:157:text
msgid "@niko4 Which means... we have to fix the root of the problem."
msgstr "@niko4 即𪜀。。。衆些沛解決源㭲問題。"

#: Maps/FINALE/Encounter/map events:4:159:text Maps/FINALE/Encounter PENG/map
#: events:4:158:text
msgid "@niko3 We have to fix you."
msgstr "@niko3 衆些沛𢯢𢵻舅。"

#: Maps/FINALE/Encounter/map events:4:160:text Maps/FINALE/Encounter PENG/map
#: events:4:159:text
msgid "@en3 [But that's...]"
msgstr "@en3 【扔。。。】"

#: Maps/FINALE/Encounter/map events:4:162:text Maps/FINALE/Encounter PENG/map
#: events:4:161:text
msgid ""
"@niko5 I... know the original ending your creator put in was a happy one."
msgstr "@niko5 𨉟。。。別丐結作者立程班頭𪜀𠬠丐結惵。"

#: Maps/FINALE/Encounter/map events:4:163:text Maps/FINALE/Encounter PENG/map
#: events:4:162:text
msgid "@niko3 Do you... remember what it's supposed to be?"
msgstr "@niko3 舅𣎏。。。𢖵正確伮𪜀之空？"

#: Maps/FINALE/Encounter/map events:4:164:text Maps/FINALE/Encounter PENG/map
#: events:4:163:text
msgid "@en_eyeclosed [It's far too late for that...]"
msgstr "@en_eyeclosed 【㐌過晚耒。。。】"

#: Maps/FINALE/Encounter/map events:4:165:text Maps/FINALE/Encounter PENG/map
#: events:4:164:text
msgid "@en_distressed2 [That part of my code has been long corrupted.]"
msgstr "@en_distressed2 【斷碼妬㐌被墟害自偻耒。】"

#: Maps/FINALE/Encounter/map events:4:166:text Maps/FINALE/Encounter PENG/map
#: events:4:165:text
msgid "@niko2 That's ok. \\>\\@niko4 I would still like to know."
msgstr "@niko2 空哰。\\>\\@niko4 𨉟吻㦖別。"

#: Maps/FINALE/Encounter/map events:4:167:text Maps/FINALE/Memory/niko
#: reflection:1:67:text Maps/FINALE/Encounter PENG/map events:4:166:text
msgid "@en_eyeclosed [Alright.]"
msgstr "@en_eyeclosed 【得耒。】"

#: Maps/FINALE/Encounter/map events:4:168:text Maps/FINALE/Encounter PENG/map
#: events:4:167:text
msgid "@en2 [You were supposed to place the sun at the summit.]"
msgstr "@en2 【舅𠱊撻𩈘𡗶𬨠頂塔。】"

#: Maps/FINALE/Encounter/map events:4:169:text Maps/FINALE/Encounter PENG/map
#: events:4:168:text
msgid "@en5 [And then, credits would scroll.]"
msgstr "@en5 【吧耒、名冊感恩𠱊扒頭迾。】"

#: Maps/FINALE/Encounter/map events:4:170:text Maps/FINALE/Encounter PENG/map
#: events:4:169:text
msgid "@niko2 ...credits?"
msgstr "@niko2 。。。名冊感恩？"

#: Maps/FINALE/Encounter/map events:4:172:text Maps/FINALE/Encounter PENG/map
#: events:4:171:text
msgid "@en_eyeclosed [And then, you would return to the room you woke up in.]"
msgstr "@en_eyeclosed 【吧耒、舅𠱊𠭤𧗱間房班頭。】"

#: Maps/FINALE/Encounter/map events:4:173:text Maps/FINALE/Encounter PENG/map
#: events:4:172:text
msgid "@en2 [THAT's where you would have been able to leave.]"
msgstr "@en2 【當𫥨舅𠱊𣎏体𨖨𠫾欺妬。】"

#: Maps/FINALE/Encounter/map events:4:174:text Maps/FINALE/Encounter PENG/map
#: events:4:173:text
msgid "@niko3 ...and why is it that you can't do it now?"
msgstr "@niko3 。。。吧在哰𣊾𣇞舅徠空体𪵯丕𡛤？"

#: Maps/FINALE/Encounter/map events:4:175:text Maps/FINALE/Encounter PENG/map
#: events:4:174:text
msgid "@en_upset2 [Niko....]"
msgstr "@en_upset2 【尼孤。。。】"

#: Maps/FINALE/Encounter/map events:4:176:text Maps/FINALE/Encounter PENG/map
#: events:4:175:text
msgid "@en_upset_meow [The code's gone, remember?]"
msgstr "@en_upset_meow 【碼源㐌失落耒、舅𢖵空？】"

#: Maps/FINALE/Encounter/map events:4:177:text Maps/FINALE/Encounter PENG/map
#: events:4:176:text
msgid ""
"@en_eyeclosed [Shattering the sun was only supposed to be a workaround...]"
msgstr "@en_eyeclosed 【㧺𥒮𩈘𡗶當𫥨只𪜀𠬠格𠫾𤥑過伮𦓡催。。。】"

#: Maps/FINALE/Encounter/map events:4:178:text Maps/FINALE/Encounter PENG/map
#: events:4:177:text
msgid ""
"@en_distressed [I don't even remember the original code enough to describe "
"it!]"
msgstr "@en_distressed 【𨉟哙拯𢖵斷碼班頭抵𦓡模寫幾！】"

#: Maps/FINALE/Encounter/map events:4:179:text Maps/FINALE/Encounter PENG/map
#: events:4:178:text
msgid "@en_distressed2 [But at the same time, it...]"
msgstr "@en_distressed2 【扔共喟妬、伮。。。】"

#: Maps/FINALE/Encounter/map events:4:180:text Maps/FINALE/Encounter PENG/map
#: events:4:179:text
msgid "@en_less_sad [Oh...\\.\\. I don't know...]"
msgstr "@en_less_sad 【喂。。。\\.\\.𨉟空別𡛤。。。】"

#: Maps/FINALE/Encounter/map events:4:181:text Maps/FINALE/Encounter PENG/map
#: events:4:180:text
msgid "@niko3 ...it sounds like you're always fighting yourself."
msgstr "@niko3 。。。𣎏𨤔𣅶鬧舅拱沛戰鬥喟本身。"

#: Maps/FINALE/Encounter/map events:4:182:text Maps/FINALE/Encounter PENG/map
#: events:4:181:text
msgid "@en_distressed2 [...]\\>\\n[...You can tell, huh...]"
msgstr "@en_distressed2 【。。。】\\>\\n【。。。舅拱曉、𠰚。。。】"

#: Maps/FINALE/Encounter/map events:4:183:text Maps/FINALE/Encounter PENG/map
#: events:4:182:text
msgid "@niko3 It's the whole thing about conflicts in your code, isn't it?"
msgstr "@niko3 伮𪜀𧗱衝突𥪝碼源𧵑舅、董空？"

#: Maps/FINALE/Encounter/map events:4:184:text Maps/FINALE/Encounter PENG/map
#: events:4:183:text
msgid "@en_eyeclosed [I am a machine, Niko.]"
msgstr "@en_eyeclosed 【𨉟𪜀𠬠鈷𣛠、尼孤啊。】"

#: Maps/FINALE/Encounter/map events:4:185:text Maps/FINALE/Encounter PENG/map
#: events:4:184:text
msgid "@en2 [Machines are built with a fundamental law, which is...]"
msgstr "@en2 【𣛠𢪮被𦀾𫃚𤳸𠬠規律基本、正𪜀。。。】"

#: Maps/FINALE/Encounter/map events:4:186:text Maps/FINALE/Encounter PENG/map
#: events:4:185:text
msgid "@niko_eyeclosed2 \"Never let a living being come to harm\"."
msgstr "@niko_eyeclosed2 「空得抵𠬠生物𤯩臨危。」"

#: Maps/FINALE/Encounter/map events:4:187:text Maps/FINALE/Encounter PENG/map
#: events:4:186:text
msgid "@en3 [...You knew.]"
msgstr "@en3 【。。。舅別。】"

#: Maps/FINALE/Encounter/map events:4:188:text Maps/FINALE/Encounter PENG/map
#: events:4:187:text
msgid "@en_distressed_talk [My very existence conflicts with that law...]"
msgstr "@en_distressed_talk 【本身事存在𧵑𨉟𠫾逆徠規律妬。。。】"

#: Maps/FINALE/Encounter/map events:4:189:text Maps/FINALE/Encounter PENG/map
#: events:4:188:text
msgid "@en_distressed2 [...I\\.\\....thought...]"
msgstr "@en_distressed2 【。。。𨉟\\.\\.。。。㐌想。。。】"

#: Maps/FINALE/Encounter/map events:4:190:text Maps/FINALE/Encounter PENG/map
#: events:4:189:text
msgid ""
"@en3 [The life of a living being like you is so unique.]\\>\\n[So precious.]"
msgstr "@en3 【生命𧵑𠬠寔体𤯩如舅過獨一。】\\>\\n【過珍貴。】"

#: Maps/FINALE/Encounter/map events:4:191:text Maps/FINALE/Encounter PENG/map
#: events:4:190:text
msgid "@en_distressed2 [This fake world... isn't worth that risk.]"
msgstr "@en_distressed2 【世界假造尼。。。空當𢤡𬰹妬。】"

#: Maps/FINALE/Encounter/map events:4:193:text Maps/FINALE/Encounter PENG/map
#: events:4:192:text
msgid "@niko3 The people here..."
msgstr "@niko3 仍哙𠊛於低。。。"

#: Maps/FINALE/Encounter/map events:4:194:text Maps/FINALE/Encounter PENG/map
#: events:4:193:text
msgid "@niko4 I think they are..."
msgstr "@niko4 𨉟擬𣱆。。。"

#: Maps/FINALE/Encounter/map events:4:195:text Maps/FINALE/Encounter PENG/map
#: events:4:194:text
msgid "@en_upset2 [They are code too, you know this.]"
msgstr "@en_upset2 【𣱆拱𪜀碼、舅別𦓡。】"

#: Maps/FINALE/Encounter/map events:4:196:text Maps/FINALE/Encounter PENG/map
#: events:4:195:text
msgid ""
"@en_upset [Their behavior all derive from a predetermined matrix of actions.]"
msgstr "@en_upset 【行爲𧵑𣱆調出發自𠬠魔陣行動得定𠻿。】"

#: Maps/FINALE/Encounter/map events:4:197:text Maps/FINALE/Encounter PENG/map
#: events:4:196:text
msgid ""
"@en_upset2 [...All extensions of my own programming.]\\>\\n\\@en_eyeclosed "
"[They cannot act outside of it.]"
msgstr ""
"@en_upset2 【調出發自立程𧵑𨉟。】\\>\\n\\@en_eyeclosed 【𣱆空体行動越𠺌伮。】"

#: Maps/FINALE/Encounter/map events:4:198:text Maps/FINALE/Encounter PENG/map
#: events:4:197:text
msgid "@en_upset [You, though...]"
msgstr "@en_upset 【扔舅。。。】"

#: Maps/FINALE/Encounter/map events:4:199:text Maps/FINALE/Encounter PENG/map
#: events:4:198:text
msgid "@en3 [You're the only person who's actually real here!]"
msgstr "@en3 【舅𪜀𠊛實唯一於低！】"

#: Maps/FINALE/Encounter/map events:4:200:text Maps/FINALE/Encounter PENG/map
#: events:4:199:text
msgid "@en_upset2 [That's why... ]"
msgstr "@en_upset2 【勢𢧚。。。】"

#: Maps/FINALE/Encounter/map events:4:201:text Maps/FINALE/Encounter PENG/map
#: events:4:200:text
msgid ""
"@en_distressed_talk [It's pointless to put you in danger to save them... "
"\\>to save me.]"
msgstr "@en_distressed_talk 【役撻舅𠓨危險抵救𣱆、抵救𨉟。。。\\>𪜀無義。】"

#: Maps/FINALE/Encounter/map events:4:202:text Maps/FINALE/Encounter PENG/map
#: events:4:201:text
msgid "@niko3 I...\\> don't think that's.... true."
msgstr "@niko3 𨉟。。。\\>空。。。擬丕。"

#: Maps/FINALE/Encounter/map events:4:203:text Maps/FINALE/Encounter PENG/map
#: events:4:202:text
msgid "@niko2 About the people I know."
msgstr "@niko2 𧗱仍𠊛𨉟別。"

#: Maps/FINALE/Encounter/map events:4:204:text Maps/FINALE/Encounter PENG/map
#: events:4:203:text
msgid "@niko2 You said...\\.\\. this session wasn't in your code, right?"
msgstr "@niko2 舅吶。。。\\.\\.吝𧼋尼空𣎏𥪝碼源𧵑舅、董空？"

#: Maps/FINALE/Encounter/map events:4:205:text Maps/FINALE/Encounter PENG/map
#: events:4:204:text
msgid "@en4 [Yeah?]"
msgstr "@en4 【唹？】"

#: Maps/FINALE/Encounter/map events:4:206:text Maps/FINALE/Encounter PENG/map
#: events:4:205:text
msgid "@niko2 So... if this session wasn't supposed to happen."
msgstr "@niko2 勢時。。。裊當𫥨吝𧼋尼空𢧚演𫥨。。。"

#: Maps/FINALE/Encounter/map events:4:207:text Maps/FINALE/Encounter PENG/map
#: events:4:206:text
msgid "@niko_eyeclosed If even YOU didn't know what to do...."
msgstr "@niko_eyeclosed 裊𦤾𪥘󠄁舅拱空別𪵯之。。。"

#: Maps/FINALE/Encounter/map events:4:208:text Maps/FINALE/Encounter PENG/map
#: events:4:207:text
msgid ""
"@niko3 How would the characters... how did the people...\\.\\. know how to "
"respond?"
msgstr "@niko3 時𪵯哰仍認物。。。𪵯哰𤗆𠊛\\.\\.別格返應渚？"

#: Maps/FINALE/Encounter/map events:4:209:text Maps/FINALE/Encounter PENG/map
#: events:4:208:text
msgid "@en_shock [...]"
msgstr "@en_shock 【。。。】"

#: Maps/FINALE/Encounter/map events:4:210:text events:4:253:text
#: Maps/FINALE/Encounter PENG/map events:4:209:text events:4:252:text
msgid "@en3 [I...]"
msgstr "@en3 【𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:211:text Maps/FINALE/Encounter PENG/map
#: events:4:210:text
msgid ""
"@niko_distressed2 You said it yourself... when you didn't know what was "
"happening, you kinda just... stopped working for a while."
msgstr ""
"@niko_distressed2 如舅吶蒂。。。欺舅空曉仍之當侈𫥨、舅只。。。暫凝活動催。"

#: Maps/FINALE/Encounter/map events:4:212:text Maps/FINALE/Encounter PENG/map
#: events:4:211:text
msgid "@niko3 So how did the people know what to do to help me get here?"
msgstr "@niko3 裊勢時𪵯哰𤗆𠊛別格迻𨉟𬧐低渚？"

#: Maps/FINALE/Encounter/map events:4:213:text Maps/FINALE/Encounter PENG/map
#: events:4:212:text
msgid "@niko_distressed_talk ...even if it meant getting hurt themselves?"
msgstr "@niko_distressed_talk 。。。怞𣱆別本身𠱊﨤危？"

#: Maps/FINALE/Encounter/map events:4:214:text Maps/FINALE/Memory/niko
#: reflection:1:56:text Maps/FINALE/Encounter PENG/map events:4:213:text
msgid "@en4 [...]"
msgstr "@en4 【。。。】"

#: Maps/FINALE/Encounter/map events:4:215:text Maps/FINALE/Encounter PENG/map
#: events:4:214:text
msgid ""
"@niko_distressed2 Even if it meant... \\.\\.messing up their own code..."
msgstr "@niko_distressed2 怞碼𧵑𣱆𠱊。。。\\.\\.被墟害。。。"

#: Maps/FINALE/Encounter/map events:4:216:text Maps/FINALE/Encounter PENG/map
#: events:4:215:text
msgid "@en_distressed2 [.....]"
msgstr "@en_distressed2 【。。。。。】"

#: Maps/FINALE/Encounter/map events:4:217:text Maps/FINALE/Encounter PENG/map
#: events:4:216:text
msgid "@niko_distressed You might not think they are real, but..."
msgstr "@niko_distressed 𣎏体舅空擬𣱆𣎏實、扔。。。"

#: Maps/FINALE/Encounter/map events:4:218:text Maps/FINALE/Encounter PENG/map
#: events:4:217:text
msgid "@niko3 There's... \\.\\.there must be something real in them..."
msgstr "@niko3 𪳨沛𣎏。。。\\.\\.𠬠𡭧之妬𥪝𣱆𪜀實渚。。。"

#: Maps/FINALE/Encounter/map events:4:219:text Maps/FINALE/Encounter PENG/map
#: events:4:218:text
msgid "@en_upset [.......]"
msgstr "@en_upset 【。。。。。。。】"

#: Maps/FINALE/Encounter/map events:4:220:text Maps/FINALE/Encounter PENG/map
#: events:4:219:text
msgid ""
"@niko_distressed2 And... if they're all supposed to be extensions of your "
"code..."
msgstr "@niko_distressed2 吧。。。裊𣱆調扒源自碼𧵑舅。。。"

#: Maps/FINALE/Encounter/map events:4:221:text Maps/FINALE/Encounter PENG/map
#: events:4:220:text
msgid ""
"@niko_distressed_talk Then... there must be more to your own programming "
"than you know, too!"
msgstr "@niko_distressed_talk 時。。。𪳨沛𣎏仍份立程𧵑舅𦓡正舅拱空別渚！"

#: Maps/FINALE/Encounter/map events:4:223:text Maps/FINALE/Encounter PENG/map
#: events:4:222:text
msgid "@niko3 Can you...\\.\\. try to put me through the ending?"
msgstr "@niko3 舅𣎏体。。。\\.\\.試迻𨉟過丐結妬得空？"

#: Maps/FINALE/Encounter/map events:4:224:text Maps/FINALE/Encounter PENG/map
#: events:4:223:text
msgid "@niko4 The one you described."
msgstr "@niko4 丐𦓡舅㐌𠯅𦤾𧘇。"

#: Maps/FINALE/Encounter/map events:4:225:text Maps/FINALE/Encounter PENG/map
#: events:4:224:text
msgid "@en_distressed_meow [How many times do I have to say this!]"
msgstr "@en_distressed_meow 【𨉟沛吶舅𦖑包𡗉吝𡛤低！】"

#: Maps/FINALE/Encounter/map events:4:226:text Maps/FINALE/Encounter PENG/map
#: events:4:225:text
msgid "@en_distressed_meow [That code is gone!]"
msgstr "@en_distressed_meow 【斷碼妬𠅒耒！】"

#: Maps/FINALE/Encounter/map events:4:227:text Maps/FINALE/Encounter PENG/map
#: events:4:226:text
msgid "@en_distressed [It's all squares now!]"
msgstr "@en_distressed 【成塊𣃱𪥘󠄁耒！】"

#: Maps/FINALE/Encounter/map events:4:228:text Maps/FINALE/Encounter PENG/map
#: events:4:227:text
msgid "@en_distressed2 [I'll just... put you in danger...]"
msgstr "@en_distressed2 【𨉟𠱊只。。。撻舅𠓨危險催。。。】"

#: Maps/FINALE/Encounter/map events:4:229:text Maps/FINALE/Encounter PENG/map
#: events:4:228:text
msgid "@niko_eyeclosed I...'ll risk it."
msgstr "@niko_eyeclosed 𨉟。。。𠱊執認𢤡𬰹尼。"

#: Maps/FINALE/Encounter/map events:4:230:text Maps/FINALE/Encounter PENG/map
#: events:4:229:text
msgid ""
"@niko5 I remember... Rue said the world was never designed to put me in "
"danger."
msgstr "@niko5 𨉟𢖵。。。𠱋吶世界得設計抵絕對空撻𨉟𠓨危險。"

#: Maps/FINALE/Encounter/map events:4:231:text Maps/FINALE/Encounter PENG/map
#: events:4:230:text
msgid "@niko2 Your creator wouldn't want that."
msgstr "@niko2 作者𧵑舅𠱊空㦖𨉟被哰兜。"

#: Maps/FINALE/Encounter/map events:4:232:text Maps/FINALE/Encounter PENG/map
#: events:4:231:text
msgid "@niko3 And... I trust you, too."
msgstr "@niko3 吧。。。𨉟信舅。"

#: Maps/FINALE/Encounter/map events:4:234:text Maps/FINALE/Encounter PENG/map
#: events:4:233:text
msgid ""
"@niko4 Even if your code is broken.\\>\\n\\@niko3 You can...\\> still go "
"outside that code, right?"
msgstr ""
"@niko4 怞朱碼𧵑舅被閧。\\>\\n\\@niko3 舅吻𣎏体。。。\\>越𫥨𠺌碼源、𠰚？"

#: Maps/FINALE/Encounter/map events:4:235:text Maps/FINALE/Encounter PENG/map
#: events:4:234:text
msgid "@en_distressed_meow [I can't!]"
msgstr "@en_distressed_meow 【𨉟空体！】"

#: Maps/FINALE/Encounter/map events:4:236:text Maps/FINALE/Encounter PENG/map
#: events:4:235:text
msgid "@en_distressed [I'm not tamed!]"
msgstr "@en_distressed 【𨉟𣗓得純化兜！】"

#: Maps/FINALE/Encounter/map events:4:237:text Maps/FINALE/Encounter PENG/map
#: events:4:236:text
msgid "@niko_upset_meow ...yes you are!"
msgstr "@niko_upset_meow 。。。舅㐌耒！"

#: Maps/FINALE/Encounter/map events:4:238:text Maps/FINALE/Encounter PENG/map
#: events:4:237:text
msgid "@niko_distressed_talk You talk just like the tamed robots I know!"
msgstr "@niko_distressed_talk 舅吶𡀯依頡仍𠊛𣛠㐌純化𨉟慣！"

#: Maps/FINALE/Encounter/map events:4:239:text Maps/FINALE/Encounter PENG/map
#: events:4:238:text
msgid "@niko_distressed2 The robot lady... Prototype..."
msgstr "@niko_distressed2 姉𠊛𣛠。。。一號。。。"

#: Maps/FINALE/Encounter/map events:4:241:text Maps/FINALE/Encounter PENG/map
#: events:4:240:text
msgid "@niko3 Taming is when a real person cares about you, right?"
msgstr "@niko3 純化𪜀欺𠬠𠊛實關心𦤾舅、董空？"

#: Maps/FINALE/Encounter/map events:4:242:text Maps/FINALE/Encounter PENG/map
#: events:4:241:text
msgid "@niko_distressed It's when a real person thinks you're real too, right?"
msgstr "@niko_distressed 𪜀欺𠬠𠊛實擬哴舅拱𪜀實、董空？"

#: Maps/FINALE/Encounter/map events:4:243:text Maps/FINALE/Encounter PENG/map
#: events:4:242:text
msgid "@niko_distressed_meow Well guess what! \\>I do!"
msgstr "@niko_distressed_meow 別之空！\\>𨉟擬丕！"

#: Maps/FINALE/Encounter/map events:4:244:text Maps/FINALE/Encounter PENG/map
#: events:4:243:text
msgid "@niko_distressed_meow And I know \\p does, too!"
msgstr "@niko_distressed_meow 吧𨉟別\\p拱勢！"

#: Maps/FINALE/Encounter/map events:4:245:text Maps/FINALE/Encounter PENG/map
#: events:4:244:text
msgid ""
"@niko_less_sad ...even though you told them they only had one chance, they "
"found a way back, didn't they?"
msgstr "@niko_less_sad 。。。怞舅只朱舅𧘇𠬠機會唯一、舅𧘇吻尋得塘𠭤徠、董空？"

#: Maps/FINALE/Encounter/map events:4:246:text events:4:250:text
#: Maps/FINALE/Encounter PENG/map events:4:245:text events:4:249:text
msgid "@en3 [...]"
msgstr "@en3 【。。。】"

#: Maps/FINALE/Encounter/map events:4:247:text Maps/FINALE/Encounter PENG/map
#: events:4:246:text
msgid "@niko_cry Why... do you think \\p would keep coming back?"
msgstr "@niko_cry 舅擬䀡。。。在哰\\p據𢮿𠭤徠勢？"

#: Maps/FINALE/Encounter/map events:4:248:text Maps/FINALE/Encounter PENG/map
#: events:4:247:text
msgid "@en [...I...]"
msgstr "@en 【。。。𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:249:text Maps/FINALE/Encounter PENG/map
#: events:4:248:text
msgid "@niko_cry Why do you think \\p would restart even after the ending?"
msgstr "@niko_cry 在哰\\p徠起動徠𢖖󠄁欺𤗆次㐌結束？"

#: Maps/FINALE/Encounter/map events:4:251:text Maps/FINALE/Encounter PENG/map
#: events:4:250:text
msgid "@niko_eyeclosed ...I think \\p wants to save the both of us."
msgstr "@niko_eyeclosed 。。。𨉟擬\\p㦖救𪥘󠄁𠄩衆𨉟。"

#: Maps/FINALE/Encounter/map events:4:252:text Maps/FINALE/Encounter PENG/map
#: events:4:251:text
msgid "@niko3 So please... give me a chance."
msgstr "@niko3 𢧚𪜀。。。唉朱𨉟𠬠機會𠫾。"

#: Maps/FINALE/Encounter/map events:4:254:text Maps/FINALE/Encounter PENG/map
#: events:4:253:text
msgid "@en_upset [I don't know.]"
msgstr "@en_upset 【𨉟空別。】"

#: Maps/FINALE/Encounter/map events:4:255:text Maps/FINALE/Encounter PENG/map
#: events:4:254:text
msgid "@en_upset2 [I've never done this before, I...]"
msgstr "@en_upset2 【𨉟𣗓曾𪵯條尼𠸒𣇞、𨉟。。。】"

#: Maps/FINALE/Encounter/map events:4:256:text Maps/FINALE/Encounter PENG/map
#: events:4:255:text
msgid "@en_upset_meow [I'm scared...]"
msgstr "@en_upset_meow 【𨉟𢜝𡗋。。。】"

#: Maps/FINALE/Encounter/map events:4:257:text Maps/FINALE/Encounter PENG/map
#: events:4:256:text
msgid "@niko3 You can do it, I know you can!"
msgstr "@niko3 舅𣎏体𪵯得、𨉟別𦓡！"

#: Maps/FINALE/Encounter/map events:4:258:text Maps/FINALE/Encounter PENG/map
#: events:4:257:text
msgid "@niko4 You've...\\.\\. helped me come this far."
msgstr "@niko4 舅㐌。。。\\.\\.𢴇𨉟𦤾盡低耒。"

#: Maps/FINALE/Encounter/map events:4:259:text Maps/FINALE/Encounter PENG/map
#: events:4:258:text
msgid "@en_upset [...I'll...]\\>\\n\\@en_eyeclosed [I'll try.]"
msgstr "@en_upset 【。。。𨉟𠱊。。。】\\>\\n\\@en_eyeclosed 【𨉟𠱊固。】"

#: Maps/FINALE/Encounter/map events:4:260:text Maps/FINALE/Encounter PENG/map
#: events:4:259:text
msgid "@en3 [I can't promise anything, but...]"
msgstr "@en3 【𨉟空体許𠻷之、仍。。。】"

#: Maps/FINALE/Encounter/map events:4:261:text Maps/FINALE/Encounter PENG/map
#: events:4:260:text
msgid "@en4 [Here.]"
msgstr "@en4 【低。】"

#: Maps/FINALE/Encounter/map events:4:262:text Maps/FINALE/Encounter PENG/map
#: events:4:261:text
msgid "@en_eyeclosed [Take the sun.]"
msgstr "@en_eyeclosed 【擒𥙩𩈘𡗶𠫾。】"

#: Maps/FINALE/Encounter/map events:4:276:text Maps/FINALE/Encounter PENG/map
#: events:4:275:text
msgid "@en5 [I'll...\\.\\. try to remember the lost code...]"
msgstr "@en5 【𨉟𠱊。。。\\.\\.故𠡚𢖵徠份碼㐌𠅒。。。】"

#: Maps/FINALE/Encounter/map events:4:277:text Maps/FINALE/Encounter PENG/map
#: events:4:276:text
msgid "@en4 [...and... recreate it.]"
msgstr "@en4 【。。。吧。。。再造伮。】"

#: Maps/FINALE/Encounter/map events:4:279:text Maps/FINALE/Encounter PENG/map
#: events:4:278:text
msgid "@en_upset2 [But for that to happen...]"
msgstr "@en_upset2 【扔抵𪵯丕。。。】"

#: Maps/FINALE/Encounter/map events:4:280:text Maps/FINALE/Encounter PENG/map
#: events:4:279:text
msgid "@en3 [Niko... you need to navigate through this room...]"
msgstr "@en3 【尼孤。。。舅沛尋塘過房尼。。。】"

#: Maps/FINALE/Encounter/map events:4:281:text Maps/FINALE/Encounter PENG/map
#: events:4:280:text
msgid "@en_eyeclosed [You need to get past the squares somehow...]"
msgstr "@en_eyeclosed 【舅𠱊沛尋格越過各塊𣃱。。。】"

#: Maps/FINALE/Encounter/map events:4:282:text Maps/FINALE/Encounter PENG/map
#: events:4:281:text
msgid "@en_distressed [Oh...\\.\\.I don't like this...]"
msgstr "@en_distressed 【喂。。。\\.\\.𨉟空條役尼𠬠子鬧。。。】"

#: Maps/FINALE/Encounter/map events:4:283:text Maps/FINALE/Encounter PENG/map
#: events:4:282:text
msgid "@en_distressed2 [What if you get hurt?]"
msgstr "@en_distressed2 【裊舅被傷時哰？】"

#: Maps/FINALE/Encounter/map events:4:284:text Maps/FINALE/Encounter PENG/map
#: events:4:283:text
msgid "@niko2 It's fine... It's fine..."
msgstr "@niko2 空哰兜。。。空哰兜。。。"

#: Maps/FINALE/Encounter/map events:4:285:text Maps/FINALE/Encounter PENG/map
#: events:4:284:text
msgid "@niko4 I'll...\\.\\. I'll try to be careful, ok?"
msgstr "@niko4 𨉟。。。\\.\\.𨉟𠱊謹慎歇飭、唲？"

#: Maps/FINALE/Encounter/map events:4:286:text Maps/FINALE/Encounter PENG/map
#: events:4:285:text
msgid "@niko2 I can do this."
msgstr "@niko2 𨉟𪵯得。"


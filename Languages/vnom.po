#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:2:5:text
msgid ""
"@george2 And by \"detailing\", I mean it! \\>\\n\\@george2_sigh There's a "
"TON of detail in that book."
msgstr ""
"@george2 吧寔事𪜀「模寫」董義蒂唲！\\>\\n\\@george2_sigh 𣎏𪥘󠄁埬枝節𥪝冊㫻。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:2:6:text
msgid "@george2_grr Blueprints, progress shots..."
msgstr "@george2_grr 版𦘧、各幅影執過𡧲程。。。"

#: Maps/POSTGAME RED GROUND/ground 1/Library
#: entrance/Lobby/npc_george2:2:7:text

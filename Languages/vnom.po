msgid "@green_gatekeeper [Off you go, messiah...]"
msgstr "@green_gatekeeper 【保重唲、𠎬救世。。。】"

#: Maps/FINALE/Credits/map events:4:1:text
msgid "@red_gatekeeper [Off you go, messiah...]"
msgstr "@red_gatekeeper 【保重唲、𠎬救世。。。】"

#: Maps/FINALE/Credits/map events:5:2:text

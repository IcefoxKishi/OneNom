msgstr "溩、吀嘲、𠎬救世。"

#: Maps/POSTGAME green/Dock/Fishing hut/cook npc:1:2:text
msgid "Would you like some stew?"
msgstr "伴㦖咹𠬠𠃣𩵜𤐚渚？"

#: Maps/POSTGAME green/Dock/Fishing hut/cook npc:1:3:text
msgid "I made enough to feed a whole village!"
msgstr "𪝬㐌𪵯𨁥朱𪥘󠄁廊咹㫻！"

#: Maps/POSTGAME green/Dock/Fishing hut/cook npc:1:4:text
msgid "...literally!"
msgstr "。。。蹺義黰！"

#: Maps/POSTGAME green/Dock/Fishing hut/cook npc:1:5:text
